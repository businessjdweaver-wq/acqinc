function save(){
  try{localStorage.setItem('acqv7',JSON.stringify(S));}catch(e){}
  if(typeof schedulePush==='function')schedulePush();
}
function load(){
  try{
    var r=localStorage.getItem('acqv7');
    if(!r)r=localStorage.getItem('acqinc_v6')||localStorage.getItem('acqinc_v5');
    if(r){var d=JSON.parse(r);for(var k in d)if(d.hasOwnProperty(k))S[k]=d[k];}
  }catch(e){}
}
// Restore S from Supabase rows — called on first load when online
function loadFromSupabase(){
  return sbPull(false).catch(function(){/* offline — localStorage already loaded */});
}

/* ═══════════════════════ HELPERS ═══════════════════════ */

function esc(s){
  if(s==null)return'';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function rnd(a){return a[Math.floor(Math.random()*a.length)];}
function rndInt(a,b){return Math.floor(Math.random()*(b-a+1))+a;}
function pick(a,n){var c=a.slice(),r=[];for(var i=0;i<n&&c.length;i++){var x=Math.floor(Math.random()*c.length);r.push(c.splice(x,1)[0]);}return r;}
function todayStr(){var d=new Date();return d.getFullYear()+'-'+d.getMonth()+'-'+d.getDate();}
function openOv(id){var el=document.getElementById(id);if(el)el.classList.add('on');}
function closeOv(id){var el=document.getElementById(id);if(el)el.classList.remove('on');}

/* ═══════════════════════ GOLD & LOG ═══════════════════════ */

function setGold(){document.getElementById('gamt').textContent=S.gold.toLocaleString();}
function goldAdd(n,reason,type){
  S.gold+=n;
  logAdd('+'+n+' gp — '+reason,type||'gold');
  setGold();save();
}
function goldSpend(n,reason,type){
  if(S.gold<n){alert('Not enough gold!\nNeed: '+n+' gp\nHave: '+S.gold+' gp');return false;}
  S.gold-=n;
  logAdd('-'+n+' gp — '+reason,type||'buy');
  setGold();save();return true;
}
function logAdd(msg,type){
  var now=new Date();
  S.log.unshift({msg:msg,type:type||'gold',
    time:now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}),
    date:now.toLocaleDateString('en-US',{month:'short',day:'numeric'})});
  if(S.log.length>500)S.log.length=500;
}
function renderLog(){
  var el=document.getElementById('loglist');
  if(!S.log.length){el.innerHTML='<div class="empty">No entries yet.</div>';return;}
  el.innerHTML=S.log.map(function(e){
    return '<div class="log-row"><div class="ltime">'+e.date+'<br>'+e.time+'</div>'+
      '<div class="lmsg">'+esc(e.msg)+'</div>'+
      '<div class="ltag lt-'+e.type+'">'+e.type+'</div></div>';
  }).join('');
}

/* ═══════════════════════ TASKS ═══════════════════════ */

function sortedActive(){
  var now=Date.now();
  var mode=document.getElementById('tsort').value;
  S.active.forEach(function(t,i){t._i=i;});
  var normal=[],burner=[];
  S.active.forEach(function(t){
    if(t.burnerUntil&&t.burnerUntil>now)burner.push(t);else normal.push(t);
  });
  if(mode==='gold-hi')normal.sort(function(a,b){return b.gp-a.gp;});
  else if(mode==='gold-lo')normal.sort(function(a,b){return a.gp-b.gp;});
  else if(mode==='az')normal.sort(function(a,b){return a.name.localeCompare(b.name);});
  else if(mode==='za')normal.sort(function(a,b){return b.name.localeCompare(a.name);});
  else if(mode==='ticks')normal.sort(function(a,b){return b.count-a.count;});
  return normal.concat(burner);
}

function taskCardHtml(t,showArrows,nbIdxs){
  var now=Date.now();
  var i=t._i;
  var onBurner=t.burnerUntil&&t.burnerUntil>now;
  var brnLabel='';
  if(onBurner){
    var rm=Math.ceil((t.burnerUntil-now)/60000);
    var rl=rm<60?rm+' min':(rm%60===0?(rm/60)+' hr':Math.floor(rm/60)+' hr '+(rm%60)+' min');
    brnLabel='<div class="burner-lbl">🕐 Back burner — '+rl+' remaining</div>';
  }
  var arrows='';
  if(showArrows&&!onBurner&&nbIdxs){
    var pos=nbIdxs.indexOf(i);
    var canU=pos>0,canD=pos<nbIdxs.length-1;
    arrows='<div class="tarr">'+
      '<button data-a="up" data-i="'+i+'"'+(canU?'':' disabled')+'>▲</button>'+
      '<button data-a="dn" data-i="'+i+'"'+(canD?'':' disabled')+'>▼</button>'+
      '</div>';
  }
  var subs=t.subtasks||[];
  var subGp=subs.length?Math.max(1,Math.floor(t.gp/subs.length)):0;
  var colBtn=subs.length?'<button class="colbtn" data-a="col" data-i="'+i+'">'+(t.collapsed?'▶':'▼')+'</button> ':'';
  var subHtml='';
  var grpMenu=(S.taskGroups&&S.taskGroups.length)?
    '<button class="btn bink sm" data-a="mvgrp" data-i="'+i+'">📂</button>':'';
  if(!t.collapsed){
    var stRows=subs.map(function(s,si){
      return '<div class="strow">'+
        '<input type="checkbox" data-a="stck" data-i="'+i+'" data-si="'+si+'"'+
        (s.done?' checked':'')+' style="width:auto;min-height:0">'+
        '<span class="stname'+(s.done?' stdone':'')+'">'+esc(s.name)+'</span>'+
        '<span class="stgp">+'+subGp+' gp</span>'+
        '<button data-a="stdl" data-i="'+i+'" data-si="'+si+
        '" style="background:none;border:none;cursor:pointer;color:var(--crimson);font-size:.75em;padding:2px 4px;margin-left:auto;">✕</button>'+
        '</div>';
    }).join('');
    subHtml='<div class="stlist">'+stRows+
      '<div class="staddrow">'+
      '<input type="text" data-a="stadd-input" data-i="'+i+'" placeholder="Add sub-task…">'+
      '<button class="btn bink sm" data-a="stadd" data-i="'+i+'">+</button>'+
      '</div></div>';
  }
  return '<div class="card'+(onBurner?' dim':'')+'">'+
    '<div class="trow">'+arrows+
    '<div class="tinfo">'+
    '<div class="tname">'+colBtn+esc(t.name)+'</div>'+
    '<div class="tsub">🪙 '+t.gp+' gp/tick · '+t.count+' ticks'+
    (subs.length?' · '+subs.filter(function(s){return s.done;}).length+'/'+subs.length+' sub-tasks':'')+
    '</div>'+brnLabel+'</div>'+
    '<div class="tacts">'+
    '<button class="btn bg sm" data-a="tick" data-i="'+i+'">+'+t.gp+' gp</button>'+
    '<button class="btn bgn sm" data-a="done" data-i="'+i+'">✓ Done</button>'+
    '<button class="btn bink sm" data-a="brn" data-i="'+i+'">🕐</button>'+
    '<button class="btn bink sm" data-a="totop" data-i="'+i+'" title="Move to top">⬆Top</button>'+
    grpMenu+
    '</div></div>'+subHtml+'</div>';
}

function renderTasks(){
  var el=document.getElementById('tlist');
  var now=Date.now();
  if(!S.active.length){
    el.innerHTML='<div class="empty">No active contracts. Add one below or activate from Archive.</div>';
    return;
  }
  S.active.forEach(function(t,i){t._i=i;});
  var isManual=document.getElementById('tsort').value==='manual';
  var sorted=sortedActive();
  var groups=S.taskGroups||[];

  // Track which tasks are in groups
  var inGroup={};
  groups.forEach(function(g){
    (g.taskIds||[]).forEach(function(ti){inGroup[ti]=g.id;});
  });

  // Ungrouped sorted tasks
  var ungrouped=sorted.filter(function(t){return !inGroup[t._i];});
  var nbIdxs=ungrouped.filter(function(t){return !(t.burnerUntil&&t.burnerUntil>now);}).map(function(t){return t._i;});

  var html='';

  // Groups first
  groups.forEach(function(g,gi){
    var gTasks=S.active.filter(function(t,i){return (g.taskIds||[]).indexOf(i)!==-1;}).map(function(t){t._i=S.active.indexOf(t);return t;});
    var gDeferred=g.deferUntil&&g.deferUntil>now;
    var dLabel='';
    if(gDeferred){var dm=Math.ceil((g.deferUntil-now)/60000);dLabel=' — '+Math.floor(dm/60)+'h'+(dm%60)+'m';}
    html+='<div class="card grp-card">'+
      '<div class="grp-hdr" data-a="gcol" data-gi="'+gi+'">'+
      '<span style="font-size:.85em;margin-right:4px">'+(g.collapsed?'▶':'▼')+'</span>'+
      '<span class="grp-hdr-name">📂 '+esc(g.name)+(gDeferred?' 🕐'+dLabel:'')+'</span>'+
      '<button class="btn bpur sm" data-a="gdef" data-gi="'+gi+'">🕐</button>'+
      '<button class="btn bred sm" data-a="gdel" data-gi="'+gi+'" style="margin-left:3px">✕</button>'+
      '</div>'+
      (!g.collapsed?'<div class="grp-body">'+
        (gTasks.length?gTasks.map(function(t){return taskCardHtml(t,false,null);}).join(''):
        '<div class="empty" style="padding:8px 0">No tasks assigned yet.</div>')+
        '</div>':'')+
      '</div>';
  });

  // Ungrouped
  html+=ungrouped.map(function(t){return taskCardHtml(t,isManual,nbIdxs);}).join('');
  el.innerHTML=html;
}

// Pending state for modals
var P={done:null,brn:null,grpDefer:null,mvGrp:null};

// Add task
document.getElementById('btn-addtask').addEventListener('click',function(){
  var n=document.getElementById('new-tname').value.trim();
  var g=parseInt(document.getElementById('new-tgp').value)||5;
  if(!n){document.getElementById('new-tname').focus();return;}
  S.active.unshift({name:n,gp:g,count:0,subtasks:[],collapsed:false});
  logAdd('New contract: "'+n+'"','task');
  document.getElementById('new-tname').value='';
  save();renderTasks();
});
document.getElementById('new-tname').addEventListener('keydown',function(e){
  if(e.key==='Enter')document.getElementById('btn-addtask').click();
});
document.getElementById('tsort').addEventListener('change',renderTasks);

// New task group button
document.getElementById('btn-newgrp').addEventListener('click',function(){
  document.getElementById('ov-ng-name').value='';
  openOv('ov-newgrp');
});
document.getElementById('ov-ng-no').addEventListener('click',function(){closeOv('ov-newgrp');});
document.getElementById('ov-ng-yes').addEventListener('click',function(){
  var n=document.getElementById('ov-ng-name').value.trim();
  if(!n)return;
  if(!S.taskGroups)S.taskGroups=[];
  S.taskGroups.push({id:Date.now(),name:n,taskIds:[],collapsed:false,deferUntil:0});
  logAdd('Task group created: "'+n+'"','task');
  closeOv('ov-newgrp');save();renderTasks();
});

// Task list click handler
document.getElementById('tlist').addEventListener('click',function(e){
  var b=e.target.closest('[data-a]');
  if(!b)return;
  var a=b.getAttribute('data-a');
  var i=parseInt(b.getAttribute('data-i'));
  var gi=parseInt(b.getAttribute('data-gi'));

  if(a==='gcol'){
    if(S.taskGroups[gi])S.taskGroups[gi].collapsed=!S.taskGroups[gi].collapsed;
    save();renderTasks();
  } else if(a==='gdef'){
    if(!S.taskGroups[gi])return;
    P.grpDefer=gi;
    document.getElementById('ov-gd-name').textContent=S.taskGroups[gi].name;
    var d=new Date(Date.now()+2*3600000);
    document.getElementById('ov-gd-time').value=
      ('0'+d.getHours()).slice(-2)+':'+('0'+d.getMinutes()).slice(-2);
    openOv('ov-grpdefer');
  } else if(a==='gdel'){
    if(S.taskGroups[gi])S.taskGroups.splice(gi,1);
    save();renderTasks();
  } else if(a==='mvgrp'){
    if(isNaN(i)||!S.active[i])return;
    P.mvGrp=i;
    document.getElementById('ov-ag-msg').textContent='Assign "'+S.active[i].name+'" to a group.';
    document.getElementById('ov-ag-sel').innerHTML=(S.taskGroups||[]).map(function(g,gi2){
      return '<option value="'+gi2+'">'+esc(g.name)+'</option>';
    }).join('');
    openOv('ov-assigngrp');
  } else if(a==='tick'){
    S.active[i].count++;
    goldAdd(S.active[i].gp,'Progress: "'+S.active[i].name+'"','task');
    renderTasks();
  } else if(a==='done'){
    P.done=i;
    var sc=S.active[i].subtasks||[];
    document.getElementById('ov-done-msg').textContent=
      'Archive "'+S.active[i].name+'"?'+(sc.length?' Sub-tasks ('+sc.length+') archived with it.':'');
    openOv('ov-done');
  } else if(a==='brn'){
    P.brn=i;
    document.getElementById('ov-brn-name').textContent=S.active[i].name;
    openOv('ov-burner');
  } else if(a==='col'){
    S.active[i].collapsed=!S.active[i].collapsed;
    save();renderTasks();
  } else if(a==='stadd'){
    var inp=document.querySelector('[data-a="stadd-input"][data-i="'+i+'"]');
    var sn=inp?inp.value.trim():'';
    if(!sn)return;
    if(!S.active[i].subtasks)S.active[i].subtasks=[];
    S.active[i].subtasks.push({name:sn,done:false});
    save();renderTasks();
  } else if(a==='stdl'){
    var si=parseInt(b.getAttribute('data-si'));
    if(S.active[i]&&S.active[i].subtasks)S.active[i].subtasks.splice(si,1);
    save();renderTasks();
  } else if(a==='totop'){
    var now4=Date.now();
    var nb3=[];S.active.forEach(function(t,idx){if(!(t.burnerUntil&&t.burnerUntil>now4))nb3.push(idx);});
    var p3=nb3.indexOf(i);
    if(p3>0){
      var item=S.active.splice(i,1)[0];
      // Insert at the position of the first non-burner task
      S.active.splice(nb3[0]<i?nb3[0]:0,0,item);
      save();
    }
    renderTasks();
  } else if(a==='up'){
    var now2=Date.now();
    var nb=[];S.active.forEach(function(t,idx){if(!(t.burnerUntil&&t.burnerUntil>now2))nb.push(idx);});
    var p=nb.indexOf(i);
    if(p>0){var s2=nb[p-1];var tmp=S.active[i];S.active[i]=S.active[s2];S.active[s2]=tmp;save();}
    renderTasks();
  } else if(a==='dn'){
    var now3=Date.now();
    var nb2=[];S.active.forEach(function(t,idx){if(!(t.burnerUntil&&t.burnerUntil>now3))nb2.push(idx);});
    var p2=nb2.indexOf(i);
    if(p2<nb2.length-1){var s3=nb2[p2+1];var tmp2=S.active[i];S.active[i]=S.active[s3];S.active[s3]=tmp2;save();}
    renderTasks();
  }
});

// Subtask checkbox change
document.getElementById('tlist').addEventListener('change',function(e){
  var cb=e.target.closest('[data-a="stck"]');
  if(!cb)return;
  var i=parseInt(cb.getAttribute('data-i'));
  var si=parseInt(cb.getAttribute('data-si'));
  if(S.active[i]&&S.active[i].subtasks&&S.active[i].subtasks[si]){
    S.active[i].subtasks[si].done=cb.checked;
    if(cb.checked){
      var tot=S.active[i].subtasks.length;
      var sg=Math.max(1,Math.floor(S.active[i].gp/tot));
      goldAdd(sg,'Sub-task: "'+S.active[i].subtasks[si].name+'" ('+S.active[i].name+')','task');
    }
    save();renderTasks();
  }
});

// Subtask enter key
document.getElementById('tlist').addEventListener('keydown',function(e){
  if(e.key!=='Enter')return;
  var inp=e.target.closest('[data-a="stadd-input"]');
  if(!inp)return;
  e.preventDefault();
  var i=parseInt(inp.getAttribute('data-i'));
  var sn=inp.value.trim();
  if(!sn||!S.active[i])return;
  if(!S.active[i].subtasks)S.active[i].subtasks=[];
  S.active[i].subtasks.push({name:sn,done:false});
  save();renderTasks();
});

// Done modal
document.getElementById('ov-done-no').addEventListener('click',function(){closeOv('ov-done');});
document.getElementById('ov-done-yes').addEventListener('click',function(){
  if(P.done===null)return;
  var t=S.active.splice(P.done,1)[0];
  // Remove from any task group
  (S.taskGroups||[]).forEach(function(g){
    if(g.taskIds)g.taskIds=g.taskIds.filter(function(id){return id!==P.done;});
  });
  // Archive with subtasks preserved (reset done state)
  var entry={name:t.name,gp:t.gp,freq:t.freq||'custom',cat:t.cat||'',
    fav:t.fav||false,
    subtasks:(t.subtasks||[]).map(function(s){return{name:s.name,done:false};})};
  var ei=-1;
  for(var x=0;x<S.archived.length;x++){if(S.archived[x].name===t.name){ei=x;break;}}
  if(ei>=0)S.archived[ei].subtasks=entry.subtasks;
  else S.archived.push(entry);
  var sc=t.subtasks?t.subtasks.length:0;
  logAdd('Archived: "'+t.name+'"'+(sc?' +'+sc+' sub-tasks':''),'task');
  P.done=null;closeOv('ov-done');save();renderTasks();
});

// Burner modal
document.getElementById('ov-brn-no').addEventListener('click',function(){closeOv('ov-burner');});
document.getElementById('ov-brn-yes').addEventListener('click',function(){
  if(P.brn===null)return;
  var mins=parseInt(document.getElementById('ov-brn-delay').value)||60;
  S.active[P.brn].burnerUntil=Date.now()+(mins*60000);
  var lb=mins<60?mins+' min':(mins%60===0?(mins/60)+' hr':Math.floor(mins/60)+' hr '+(mins%60)+' min');
  logAdd('"'+S.active[P.brn].name+'" deferred '+lb,'task');
  P.brn=null;closeOv('ov-burner');save();renderTasks();
});

// Group defer modal
document.getElementById('ov-gd-no').addEventListener('click',function(){closeOv('ov-grpdefer');});
document.getElementById('ov-gd-yes').addEventListener('click',function(){
  if(P.grpDefer===null)return;
  var tv=document.getElementById('ov-gd-time').value||'14:00';
  var parts=tv.split(':');
  var target=new Date();
  target.setHours(parseInt(parts[0])||14,parseInt(parts[1])||0,0,0);
  if(target.getTime()<=Date.now())target.setDate(target.getDate()+1);
  var ms=target.getTime();
  var g=S.taskGroups[P.grpDefer];
  if(g){
    g.deferUntil=ms;
    (g.taskIds||[]).forEach(function(ti){if(S.active[ti])S.active[ti].burnerUntil=ms;});
    logAdd('Group "'+g.name+'" deferred until '+tv,'task');
  }
  P.grpDefer=null;closeOv('ov-grpdefer');save();renderTasks();
});

// Assign to group modal
document.getElementById('ov-ag-no').addEventListener('click',function(){closeOv('ov-assigngrp');});
document.getElementById('ov-ag-remove').addEventListener('click',function(){
  if(P.mvGrp===null)return;
  (S.taskGroups||[]).forEach(function(g){
    if(g.taskIds)g.taskIds=g.taskIds.filter(function(id){return id!==P.mvGrp;});
  });
  P.mvGrp=null;closeOv('ov-assigngrp');save();renderTasks();
});
document.getElementById('ov-ag-yes').addEventListener('click',function(){
  if(P.mvGrp===null)return;
  var gi=parseInt(document.getElementById('ov-ag-sel').value);
  if(isNaN(gi)||!S.taskGroups[gi])return;
  (S.taskGroups||[]).forEach(function(g){
    if(g.taskIds)g.taskIds=g.taskIds.filter(function(id){return id!==P.mvGrp;});
  });
  S.taskGroups[gi].taskIds.push(P.mvGrp);
  logAdd('"'+S.active[P.mvGrp].name+'" → group "'+S.taskGroups[gi].name+'"','task');
  P.mvGrp=null;closeOv('ov-assigngrp');save();renderTasks();
});

/* ═══════════════════════ ARCHIVE ═══════════════════════ */

var FLAB={daily:'Daily',weekly:'Weekly',monthly:'Monthly',yearly:'Yearly',selfcare:'Self-Care',custom:'Custom'};
var FORD=['daily','weekly','monthly','yearly','selfcare','custom'];

function archGroups(){
  var grps={};
  S.archived.forEach(function(t,i){
    var k=t.archGroup||(t.freq||'custom');
    if(!grps[k])grps[k]=[];
    grps[k].push({t:t,i:i});
  });
  return grps;
}
function archGroupOrder(){
  var grps=archGroups();
  var stored=S.archGroups||[];
  var all=Object.keys(grps);
  // Custom always first
  var order=['custom'].filter(function(k){return grps[k];});
  // Then stored order (excluding custom)
  stored.map(function(g){return g.key;}).filter(function(k){return grps[k]&&k!=='custom';}).forEach(function(k){
    if(order.indexOf(k)===-1)order.push(k);
  });
  // Then anything remaining
  all.forEach(function(k){if(order.indexOf(k)===-1)order.push(k);});
  return order;
}

var P2={archMove:null};

function renderArchive(){
  var el=document.getElementById('alist');
  var grps=archGroups();
  var order=archGroupOrder();
  var activeNames=S.active.map(function(t){return t.name;});

  if(!S.archived.length){el.innerHTML='<div class="empty">Archive is empty.</div>';return;}

  el.innerHTML=order.map(function(k,ki){
    var entries=grps[k]||[];
    var label=FLAB[k]||k;
    var collapsed=S.archCollapsed&&S.archCollapsed[k];
    var canUp=ki>0,canDn=ki<order.length-1;
    return '<div class="card" style="padding:8px 10px;margin-bottom:8px">'+
      '<div class="ach-grp-hdr" data-a="ag-col" data-k="'+esc(k)+'">'+
      '<span style="font-size:.78em;margin-right:3px">'+(collapsed?'▶':'▼')+'</span>'+
      '<span class="ach-grp-name">'+esc(label)+'</span>'+
      '<span style="font-size:.7em;color:var(--ink-light)">('+entries.length+')</span>'+
      '<div style="display:flex;gap:3px;margin-left:6px">'+
      '<button data-a="ag-up" data-k="'+esc(k)+'" class="btn bink sm" style="min-height:24px;padding:2px 6px"'+(canUp?'':' disabled')+'>▲</button>'+
      '<button data-a="ag-dn" data-k="'+esc(k)+'" class="btn bink sm" style="min-height:24px;padding:2px 6px"'+(canDn?'':' disabled')+'>▼</button>'+
      '</div></div>'+
      (!collapsed?entries.map(function(entry,ei){
        var t=entry.t,ai=entry.i;
        var isActive=activeNames.indexOf(t.name)!==-1;
        var canEUp=ei>0,canEDn=ei<entries.length-1;
        return '<div class="ach-row">'+
          '<button class="fav-btn'+(t.fav?' on':'')+'" data-a="afav" data-i="'+ai+'">'+(t.fav?'★':'☆')+'</button>'+
          '<div class="ach-updn">'+
          '<button data-a="aup" data-i="'+ai+'"'+(canEUp?'':' disabled')+'>▲</button>'+
          '<button data-a="adn" data-i="'+ai+'"'+(canEDn?'':' disabled')+'>▼</button>'+
          '</div>'+
          '<div class="ach-info">'+
          '<div class="ach-name">'+(t.fav?'★ ':'')+esc(t.name)+
          ' <span data-a="aname-edit" data-i="'+ai+'" style="cursor:pointer;font-size:.7em;opacity:.5" title="Edit name">✏️</span>'+
          '</div>'+
          '<div class="ach-sub">'+(t.cat||'')+(t.cat?' · ':'')+
          '<span data-a="agp-edit" data-i="'+ai+'" style="cursor:pointer;border-bottom:1px dashed var(--gold-dark);color:var(--gold-dark)">'+t.gp+' gp/tick</span>'+
          ((t.subtasks&&t.subtasks.length)?' · '+t.subtasks.length+' sub-tasks':'')+
          (t.fav?' · ⏰ auto':'')+
          '</div></div>'+
          '<button class="btn bink sm" data-a="amove" data-i="'+ai+'">📂</button>'+
          '<button class="btn'+(isActive?' bink disabled':' bgn')+' sm" data-a="act" data-i="'+ai+'"'+(isActive?' disabled':'')+'>'+
          (isActive?'Active':'Activate')+
          '</button></div>';
      }).join(''):'')+
      '</div>';
  }).join('');
}

document.getElementById('btn-arch-newgrp').addEventListener('click',function(){
  var n=(document.getElementById('arch-newgrp-name').value||'').trim();
  if(!n)return;
  var k=n.toLowerCase().replace(/\s+/g,'-');
  FLAB[k]=n;
  if(!S.archGroups)S.archGroups=[];
  var exists=S.archGroups.some(function(g){return g.key===k;});
  if(!exists)S.archGroups.push({key:k,label:n});
  document.getElementById('arch-newgrp-name').value='';
  save();renderArchive();
});

document.getElementById('alist').addEventListener('click',function(e){
  var b=e.target.closest('[data-a]');
  if(!b)return;
  var a=b.getAttribute('data-a');
  var ai=parseInt(b.getAttribute('data-i'));
  var k=b.getAttribute('data-k');

  if(a==='ag-col'){
    if(!S.archCollapsed)S.archCollapsed={};
    S.archCollapsed[k]=!S.archCollapsed[k];
    save();renderArchive();
  } else if(a==='ag-up'||a==='ag-dn'){
    var order=archGroupOrder();
    var idx=order.indexOf(k);
    var swap=a==='ag-up'?idx-1:idx+1;
    if(swap>=0&&swap<order.length){
      if(!S.archGroups||!S.archGroups.length){
        S.archGroups=order.map(function(x){return{key:x,label:FLAB[x]||x};});
      }
      // Reorder S.archGroups to match
      var tmp=order[idx];order[idx]=order[swap];order[swap]=tmp;
      S.archGroups=order.map(function(x){return{key:x,label:FLAB[x]||x};});
      save();renderArchive();
    }
  } else if(a==='afav'){
    S.archived[ai].fav=!S.archived[ai].fav;
    save();renderArchive();
  } else if(a==='aup'||a==='adn'){
    var t=S.archived[ai];
    var grpKey=t.archGroup||(t.freq||'custom');
    var grpIdxs=[];
    S.archived.forEach(function(x,xi){if((x.archGroup||(x.freq||'custom'))===grpKey)grpIdxs.push(xi);});
    var pos=grpIdxs.indexOf(ai);
    var sw=a==='aup'?grpIdxs[pos-1]:grpIdxs[pos+1];
    if(sw!==undefined){
      var tmp2=S.archived[ai];S.archived[ai]=S.archived[sw];S.archived[sw]=tmp2;
      save();renderArchive();
    }
  } else if(a==='aname-edit'){
    var curName=S.archived[ai].name;
    var newName=(prompt('Edit task name:\nCurrent: "'+curName+'"')||'').trim();
    if(newName&&newName!==curName){
      // Also update any active task with the same name
      S.active.forEach(function(t){if(t.name===curName)t.name=newName;});
      S.archived[ai].name=newName;
      logAdd('Archive task renamed: "'+curName+'" → "'+newName+'"','task');
      save();renderArchive();renderTasks();
    }
  } else if(a==='agp-edit'){
    P2.archMove=null;
    // Inline prompt — use a small popover approach via modal
    var curGp=S.archived[ai].gp;
    var newGp=parseInt(prompt('Edit gold per tick for "'+S.archived[ai].name+'".\nCurrent: '+curGp+' gp\n\nEnter new amount:'),10);
    if(!isNaN(newGp)&&newGp>0){
      S.archived[ai].gp=newGp;
      logAdd('Archive gp updated: "'+S.archived[ai].name+'" → '+newGp+' gp/tick','task');
      save();renderArchive();
    }
  } else if(a==='amove'){
    P2.archMove=ai;
    document.getElementById('ov-am-msg').textContent='Move "'+S.archived[ai].name+'" to a different group.';
    var grps2=archGroups();
    var ord2=archGroupOrder();
    var curK=S.archived[ai].archGroup||(S.archived[ai].freq||'custom');
    document.getElementById('ov-am-dest').innerHTML=ord2.map(function(x){
      return '<option value="'+esc(x)+'"'+(x===curK?' selected':'')+'>'+esc(FLAB[x]||x)+'</option>';
    }).join('');
    openOv('ov-archmove');
  } else if(a==='act'){
    if(b.disabled)return;
    var t2=S.archived[ai];
    if(S.active.some(function(x){return x.name===t2.name;}))return;
    S.active.push({name:t2.name,gp:t2.gp,count:0,freq:t2.freq,cat:t2.cat,
      subtasks:(t2.subtasks||[]).map(function(s){return{name:s.name,done:false};}),
      collapsed:false,fav:t2.fav});
    logAdd('Activated: "'+t2.name+'"','task');
    save();renderTasks();renderArchive();
  }
});

document.getElementById('ov-am-no').addEventListener('click',function(){closeOv('ov-archmove');});
document.getElementById('ov-am-yes').addEventListener('click',function(){
  if(P2.archMove===null)return;
  var dest=document.getElementById('ov-am-dest').value;
  S.archived[P2.archMove].archGroup=dest;
  P2.archMove=null;closeOv('ov-archmove');save();renderArchive();
});

/* ═══════════════════════ PARTY ═══════════════════════ */

var P3={lvl:null,sq:null};

function charCardHtml(c,ci){
  var inSq=(S.squads||[]).filter(function(s){return s.memberIdxs&&s.memberIdxs.indexOf(ci)!==-1;}).map(function(s){return s.name;});
  return '<div class="char-card">'+
    '<div style="display:flex;justify-content:space-between;align-items:flex-start">'+
    '<div><div class="cname">'+esc(c.name)+
    (c.premium?' <span style="font-size:.6em;color:var(--gold-dark);font-family:\'Cinzel\',serif;background:rgba(201,146,42,.15);border:1px solid var(--gold);border-radius:8px;padding:1px 6px;">⭐ Premium</span>':'')+
    (c.hireling?' <span style="font-size:.6em;color:var(--ink-light);font-family:\'Cinzel\',serif;background:rgba(44,26,14,.08);border:1px solid var(--ink-light);border-radius:8px;padding:1px 6px;">🪓 Hireling</span>':'')+
    (c.formerHireling?' <span style="font-size:.6em;color:var(--teal);font-family:\'Cinzel\',serif;background:rgba(26,107,138,.1);border:1px solid var(--teal);border-radius:8px;padding:1px 6px;">🎖️ Risen</span>':'')+
    '</div>'+
    '<div class="cmeta">'+esc(c.species)+' '+esc(c.cls)+' · '+esc(c.bg)+'</div>'+
    '<div class="clvl">Level '+c.level+' · '+c.age+' yrs · '+esc(c.height)+' · '+esc(c.weight)+
    (inSq.length?' <span style="color:var(--crimson)">⚔ '+inSq.join(', ')+'</span>':'')+
    '</div></div>'+
    '<button class="btn bg sm" data-a="lv" data-ci="'+ci+'">Level Up</button>'+
    '</div>'+
    '<div class="pills">'+
    (c.lang||[]).map(function(l){return '<span class="pill">🗣 '+esc(l)+'</span>';}).join('')+
    '<span class="pill">🙏 '+esc(c.rel||'–')+'</span>'+
    '</div>'+
    '<div class="pills">'+(c.skills||[]).map(function(s){return '<span class="pill">⭐ '+esc(s)+'</span>';}).join('')+'</div>'+
    '<div class="pills">'+(c.tools||[]).map(function(s){return '<span class="pill">🔧 '+esc(s)+'</span>';}).join('')+'</div>'+
    '<div class="inv-ttl">📦 Inventory ('+(c.inv||[]).length+')</div>'+
    ((c.inv||[]).length?(c.inv||[]).map(function(x){return '<div class="inv-item">· '+esc(x)+'</div>';}).join(''):
    '<div style="font-size:.8em;color:var(--ink-light);font-style:italic">Empty.</div>')+
    '</div>';
}

function renderParty(){
  if(typeof partyStatsOpen!=='undefined'&&partyStatsOpen)renderPartyStats();
  var el=document.getElementById('plist');
  if(!S.party.length){el.innerHTML='<div class="empty">No adventurers. Visit the Recruitment Office!</div>';return;}
  if(!S.squadCollapsed)S.squadCollapsed={};
  var squads=S.squads||[];
  var assigned={};
  squads.forEach(function(sq){(sq.memberIdxs||[]).forEach(function(ci){assigned[ci]=true;});});

  var html='<div style="margin-bottom:12px">'+
    '<div style="font-family:\'Cinzel\',serif;font-size:.8em;text-transform:uppercase;letter-spacing:.05em;'+
    'color:var(--gold-dark);border-bottom:1px dashed var(--parchment-deep);padding-bottom:4px;'+
    'margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;">'+
    'Squads <button class="btn bg sm" data-a="sqnew">+ New Squad</button></div>'+
    (squads.length?squads.map(function(sq,sqi){
      var collapsed=S.squadCollapsed[sqi];
      var members=(sq.memberIdxs||[]).filter(function(ci){return S.party[ci];});
      return '<div class="sq-card">'+
        '<div class="sq-hdr" data-a="sqcol" data-sqi="'+sqi+'">'+
        '<span style="font-size:.8em;margin-right:4px">'+(collapsed?'▶':'▼')+'</span>'+
        '<span class="sq-name">⚔ '+esc(sq.name)+'</span>'+
        '<span style="font-size:.7em;color:var(--ink-light);margin-left:4px">('+members.length+')</span>'+
        '<button class="btn bink sm" data-a="sqedit" data-sqi="'+sqi+'" style="margin-left:auto">Edit</button>'+
        '</div>'+
        (!collapsed?'<div style="padding-top:5px">'+
          (members.length?members.map(function(ci){return charCardHtml(S.party[ci],ci);}).join(''):
          '<div class="empty" style="padding:7px 0">No members assigned.</div>')+
          '</div>':'')+
        '</div>';
    }).join(''):'<div class="empty" style="padding:8px 0">No squads yet.</div>')+
    '</div>';

  // Unassigned
  var unassigned=S.party.map(function(c,ci){return{c:c,ci:ci};}).filter(function(x){return !assigned[x.ci];});
  if(unassigned.length){
    html+='<div style="font-family:\'Cinzel\',serif;font-size:.72em;text-transform:uppercase;'+
      'letter-spacing:.05em;color:var(--ink-light);border-bottom:1px dashed var(--parchment-deep);'+
      'padding-bottom:3px;margin-bottom:7px;">Unassigned</div>'+
      unassigned.map(function(x){return charCardHtml(x.c,x.ci);}).join('');
  }

  // Assets — collapsible with gold total
  var assets=S.partyAssets||[];
  if(!S.assetsCollapsed)S.assetsCollapsed=false;
  var assetsCollapsed=S.assetsCollapsed;

  // Calculate total gold value by matching against all item lists
  var allPurchasables=[].concat(VEHICLES,BUILDINGS,PETS,GEAR);
  var totalValue=0;
  // Also count hire costs for party members and level-up costs
  S.party.forEach(function(c){
    if(c.hireCost)totalValue+=c.hireCost;
    for(var lv=1;lv<c.level;lv++)totalValue+=lv*50;
  });
  assets.forEach(function(a){
    var match=allPurchasables.filter(function(x){return x.name===a.name;});
    if(match.length)totalValue+=match[0].price;
  });

  html+='<div class="card" style="margin-top:14px;padding:9px 12px">'+
    '<div style="display:flex;align-items:center;cursor:pointer;user-select:none" data-a="assets-col">'+
    '<span style="font-size:.8em;margin-right:5px">'+(assetsCollapsed?'▶':'▼')+'</span>'+
    '<span style="font-family:\'Cinzel\',serif;font-size:.78em;text-transform:uppercase;letter-spacing:.05em;color:var(--gold-dark);flex:1">'+
    '🏰 Assets &amp; Investments</span>'+
    '<span style="font-family:\'Cinzel\',serif;font-size:.75em;color:var(--gold-dark);font-weight:700">'+totalValue.toLocaleString()+' gp invested</span>'+
    '</div>'+
    (!assetsCollapsed?
      '<div style="margin-top:8px;border-top:1px dashed var(--parchment-deep);padding-top:8px">'+
      // Party members row
      '<div style="font-size:.72em;color:var(--ink-light);text-transform:uppercase;font-family:\'Cinzel\',serif;letter-spacing:.04em;margin-bottom:4px">Party Hire &amp; Levels</div>'+
      S.party.map(function(c){
        var hc=c.hireCost||0;
        var lc=0;for(var lv=1;lv<c.level;lv++)lc+=lv*50;
        return '<div class="inv-item" style="display:flex;justify-content:space-between">'+
          '<span>'+esc(c.name)+' (Lv '+c.level+')</span>'+
          '<span style="font-family:\'Cinzel\',serif;font-size:.78em;color:var(--gold-dark)">'+(hc+lc).toLocaleString()+' gp</span>'+
          '</div>';
      }).join('')+
      // Party assets rows
      (assets.length?
        '<div style="font-size:.72em;color:var(--ink-light);text-transform:uppercase;font-family:\'Cinzel\',serif;letter-spacing:.04em;margin:8px 0 4px">Purchased Assets</div>'+
        assets.map(function(a,ai){
          var match=allPurchasables.filter(function(x){return x.name===a.name;});
          var val=match.length?match[0].price:0;
          return '<div class="inv-item" style="display:flex;justify-content:space-between;align-items:center">'+
            '<span>'+esc(a.ic)+' '+esc(a.name)+'</span>'+
            '<span style="display:flex;align-items:center;gap:8px">'+
            '<span style="font-family:\'Cinzel\',serif;font-size:.78em;color:var(--gold-dark)">'+(val?val.toLocaleString()+' gp':'–')+'</span>'+
            '<button class="btn bred sm" data-a="asset-sell" data-ai="'+ai+'" style="font-size:.6em;min-height:22px;padding:1px 6px" title="Sell / remove">✕</button>'+
            '</span></div>';
        }).join('')
        :'<div style="font-size:.8em;color:var(--ink-light);font-style:italic;margin-top:4px">No purchased assets yet.</div>')+
      '</div>'
    :'')+
    '</div>';

  el.innerHTML=html;
}

document.getElementById('plist').addEventListener('click',function(e){
  var b=e.target.closest('[data-a]');
  if(!b)return;
  var a=b.getAttribute('data-a');
  var ci=parseInt(b.getAttribute('data-ci'));
  var sqi=parseInt(b.getAttribute('data-sqi'));

  if(a==='assets-col'){
    S.assetsCollapsed=!S.assetsCollapsed;
    save();renderParty();
  } else if(a==='asset-sell'){
    var ai=parseInt(b.getAttribute('data-ai'));
    var asset=S.partyAssets[ai];
    if(asset&&confirm('Remove "'+asset.name+'" from Party Assets?\n(This does not refund gold.)')){
      S.partyAssets.splice(ai,1);
      logAdd('Removed asset: '+asset.name,'buy');
      save();renderParty();
    }
  } else if(a==='lv'){
    var c=S.party[ci];
    P3.lvl=ci;
    document.getElementById('ov-lv-msg').textContent=
      'Level up '+c.name+' from Level '+c.level+' to Level '+(c.level+1)+' for '+(c.level===0?125:c.level*50)+' gp?'+
      (c.hireling&&c.level===0?' They will graduate to a full adventurer, gaining skills, tools, languages, and a surname.':'');
    openOv('ov-lvlup');
  } else if(a==='sqcol'){
    S.squadCollapsed[sqi]=!S.squadCollapsed[sqi];
    save();renderParty();
  } else if(a==='sqnew'){
    P3.sq=null;
    document.getElementById('ov-sq-title').textContent='⚔ New Squad';
    document.getElementById('ov-sq-name').value='';
    document.getElementById('ov-sq-del').style.display='none';
    document.getElementById('ov-sq-members').innerHTML=S.party.map(function(c,ci2){
      return '<label><input type="checkbox" class="sqcb" value="'+ci2+'"> '+esc(c.name)+' ('+esc(c.cls)+')</label>';
    }).join('');
    openOv('ov-squad');
  } else if(a==='sqedit'){
    P3.sq=sqi;
    var sq=S.squads[sqi];
    document.getElementById('ov-sq-title').textContent='⚔ Edit Squad';
    document.getElementById('ov-sq-name').value=sq.name;
    document.getElementById('ov-sq-del').style.display='';
    document.getElementById('ov-sq-members').innerHTML=S.party.map(function(c,ci2){
      var chk=(sq.memberIdxs||[]).indexOf(ci2)!==-1?'checked':'';
      return '<label><input type="checkbox" class="sqcb" value="'+ci2+'" '+chk+'> '+esc(c.name)+' ('+esc(c.cls)+')</label>';
    }).join('');
    openOv('ov-squad');
  }
});

document.getElementById('ov-lv-no').addEventListener('click',function(){closeOv('ov-lvlup');});
document.getElementById('ov-lv-yes').addEventListener('click',function(){
  if(P3.lvl===null)return;
  var c=S.party[P3.lvl];
  var cost=c.level===0?125:c.level*50;
  if(!goldSpend(cost,'Level up '+c.name,'hire'))return;
  c.level++;
  if(c.hireling&&c.level===1){
    var ln=rnd(DND.ln);
    c.name=c.name+' '+ln;
    c.formerHireling=true;
    var existSk=c.skills||[],existTl=c.tools||[],existLa=c.lang||[];
    var newSk=pick(DND.skills.filter(function(s){return existSk.indexOf(s)===-1;}),Math.max(0,4-existSk.length));
    var newTl=pick(DND.tools.filter(function(t){return existTl.indexOf(t)===-1;}),Math.max(0,2-existTl.length));
    var newLa=pick(DND.lang.filter(function(l){return existLa.indexOf(l)===-1;}),Math.max(0,2-existLa.length));
    var newWp=pick(DND.weapons.filter(function(w){return (c.weapons||[]).indexOf(w)===-1;}),Math.max(0,2-(c.weapons||[]).length));
    c.skills=existSk.concat(newSk);
    c.tools=existTl.concat(newTl);
    c.lang=existLa.concat(newLa);
    c.weapons=(c.weapons||[]).concat(newWp);
    if(!c.rel)c.rel=rnd(DND.rel);
    if(!c.inv)c.inv=[];
    if(c.inv.indexOf("Adventurer's Pack")===-1)c.inv.push("Adventurer's Pack");
    logAdd(c.name+' graduated: hireling to Level 1 adventurer!','hire');
    alert('Graduated! '+c.name+' is now a full adventurer.\nSurname earned: "'+ln+'"\n'+
      (newSk.length?'\nNew skills: '+newSk.join(', '):'')+
      (newTl.length?'\nNew tools: '+newTl.join(', '):'')+
      (newLa.length?'\nNew languages: '+newLa.join(', '):''));
  } else {
    logAdd(c.name+' reached Level '+c.level+'!','hire');
  }
  P3.lvl=null;closeOv('ov-lvlup');save();renderParty();
});
document.getElementById('ov-sq-no').addEventListener('click',function(){closeOv('ov-squad');});
document.getElementById('ov-sq-del').addEventListener('click',function(){
  if(P3.sq===null)return;
  S.squads.splice(P3.sq,1);P3.sq=null;closeOv('ov-squad');save();renderParty();
});
document.getElementById('ov-sq-yes').addEventListener('click',function(){
  var n=document.getElementById('ov-sq-name').value.trim();
  if(!n)return;
  var ms=[];
  document.querySelectorAll('.sqcb:checked').forEach(function(cb){ms.push(parseInt(cb.value));});
  if(!S.squads)S.squads=[];
  if(P3.sq===null){S.squads.push({id:Date.now(),name:n,memberIdxs:ms});logAdd('Squad: "'+n+'"','hire');}
  else{S.squads[P3.sq].name=n;S.squads[P3.sq].memberIdxs=ms;}
  P3.sq=null;closeOv('ov-squad');save();renderParty();
});

/* ── Party Stats Panel ── */

var partyStatsOpen=false;

document.getElementById('btn-party-stats').addEventListener('click',function(){
  partyStatsOpen=!partyStatsOpen;
  var panel=document.getElementById('party-stats-panel');
  panel.style.display=partyStatsOpen?'block':'none';
  this.textContent=partyStatsOpen?'📊 Hide Stats':'📊 Stats';
  if(partyStatsOpen)renderPartyStats();
});

function renderPartyStats(){
  var panel=document.getElementById('party-stats-panel');
  if(!panel||!partyStatsOpen)return;
  var party=S.party||[];
  if(!party.length){panel.innerHTML='<div class="empty">No adventurers yet.</div>';return;}

  // Gather coverage counts
  function countCoverage(allOptions,getter){
    var counts={};
    allOptions.forEach(function(opt){counts[opt]=0;});
    party.forEach(function(c){
      (getter(c)||[]).forEach(function(val){
        if(counts.hasOwnProperty(val))counts[val]++;
        // also count unknown values
      });
    });
    return counts;
  }

  function singleCoverage(allOptions,getter){
    // for single-value fields like species, cls, rel
    var counts={};
    allOptions.forEach(function(opt){counts[opt]=0;});
    party.forEach(function(c){
      var val=getter(c);
      if(val&&counts.hasOwnProperty(val))counts[val]++;
    });
    return counts;
  }

  function coverageBar(count,max){
    var pct=max?Math.round(count/max*100):0;
    var col=count===0?'var(--crimson)':count===1?'var(--gold-dark)':'var(--forest)';
    return '<div style="display:flex;align-items:center;gap:6px;margin:2px 0">'+
      '<div style="flex:1;height:6px;background:rgba(44,26,14,.1);border-radius:3px;overflow:hidden">'+
      '<div style="width:'+pct+'%;height:100%;background:'+col+';border-radius:3px;transition:width .3s"></div>'+
      '</div>'+
      '<span style="font-size:.7em;color:'+col+';min-width:1.8em;text-align:right">'+count+'</span>'+
      '</div>';
  }

  function section(title,icon,allOptions,counts){
    var max=party.length;
    var covered=Object.values?Object.keys(counts).filter(function(k){return counts[k]>0;}).length:
      (function(){var n=0;for(var k in counts)if(counts[k]>0)n++;return n;})();
    var total=allOptions.length;
    var rows=allOptions.map(function(opt){
      var n=counts[opt]||0;
      return '<div style="margin-bottom:3px">'+
        '<div style="display:flex;justify-content:space-between;align-items:baseline">'+
        '<span style="font-size:.78em;color:var(--ink)">'+esc(opt)+'</span>'+
        '</div>'+
        coverageBar(n,max)+
        '</div>';
    }).join('');
    return '<div style="margin-bottom:14px">'+
      '<div style="font-family:\'Cinzel\',serif;font-size:.75em;text-transform:uppercase;'+
      'letter-spacing:.05em;color:var(--gold-dark);border-bottom:1px dashed var(--parchment-deep);'+
      'padding-bottom:3px;margin-bottom:7px;display:flex;justify-content:space-between">'+
      '<span>'+icon+' '+title+'</span>'+
      '<span style="color:'+(covered===total?'var(--forest)':'var(--crimson)')+'">'+covered+'/'+total+' covered</span>'+
      '</div>'+rows+'</div>';
  }

  var skillCounts=countCoverage(DND.skills,function(c){return c.skills||[];});
  var toolCounts=countCoverage(DND.tools,function(c){return c.tools||[];});
  var langCounts=countCoverage(DND.lang,function(c){return c.lang||[];});
  var relCounts=singleCoverage(DND.rel,function(c){return c.rel;});
  var speciesCounts=singleCoverage(DND.species,function(c){return c.species;});
  var clsCounts=singleCoverage(DND.cls,function(c){return c.cls;});

  panel.innerHTML=
    '<div style="background:rgba(255,255,255,.5);border:1px solid var(--parchment-deep);border-radius:7px;'+
    'padding:12px 13px;margin-bottom:14px">'+
    '<div style="font-family:\'Cinzel\',serif;font-size:.82em;color:var(--crimson);margin-bottom:10px;font-weight:700">'+
    '📊 Party Coverage — '+party.length+' Adventurer'+(party.length>1?'s':'')+'</div>'+
    section('Skills','⭐',DND.skills,skillCounts)+
    section('Tools & Kits','🔧',DND.tools,toolCounts)+
    section('Languages','🗣',DND.lang,langCounts)+
    section('Faiths','🙏',DND.rel,relCounts)+
    section('Species','🧬',DND.species,speciesCounts)+
    section('Classes','⚔',DND.cls,clsCounts)+
    '</div>';
}

/* ── Reset Game Progress ── */

document.getElementById('btn-reset-game').addEventListener('click',function(){
  if(!confirm('⚠ Wipe ALL game progress?\n\nThis will permanently clear:\n• Gold\n• Active & completed contracts\n• Party members\n• Squads & party assets\n• Quest progress\n• Ledger log\n\nYour archived tasks and settings are kept.\n\nThis cannot be undone.'))return;
  // Keep archive, settings, taskGroups labels — reset everything else
  S.gold=0;
  S.active=[];
  S.party=[];
  S.squads=[];
  S.squadCollapsed={};
  S.partyAssets=[];
  S.taskGroups=[];
  S.doneEnc=[];
  S.encAssigned={};
  S.pendingQuests=[];
  S.stock=[];
  S.stockDate='';
  S.log=[];
  S.lastFavCheck='';
  // Add the starter founder and opening log entry
  S.party.push({
    name:'The Founder',species:'Human',cls:'Expert',bg:'Guild Artisan',
    rel:'Avandra (Change)',age:34,height:"5'10\"",weight:'175 lbs',
    lang:['Common','Elvish'],skills:['Persuasion','Insight','Investigation','History'],
    tools:["Cartographer's Tools",'Gaming Set'],weapons:['Simple Weapons'],
    level:1,inv:['Ledger of Accounts','Fancy Quill Pen','Company Seal']
  });
  S.gold=10;
  logAdd('Franchise re-established. Starting stipend: 10 gp.','gold');
  setGold();
  save();
  renderTasks();renderParty();
  alert('✅ Progress wiped. Welcome back, Founder.');
});

var recruit=null;
document.getElementById('btn-randall').addEventListener('click',function(){
  recruit={
    name:rnd(DND.fn)+' '+rnd(DND.ln),species:rnd(DND.species),cls:rnd(DND.cls),
    bg:rnd(DND.bg),rel:rnd(DND.rel),age:rndInt(18,120),
    height:rndInt(4,7)+"'"+rndInt(0,11)+'"',weight:rndInt(90,280)+' lbs',
    lang:pick(DND.lang,rndInt(2,4)),skills:pick(DND.skills,4),
    tools:pick(DND.tools,2),weapons:pick(DND.weapons,rndInt(1,3)),
    level:1,inv:["Adventurer's Pack","Traveler's Clothes"],
    hireCost:(20+rndInt(0,80))*5
  };
  document.getElementById('rbox').innerHTML=
    '<div class="cname">'+esc(recruit.name)+'</div>'+
    '<div class="cmeta">'+esc(recruit.species)+' '+esc(recruit.cls)+' · '+esc(recruit.bg)+'</div>'+
    '<div class="clvl">'+recruit.age+' yrs · '+esc(recruit.height)+' · '+esc(recruit.weight)+'</div>'+
    '<div class="pills" style="margin-top:7px">'+
    '<span class="pill">🙏 '+esc(recruit.rel)+'</span>'+
    recruit.lang.map(function(l){return '<span class="pill">🗣 '+esc(l)+'</span>';}).join('')+
    '</div><div class="pills">'+
    recruit.skills.map(function(s){return '<span class="pill">⭐ '+esc(s)+'</span>';}).join('')+
    '</div><div class="pills">'+
    recruit.tools.map(function(s){return '<span class="pill">🔧 '+esc(s)+'</span>';}).join('')+
    recruit.weapons.map(function(s){return '<span class="pill">⚔ '+esc(s)+'</span>';}).join('')+
    '</div>';
  document.getElementById('hire-cost').textContent=recruit.hireCost;
  document.getElementById('hirebar').style.display='flex';
});

document.getElementById('btn-hire').addEventListener('click',function(){
  if(!recruit)return;
  if(!goldSpend(recruit.hireCost,'Hired '+recruit.name,'hire'))return;
  var c={};for(var k in recruit)c[k]=recruit[k];
  S.party.push(c);
  logAdd(c.name+' ('+c.species+' '+c.cls+') joined the party!','hire');
  recruit=null;
  document.getElementById('rbox').innerHTML='<div class="empty">Roll the dice for another candidate…</div>';
  document.getElementById('hirebar').style.display='none';
  save();renderParty();
});

