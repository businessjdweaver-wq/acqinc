var PREM_BASE=500;

function premOptCost(){
  var opts=0;
  if(document.getElementById('prem-species').value)opts++;
  if(document.getElementById('prem-cls').value)opts++;
  if(document.getElementById('prem-bg').value)opts++;
  if(document.getElementById('prem-rel').value)opts++;
  document.querySelectorAll('.prem-sk.on,.prem-tl.on,.prem-la.on').forEach(function(){opts++;});
  return opts*50;
}

function updatePremCost(){
  var extra=premOptCost();
  var total=PREM_BASE+extra;
  document.getElementById('prem-cost').textContent=total.toLocaleString();
  document.getElementById('prem-cost-breakdown').textContent=
    'Base '+PREM_BASE+' gp + '+extra+' gp in selected options = '+total+' gp total';
}

// Populate dropdowns and toggle lists once
(function initPremForm(){
  function populate(selId,arr){
    var el=document.getElementById(selId);
    arr.forEach(function(v){
      var o=document.createElement('option');o.value=v;o.textContent=v;el.appendChild(o);
    });
    el.addEventListener('change',updatePremCost);
  }
  populate('prem-species',DND.species);
  populate('prem-cls',DND.cls);
  populate('prem-bg',DND.bg);
  populate('prem-rel',DND.rel);

  function makeToggles(containerId,arr,cls){
    var el=document.getElementById(containerId);
    arr.forEach(function(v){
      var span=document.createElement('span');
      span.className='prem-toggle '+cls;
      span.textContent=v;
      span.setAttribute('data-v',v);
      span.addEventListener('click',function(){
        this.classList.toggle('on');
        updatePremCost();
      });
      el.appendChild(span);
    });
  }
  makeToggles('prem-skills-list',DND.skills,'prem-sk');
  makeToggles('prem-tools-list',DND.tools,'prem-tl');
  makeToggles('prem-lang-list',DND.lang,'prem-la');
}());

document.getElementById('btn-prem-rname').addEventListener('click',function(){
  document.getElementById('prem-fname').value=rnd(DND.fn);
});
document.getElementById('btn-prem-rlname').addEventListener('click',function(){
  document.getElementById('prem-lname').value=rnd(DND.ln);
});

document.getElementById('btn-prem-hire').addEventListener('click',function(){
  var extra=premOptCost();
  var total=PREM_BASE+extra;
  if(!goldSpend(total,'Premium mercenary hire','hire'))return;

  var fname=(document.getElementById('prem-fname').value.trim()||rnd(DND.fn));
  var lname=(document.getElementById('prem-lname').value.trim()||rnd(DND.ln));
  var species=document.getElementById('prem-species').value||rnd(DND.species);
  var cls=document.getElementById('prem-cls').value||rnd(DND.cls);
  var bg=document.getElementById('prem-bg').value||rnd(DND.bg);
  var rel=document.getElementById('prem-rel').value||rnd(DND.rel);

  // Collect required skills/tools/languages, then top up with randoms to minimums
  var reqSk=[],reqTl=[],reqLa=[];
  document.querySelectorAll('.prem-sk.on').forEach(function(t){reqSk.push(t.getAttribute('data-v'));});
  document.querySelectorAll('.prem-tl.on').forEach(function(t){reqTl.push(t.getAttribute('data-v'));});
  document.querySelectorAll('.prem-la.on').forEach(function(t){reqLa.push(t.getAttribute('data-v'));});

  // Pad out to at least the random minimums (4 skills, 2 tools, 2 langs)
  var extraSk=pick(DND.skills.filter(function(s){return reqSk.indexOf(s)===-1;}),Math.max(0,4-reqSk.length));
  var extraTl=pick(DND.tools.filter(function(t){return reqTl.indexOf(t)===-1;}),Math.max(0,2-reqTl.length));
  var extraLa=pick(DND.lang.filter(function(l){return reqLa.indexOf(l)===-1;}),Math.max(0,2-reqLa.length));

  var c={
    name:fname+' '+lname,
    species:species,cls:cls,bg:bg,rel:rel,
    age:rndInt(18,120),
    height:rndInt(4,7)+"'"+rndInt(0,11)+'"',
    weight:rndInt(90,280)+' lbs',
    lang:reqLa.concat(extraLa),
    skills:reqSk.concat(extraSk),
    tools:reqTl.concat(extraTl),
    weapons:pick(DND.weapons,rndInt(1,3)),
    level:1,inv:["Adventurer's Pack","Traveler's Clothes"],
    hireCost:total,
    premium:true
  };
  S.party.push(c);
  logAdd('⭐ Premium hire: '+c.name+' ('+c.species+' '+c.cls+') — '+total+' gp','hire');

  // Reset form
  document.getElementById('prem-fname').value='';
  document.getElementById('prem-lname').value='';
  document.getElementById('prem-species').value='';
  document.getElementById('prem-cls').value='';
  document.getElementById('prem-bg').value='';
  document.getElementById('prem-rel').value='';
  document.querySelectorAll('.prem-sk,.prem-tl,.prem-la').forEach(function(t){t.classList.remove('on');});
  updatePremCost();
  save();renderParty();
  alert('⭐ '+c.name+' has joined your franchise!\n'+c.species+' '+c.cls+' · '+c.bg);
});

/* ═══════════════════════ QUEST SYSTEM ═══════════════════════ */

function cycleId(){
  var d=new Date();
  return d.getFullYear()+'-'+(d.getMonth()+1);
}
function cycleLabel(){
  var d=new Date();
  return d.toLocaleString('default',{month:'long',year:'numeric'});
}

function initQuestState(){
  var id=cycleId();
  var maxLv=partyMaxLevel();
  var available=tiersForLevel(maxLv);

  // Build revealed list: 10 quests, 40% common (4 slots), rest from available tiers
  // Since we only have 2 common quests currently, reveal all commons + fill remainder
  var commons=QPOOL.filter(function(q){return q.tier==='common'&&q.startVisible;});
  var nonCommons=QPOOL.filter(function(q){return q.tier!=='common'&&available.indexOf(q.tier)!==-1&&q.startVisible;});

  // Guarantee at least 40% common — pad with all available commons
  var revealed=[];
  commons.forEach(function(q){revealed.push(q.idx);});
  nonCommons.forEach(function(q){revealed.push(q.idx);});

  // Also reveal quest idx 7 (perilous, not startVisible) if perilous is available,
  // so we hit 10 total when possible
  if(available.indexOf('perilous')!==-1&&revealed.indexOf(7)===-1){
    revealed.push(7);
  }

  S.questState={
    cycleId:id,
    revealed:revealed,
    done:[],
    pending:[],
    assigned:{},
    partyLvAtStart:maxLv
  };
}

function checkQuestCycleReset(){
  if(!S.questState||!S.questState.cycleId){initQuestState();return;}
  var cur=cycleId();
  if(S.questState.cycleId===cur)return;
  var old=S.questState;
  var missed=QPOOL.filter(function(q){
    return old.revealed.indexOf(q.idx)!==-1&&old.done.indexOf(q.idx)===-1;
  }).map(function(q){return q.title;});
  if(!S.questCycles)S.questCycles=[];
  S.questCycles.push({cycleId:old.cycleId,completed:old.done,missed:missed});
  var msg='New quest cycle: '+cycleLabel()+'. Previous cycle ended';
  if(old.done.length)msg+=' — '+old.done.length+' quest'+(old.done.length>1?'s':'')+' completed';
  if(missed.length)msg+=' — missed: '+missed.join(', ');
  msg+='.';
  logAdd(msg,'adv');
  initQuestState();
  save();
  alert('📅 A new quest cycle has begun!\n\n'+cycleLabel()+'\n\nFresh opportunities await. Check the Quest screen.\n'+(missed.length?'Lost last cycle: '+missed.join(', '):''));
}

function partyMaxLevel(){
  var max=0;
  (S.party||[]).forEach(function(c){if(!c.hireling&&c.level>max)max=c.level;});
  return max;
}

function questCalcReward(q,charIdxs,pay){
  var tier=QTIERS[q.tier];
  var pr=q.pre;
  var b=q.baseGp;
  b+=(pr.skills||[]).length*10;
  b+=(pr.tools||[]).length*15;
  b+=(pr.lang||[]).length*10;
  if(pr.rel)b+=20;
  b+=(pr.items||[]).length*15;
  if(pr.gold)b+=Math.floor(pr.gold*1.5);
  b+=(pr.pay||0)*8;
  b+=Math.max(0,(pay||0)-(pr.pay||0))*4;
  b+=Math.max(0,(charIdxs||[]).length-1)*15;
  var topLevel=0;
  (charIdxs||[]).forEach(function(ci){
    var c=S.party[ci];if(c&&!c.hireling&&c.level>topLevel)topLevel=c.level;
  });
  b+=Math.max(0,topLevel-tier.minLv)*tier.lvBonus;
  // Optional asset bonuses
  var assetNames=(S.partyAssets||[]).map(function(a){return a.name;});
  if(q.vehicleReq&&assetNames.indexOf(q.vehicleReq.name)!==-1)b+=Math.round(q.baseGp*0.25);
  if(q.buildingReq&&assetNames.indexOf(q.buildingReq.name)!==-1)b+=Math.round(q.baseGp*0.25);
  return b;
}

function questPrereqCheck(q,charIdxs,pay){
  var pr=q.pre,missing=[];
  var sk=[],to=[],la=[],re=[],inv=[];
  (charIdxs||[]).forEach(function(ci){
    var c=S.party[ci];if(!c)return;
    (c.skills||[]).forEach(function(s){sk.push(s);});
    (c.tools||[]).forEach(function(t){to.push(t);});
    (c.lang||[]).forEach(function(l){la.push(l);});
    if(c.rel)re.push(c.rel);
    (c.inv||[]).forEach(function(x){inv.push(x);});
  });
  (pr.skills||[]).forEach(function(s){if(sk.indexOf(s)===-1)missing.push('Skill: '+s);});
  (pr.tools||[]).forEach(function(t){if(to.indexOf(t)===-1)missing.push('Tool: '+t);});
  (pr.lang||[]).forEach(function(l){if(la.indexOf(l)===-1)missing.push('Language: '+l);});
  if(pr.rel&&re.indexOf(pr.rel)===-1)missing.push('Faith: '+pr.rel);
  (pr.items||[]).forEach(function(x){if(inv.indexOf(x)===-1)missing.push('Item: '+x);});
  if(pr.gold&&S.gold<pr.gold)missing.push('Gold invest: '+pr.gold+' gp');
  var topLevel=0;
  (charIdxs||[]).forEach(function(ci){var c=S.party[ci];if(c&&!c.hireling&&c.level>topLevel)topLevel=c.level;});
  if(QTIERS[q.tier].minLv>0&&topLevel<QTIERS[q.tier].minLv)
    missing.push('Party level '+QTIERS[q.tier].minLv+'+ required (highest: '+topLevel+')');
  // Vehicle/building optional bonuses — not blocking but noted
  return missing;
}

function questPrereqHtml(q,charIdxs,pay){
  var pr=q.pre;
  var tier=QTIERS[q.tier];
  var sk=[],to=[],la=[],re=[],inv=[];
  (charIdxs||[]).forEach(function(ci){
    var c=S.party[ci];if(!c)return;
    (c.skills||[]).forEach(function(s){sk.push(s);});
    (c.tools||[]).forEach(function(t){to.push(t);});
    (c.lang||[]).forEach(function(l){la.push(l);});
    if(c.rel)re.push(c.rel);
    (c.inv||[]).forEach(function(x){inv.push(x);});
  });
  var topLevel=0;
  (charIdxs||[]).forEach(function(ci){var c=S.party[ci];if(c&&!c.hireling&&c.level>topLevel)topLevel=c.level;});
  function row(label,met){
    return '<div class="prerow"><span class="'+(met?'pmet':'punmet')+'">'+( met?'✓':'✗')+'</span>'+esc(label)+'</div>';
  }
  var rows='';
  if(tier.minLv)rows+=row('Party level '+tier.minLv,topLevel>=tier.minLv);
  (pr.skills||[]).forEach(function(s){rows+=row('Skill: '+s,sk.indexOf(s)!==-1);});
  (pr.tools||[]).forEach(function(t){rows+=row('Tool: '+t,to.indexOf(t)!==-1);});
  (pr.lang||[]).forEach(function(l){rows+=row('Language: '+l,la.indexOf(l)!==-1);});
  if(pr.rel)rows+=row('Faith: '+pr.rel,re.indexOf(pr.rel)!==-1);
  (pr.items||[]).forEach(function(x){rows+=row('Has item: '+x,inv.indexOf(x)!==-1);});
  if(pr.gold)rows+=row('Gold invest: '+pr.gold+' gp',S.gold>=pr.gold);
  if(pr.pay)rows+=row('Payroll: '+(pay||0)+' / '+pr.pay+' units',(pay||0)>=pr.pay);
  // Optional vehicle/building bonuses
  var assetNames=(S.partyAssets||[]).map(function(a){return a.name;});
  if(q.vehicleReq){
    var hasV=assetNames.indexOf(q.vehicleReq.name)!==-1;
    rows+='<div class="prerow" style="color:var(--gold-dark)">'+
      '<span class="'+(hasV?'pmet':'punmet')+'">'+(hasV?'✓':'○')+'</span>'+
      esc(q.vehicleReq.ic+' '+q.vehicleReq.name)+' <span style="font-size:.8em;font-style:italic">(optional — '+esc(q.vehicleReq.desc)+')</span></div>';
  }
  if(q.buildingReq){
    var hasB=assetNames.indexOf(q.buildingReq.name)!==-1;
    rows+='<div class="prerow" style="color:var(--gold-dark)">'+
      '<span class="'+(hasB?'pmet':'punmet')+'">'+(hasB?'✓':'○')+'</span>'+
      esc(q.buildingReq.ic+' '+q.buildingReq.name)+' <span style="font-size:.8em;font-style:italic">(optional — '+esc(q.buildingReq.desc)+')</span></div>';
  }
  if(!rows)rows='<div style="font-size:.8em;color:var(--ink-light);font-style:italic">None required.</div>';
  return '<div class="prereq-box"><div class="prereq-ttl">Prerequisites</div>'+rows+'</div>';
}

function questReadiness(q,qs){
  var available=S.party.map(function(_,ci){return ci;}).filter(function(ci){
    var busy=false;
    (qs.pending||[]).forEach(function(pq){if(pq.doneAt>Date.now()&&(pq.chars||[]).indexOf(ci)!==-1)busy=true;});
    return !busy;
  });
  var missing=questPrereqCheck(q,available,q.pre.pay||0);
  if(missing.length===0)return 'ready';
  if(missing.length<=2)return 'stretch';
  return 'overreach';
}

function fmtCountdown(ms){
  if(ms<=0)return 'Ready to collect!';
  var h=Math.floor(ms/3600000);
  var m=Math.floor((ms%3600000)/60000);
  var s=Math.floor((ms%60000)/1000);
  return h+'h '+'0'.concat(m).slice(-2)+'m '+'0'.concat(s).slice(-2)+'s remaining';
}

var advCountdownTimer=null;

function renderAdv(){
  var el=document.getElementById('avcontent');
  if(!S.questState||S.questState.cycleId!==cycleId()){checkQuestCycleReset();}
  var qs=S.questState;
  var now=Date.now();
  var pendingByIdx={};
  (qs.pending||[]).forEach(function(pq){pendingByIdx[pq.idx]=pq;});
  var doneCount=qs.done.length;
  var totalVisible=qs.revealed.length;
  var pct=totalVisible?Math.round(doneCount/totalVisible*100):0;
  var html='<div class="adv-hdr">'+
    '<div class="adv-ttl">⚔ Quest Board — '+cycleLabel()+'</div>'+
    '<div class="adv-sub">Complete quests to unlock deeper opportunities.</div>'+
    '<div class="adv-prog"><div class="adv-bar" style="width:'+pct+'%"></div></div>'+
    '<div style="font-size:.72em;color:var(--parchment-deep);margin-top:3px">'+
    doneCount+' / '+totalVisible+' revealed quests completed</div>'+
    '</div>';

  QPOOL.forEach(function(q){
    var isRevealed=qs.revealed.indexOf(q.idx)!==-1;
    var isDone=qs.done.indexOf(q.idx)!==-1;
    var pq=pendingByIdx[q.idx];
    var inProgress=pq&&!isDone;
    var tier=QTIERS[q.tier];
    var maxLv=partyMaxLevel();
    var available=tiersForLevel(maxLv);
    var allTiers=['common','uncommon','rare','perilous','legendary'];
    var stretchTier=allTiers[available.length]||null;

    // Completely hide quests three or more tiers beyond current
    var tierIdx=allTiers.indexOf(q.tier);
    var availIdx=available.length; // index of first unavailable tier
    if(tierIdx>availIdx+1){return;} // more than one tier ahead — hide entirely

    // Deep preview: two tiers ahead — very blurred, for planning only
    if(tierIdx===availIdx+1){
      html+='<div class="enc-card" style="opacity:.2;border-style:dashed">'+
        '<div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">'+
        '<span>'+tier.badge+'</span>'+
        '<span style="font-family:\'Cinzel\',serif;font-size:.65em;text-transform:uppercase;color:'+tier.color+'">'+tier.label+' · Future</span>'+
        '</div>'+
        '<div class="etitle" style="filter:blur(6px)">'+esc(q.title)+'</div>'+
        '<div style="font-size:.78em;color:var(--ink-light);margin-top:5px">📋 Planning preview — requires Level '+tier.minLv+'</div>'+
        '</div>';
      return;
    }

    // Stretch tier: one tier ahead — blurred but readable level requirement
    if(q.tier===stretchTier&&!isRevealed){
      html+='<div class="enc-card" style="opacity:.35;border-style:dashed">'+
        '<div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">'+
        '<span>'+tier.badge+'</span>'+
        '<span style="font-family:\'Cinzel\',serif;font-size:.65em;text-transform:uppercase;color:'+tier.color+'">'+tier.label+' · Locked</span>'+
        '</div>'+
        '<div class="etitle" style="filter:blur(4px)">'+esc(q.title)+'</div>'+
        '<div style="font-size:.78em;color:var(--ink-light);margin-top:5px">🔒 Reach Level '+tier.minLv+' to unlock this tier</div>'+
        '</div>';
      return;
    }

    // Not yet revealed within available tiers — show unlock hint
    if(!isRevealed){
      var parentsDone=QPOOL.some(function(p2){
        return qs.done.indexOf(p2.idx)!==-1&&p2.unlocks.indexOf(q.idx)!==-1;
      });
      var isLeg=q.tier==='legendary';
      var legUnlocked=isLeg&&[6,7].every(function(pi){return qs.done.indexOf(pi)!==-1;})&&maxLv>=QTIERS.perilous.minLv;
      if(parentsDone||legUnlocked){
        html+='<div class="enc-card" style="opacity:.4;border-style:dashed">'+
          '<div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">'+
          '<span>'+tier.badge+'</span>'+
          '<span style="font-family:\'Cinzel\',serif;font-size:.65em;text-transform:uppercase;color:'+tier.color+'">'+tier.label+'</span>'+
          '</div>'+
          '<div class="etitle" style="filter:blur(3px)">'+esc(q.title)+'</div>'+
          '<div style="font-size:.78em;color:var(--ink-light);margin-top:5px">🔒 Complete a prerequisite quest to reveal</div>'+
          '</div>';
      }
      return;
    }

    var readiness=!isDone&&!inProgress?questReadiness(q,qs):'ready';
    var borderCol=isDone?'var(--forest)':inProgress?'var(--gold-dark)':
      readiness==='ready'?'var(--forest)':readiness==='stretch'?'var(--gold-dark)':'var(--crimson)';

    var assigned=qs.assigned[q.idx]||[];
    var names=assigned.map(function(ci){return S.party[ci]?S.party[ci].name:'?';});

    var statusHtml='';
    if(inProgress){
      var remaining=pq.doneAt-now;
      var ready=remaining<=0;
      statusHtml='<div style="margin-top:6px;padding:7px 10px;background:rgba(201,146,42,.12);border:1px solid var(--gold-dark);border-radius:5px">'+
        '<div style="font-family:Cinzel,serif;font-size:.72em;color:var(--gold-dark);margin-bottom:3px">'+
        (ready?'✅ Quest complete — reward ready!':'⏳ In progress')+
        '</div>'+
        '<div style="font-family:monospace;font-size:.82em;color:var(--ink)" id="qcd-'+q.idx+'">'+fmtCountdown(remaining)+'</div>'+
        '<div style="font-size:.72em;color:var(--ink-light);margin-top:2px">'+
        names.map(function(n){return '<span style="background:rgba(139,26,26,.1);border:1px solid rgba(139,26,26,.3);border-radius:5px;padding:1px 5px;color:var(--crimson)">⚔ '+esc(n)+'</span>';}).join(' ')+
        '</div>'+
        '<div style="font-size:.72em;color:var(--gold-dark);margin-top:2px">💰 Reward: '+pq.reward+' gp</div>'+
        (ready?'<button class="btn bgn sm" style="margin-top:6px" data-a="qcollect" data-qi="'+q.idx+'">🏆 Collect '+pq.reward+' gp</button>':'')+
        '</div>';
    } else if(isDone){
      statusHtml='<div style="color:var(--forest);font-size:.8em;margin-top:5px">✓ Completed this cycle</div>';
    } else {
      var ri=readiness==='ready'?'🟢 Ready':readiness==='stretch'?'🟡 Stretch — push your limits':'🔴 Overreach — significant gaps';
      statusHtml='<div style="font-size:.72em;margin-top:4px">'+ri+'</div>';
    }

    html+='<div class="enc-card" style="border-color:'+borderCol+';border-width:1.5px">'+
      '<div style="display:flex;align-items:center;gap:6px;margin-bottom:3px">'+
      '<span>'+tier.badge+'</span>'+
      '<span class="etype et-'+q.type+'" style="color:'+tier.color+'">'+tier.label.toUpperCase()+' · '+q.type.toUpperCase()+'</span>'+
      '</div>'+
      '<div class="etitle">'+esc(q.title)+'</div>'+
      '<div class="edesc">'+esc(q.desc)+'</div>'+
      '<div class="erew">🪙 Base '+q.baseGp+' gp'+(q.pre.gold?' · Invest '+q.pre.gold+' gp':'')+
      (q.reward?' · '+esc(q.reward):'')+'</div>'+
      (!isDone&&!inProgress?'<div style="margin-top:4px;font-size:.75em;color:var(--ink-light)">Assigned: '+
        (names.length?names.map(function(n){return '<span style="background:rgba(139,26,26,.1);border:1px solid rgba(139,26,26,.3);border-radius:5px;padding:1px 5px;color:var(--crimson)">⚔ '+esc(n)+'</span>';}).join(' '):'<em>none yet</em>')+
        '</div>':'')+
      statusHtml+
      (!isDone&&!inProgress?'<button class="btn bg sm" style="margin-top:7px" data-a="qassign" data-qi="'+q.idx+'">⚔ Assign &amp; Begin</button>':'')+
      '</div>';
  });

  el.innerHTML=html;

  if(advCountdownTimer)clearInterval(advCountdownTimer);
  var hasActive=(qs.pending||[]).some(function(pq){return pq.doneAt>Date.now();});
  if(hasActive){
    advCountdownTimer=setInterval(function(){
      var n=Date.now();
      (S.questState.pending||[]).forEach(function(pq){
        if(S.questState.done.indexOf(pq.idx)!==-1)return;
        var cdEl=document.getElementById('qcd-'+pq.idx);
        if(!cdEl)return;
        var rem=pq.doneAt-n;
        cdEl.textContent=fmtCountdown(rem);
        if(rem<=0){clearInterval(advCountdownTimer);renderAdv();}
      });
    },1000);
  }
}

function questUnlock(completedIdx){
  var qs=S.questState;
  var q=QPOOL[completedIdx];
  if(!q)return;
  var available=tiersForLevel(partyMaxLevel());
  (q.unlocks||[]).forEach(function(ui){
    if(qs.revealed.indexOf(ui)!==-1)return;
    var target=QPOOL[ui];
    if(!target)return;
    // Don't reveal if the target tier isn't available for this party yet
    if(available.indexOf(target.tier)===-1)return;
    // Special double-lock for legendary
    if(target.tier==='legendary'){
      var bothPeril=[6,7].every(function(pi){return qs.done.indexOf(pi)!==-1;});
      if(!bothPeril||partyMaxLevel()<QTIERS.legendary.minLv)return;
    }
    qs.revealed.push(ui);
    logAdd('New quest revealed: "'+target.title+'" ('+QTIERS[target.tier].label+')','adv');
  });
}

function awardLegendaryReward(q){
  var roll=Math.random();
  var rewards=[];
  if(roll<0.05){
    rewards.push({type:'pet',item:rnd(LEG_PETS)});
    rewards.push({type:'artifact',item:rnd(LEG_ARTIFACTS)});
    rewards.push({type:'adventurer',item:rnd(LEG_ADVENTURERS)});
  } else if(roll<0.38){
    rewards.push({type:'pet',item:rnd(LEG_PETS)});
  } else if(roll<0.71){
    rewards.push({type:'artifact',item:rnd(LEG_ARTIFACTS)});
  } else {
    rewards.push({type:'adventurer',item:rnd(LEG_ADVENTURERS)});
  }
  var msgs=[];
  rewards.forEach(function(r){
    if(r.type==='adventurer'){
      var c=r.item,newC={};
      for(var k in c)newC[k]=c[k];
      S.party.push(newC);
      logAdd('⚔ Legendary recruit: '+c.name+' (Lv '+c.level+' '+c.cls+') joins the franchise!','hire');
      msgs.push('⚔ New Adventurer: '+c.name+'\n'+c.species+' '+c.cls+' · Level '+c.level);
    } else {
      if(!S.partyAssets)S.partyAssets=[];
      S.partyAssets.push({name:r.item.name,ic:r.item.ic,type:r.item.type});
      logAdd('✨ Legendary reward: '+r.item.name,'adv');
      msgs.push((r.type==='pet'?'🐾 Legendary Companion':'✨ Artifact')+': '+r.item.name+'\n'+r.item.desc);
    }
  });
  alert('🏆 LEGENDARY REWARD!\n\n'+msgs.join('\n\n'));
}

var P4={quest:null};

document.getElementById('avcontent').addEventListener('click',function(e){
  var bc=e.target.closest('[data-a="qcollect"]');
  if(bc){
    var qi=parseInt(bc.getAttribute('data-qi'));
    var qs=S.questState;
    var pqIdx=-1;
    (qs.pending||[]).forEach(function(pq,pi){if(pq.idx===qi)pqIdx=pi;});
    if(pqIdx===-1)return;
    var pq=qs.pending[pqIdx];
    if(pq.doneAt>Date.now()){alert('Not ready yet! '+fmtCountdown(pq.doneAt-Date.now()));return;}
    var q=QPOOL[qi];
    var cn=(pq.chars||[]).map(function(ci){return S.party[ci]?S.party[ci].name:'?';}).join(', ')||'unassigned';
    goldAdd(pq.reward,'Quest reward: "'+q.title+'" ('+cn+')','adv');
    qs.done.push(qi);
    qs.pending.splice(pqIdx,1);
    if(q.petReward&&Math.random()<q.petReward.chance){
      var eligible=PETS.filter(function(p){return p.rar===q.petReward.tier;});
      if(!eligible.length)eligible=PETS.filter(function(p){return p.rar==='common';});
      var pet=eligible[Math.floor(Math.random()*eligible.length)];
      if(!S.partyAssets)S.partyAssets=[];
      S.partyAssets.push({name:pet.name,ic:pet.ic,type:'pet'});
      logAdd('🐾 '+pet.name+' joins as companion','adv');
      alert('🐾 Rare Find!\n\n'+pet.ic+' '+pet.name+'\n'+pet.desc+'\n\nAdded to Party Assets.');
    }
    if(q.legendaryReward)awardLegendaryReward(q);
    questUnlock(qi);
    save();renderAdv();
    return;
  }

  var b=e.target.closest('[data-a="qassign"]');
  if(!b)return;
  var qi2=parseInt(b.getAttribute('data-qi'));
  P4.quest=qi2;
  var q2=QPOOL[qi2];
  var pr=q2.pre;
  var qs2=S.questState;
  document.getElementById('ov-q-desc').textContent=q2.desc;

  var busy={};
  var now0=Date.now();
  (qs2.pending||[]).forEach(function(pq){
    if(pq.idx===qi2)return;
    if(pq.doneAt>now0)(pq.chars||[]).forEach(function(ci){busy[ci]=true;});
  });

  var totalPre=(pr.skills||[]).length+(pr.tools||[]).length+(pr.lang||[]).length+(pr.rel?2:0)+(pr.items||[]).length;
  function score(c){
    var s=0;
    (pr.skills||[]).forEach(function(x){if((c.skills||[]).indexOf(x)!==-1)s++;});
    (pr.tools||[]).forEach(function(x){if((c.tools||[]).indexOf(x)!==-1)s++;});
    (pr.lang||[]).forEach(function(x){if((c.lang||[]).indexOf(x)!==-1)s++;});
    if(pr.rel&&c.rel===pr.rel)s+=2;
    (pr.items||[]).forEach(function(x){if((c.inv||[]).indexOf(x)!==-1)s++;});
    return s;
  }

  var bestEl=document.getElementById('ov-q-best');
  if(totalPre>0&&S.party.length){
    var scored=S.party.map(function(c,ci){return{ci:ci,sc:score(c),name:c.name};})
      .filter(function(x){return !busy[x.ci]&&!S.party[x.ci].hireling;})
      .sort(function(a,b2){return b2.sc-a.sc;});
    if(scored.length&&scored[0].sc>0){
      bestEl.style.display='block';
      bestEl.textContent='💡 Best fit: '+scored.slice(0,2).map(function(x){return x.name;}).join(', ');
    } else bestEl.style.display='none';
  } else bestEl.style.display='none';

  var prevAssigned=qs2.assigned[qi2]||[];
  document.getElementById('ov-q-chars').innerHTML=S.party.length?
    S.party.map(function(c,ci){
      var isBusy=busy[ci];
      var chk=prevAssigned.indexOf(ci)!==-1?'checked':'';
      var pct2=totalPre>0?Math.round(score(c)/totalPre*100):null;
      var ml=pct2!==null?' <span style="font-size:.67em;color:'+(pct2>=80?'var(--forest)':pct2>=40?'var(--gold-dark)':'var(--ink-light)')+'">'+
        (pct2>=80?'⭐':pct2>=40?'🔸':'')+pct2+'%</span>':'';;
      var bl=isBusy?'<span style="font-size:.63em;color:var(--crimson);margin-left:4px">⚠ on quest</span>':'';
      var hl=c.hireling?'<span style="font-size:.63em;color:var(--ink-light);margin-left:4px">🪓 hireling</span>':'';
      return '<label style="'+(isBusy?'opacity:.45;cursor:not-allowed;':'')+'display:flex;align-items:center;gap:6px;margin-bottom:4px">'+
        '<input type="checkbox" class="qcb" value="'+ci+'" '+chk+(isBusy?' disabled':'')+' style="width:auto">'+
        esc(c.name)+' ('+esc(c.cls)+', Lv '+c.level+')'+ml+bl+hl+'</label>';
    }).join('')+''  :'<div style="font-style:italic;font-size:.82em;color:var(--ink-light)">No adventurers yet.</div>';

  var prRow=document.getElementById('ov-q-payrow');
  if(pr.pay){
    prRow.style.display='block';
    var sel=document.getElementById('ov-q-pay');
    sel.value='0';
    for(var oi=0;oi<sel.options.length;oi++){
      if(parseFloat(sel.options[oi].value)>=pr.pay){sel.value=sel.options[oi].value;break;}
    }
  } else {
    prRow.style.display='none';
    document.getElementById('ov-q-pay').value='0';
  }
  var gpRow=document.getElementById('ov-q-goldrow');
  if(pr.gold){gpRow.style.display='block';document.getElementById('ov-q-goldnote').textContent=pr.gold+' gp spent now — returned with 50% profit in reward.';}
  else gpRow.style.display='none';

  updateQuestModal();
  openOv('ov-quest');
});

function getQuestChars(){
  var r=[];
  document.querySelectorAll('.qcb:checked').forEach(function(cb){r.push(parseInt(cb.value));});
  return r;
}

function updateQuestModal(){
  if(P4.quest===null)return;
  var q=QPOOL[P4.quest];
  var chars=getQuestChars();
  var pay=parseFloat(document.getElementById('ov-q-pay').value)||0;
  document.getElementById('ov-q-prereqs').innerHTML=questPrereqHtml(q,chars,pay);
  document.getElementById('ov-q-reward').textContent=questCalcReward(q,chars,pay);
  var missing=questPrereqCheck(q,chars,pay);
  var unmet=document.getElementById('ov-q-unmet');
  if(missing.length){unmet.style.display='block';unmet.textContent='⚠ Missing: '+missing.join('; ')+'. Can still complete — bonus reduced.';}
  else unmet.style.display='none';
}

document.getElementById('ov-q-chars').addEventListener('change',updateQuestModal);
document.getElementById('ov-q-pay').addEventListener('change',updateQuestModal);

document.getElementById('ov-q-no').addEventListener('click',function(){closeOv('ov-quest');});
document.getElementById('ov-q-yes').addEventListener('click',function(){
  if(P4.quest===null)return;
  var q=QPOOL[P4.quest];
  var pr=q.pre;
  var chars=getQuestChars();
  var pay=parseFloat(document.getElementById('ov-q-pay').value)||0;
  var reward=questCalcReward(q,chars,pay);
  if(chars.length>0){
    var allHirelings=chars.every(function(ci){return S.party[ci]&&S.party[ci].hireling;});
    if(allHirelings){alert('⚠ At least one full adventurer required.');return;}
  }
  if(pr.gold&&pr.gold>0){if(!goldSpend(pr.gold,'Gold invest: "'+q.title+'"','adv'))return;}
  var payCost=Math.round(pay*4);
  if(payCost>0){if(!goldSpend(payCost,'Payroll for "'+q.title+'"','adv'))return;}
  var qs=S.questState;
  if(!qs.assigned)qs.assigned={};
  qs.assigned[P4.quest]=chars;
  if(!qs.pending)qs.pending=[];
  var doneAt=Date.now()+(8*3600000);
  qs.pending.push({idx:P4.quest,chars:chars,reward:reward,doneAt:doneAt});
  var cn=chars.map(function(ci){return S.party[ci]?S.party[ci].name:'?';}).join(', ')||'unassigned';
  logAdd('Quest started: "'+q.title+'" ('+cn+') — '+reward+' gp in 8 hrs','adv');
  P4.quest=null;closeOv('ov-quest');save();renderAdv();
});

/* ═══════════════════════ STORE ═══════════════════════ */

var storeTab='gear';
var P5={item:null};

document.getElementById('s-store').querySelector('.store-tabs').addEventListener('click',function(e){
  var b=e.target.closest('.stab');
  if(!b)return;
  storeTab=b.getAttribute('data-tab');
  document.querySelectorAll('.stab').forEach(function(t){t.classList.remove('on');});
  b.classList.add('on');
  var notes={gear:'Gear & magic refreshes daily',vehicles:'All vehicles available',buildings:'All buildings available',pets:'Companions & familiars'};
  document.getElementById('store-note').textContent=notes[storeTab]||'';
  document.getElementById('btn-reroll').style.display=storeTab==='gear'?'':'none';
  renderStore();
});

function buildStock(){
  function byR(r){return GEAR.filter(function(x){return x.rar===r;});}
  S.stock=[].concat(
    pick(byR('common'),5),pick(byR('uncommon'),3),
    pick(byR('rare'),Math.random()<0.6?2:1),
    Math.random()<0.2?pick(byR('veryrare'),1):[]
  );
  S.stockDate=todayStr();save();
}

function renderStore(){
  var items;
  if(storeTab==='gear'){
    if(!S.stock||!S.stock.length||S.stockDate!==todayStr())buildStock();
    items=S.stock;
  } else if(storeTab==='vehicles'){items=VEHICLES;}
  else if(storeTab==='pets'){items=PETS;}
  else{items=BUILDINGS;}
  var notes={gear:'Gear & magic refreshes daily',vehicles:'All vehicles available',buildings:'All buildings available',pets:'Companions & familiars'};
  document.getElementById('store-note').textContent=notes[storeTab]||'';
  document.getElementById('btn-reroll').style.display=storeTab==='gear'?'':'none';
  var el=document.getElementById('slist');
  if(!items||!items.length){el.innerHTML='<div class="empty">Nothing available.</div>';return;}
  el.innerHTML=items.map(function(item,i){
    var ok=S.gold>=item.price;
    return '<div class="store-card">'+
      '<div class="stic">'+item.ic+'</div>'+
      '<div class="sinfo"><div class="sname">'+esc(item.name)+
      '<span style="font-size:.55em;background:rgba(44,26,14,.07);border-radius:2px;padding:1px 4px;margin-left:4px;color:var(--ink-light);">'+item.type+'</span>'+
      '</div><div class="sdesc">'+esc(item.desc)+'</div>'+
      '<span class="rarity r-'+item.rar+'">'+item.rar+'</span></div>'+
      '<div class="spcol"><div class="sprice">🪙 '+item.price.toLocaleString()+' gp</div>'+
      '<button class="btn bg sm" data-a="buy" data-i="'+i+'"'+(ok?'':' disabled')+'>Buy</button>'+
      '</div></div>';
  }).join('');
}

document.getElementById('btn-reroll').addEventListener('click',function(){buildStock();renderStore();});

document.getElementById('slist').addEventListener('click',function(e){
  var b=e.target.closest('[data-a="buy"]');
  if(!b||b.disabled)return;
  var i=parseInt(b.getAttribute('data-i'));
  var items=storeTab==='gear'?S.stock:storeTab==='vehicles'?VEHICLES:storeTab==='pets'?PETS:BUILDINGS;
  P5.item={item:items[i],tab:storeTab};
  document.getElementById('ov-bi-msg').textContent='"'+items[i].name+'" — '+items[i].price.toLocaleString()+' gp';
  var cr=document.getElementById('ov-bi-charrow');
  var pn=document.getElementById('ov-bi-partynote');
  if(items[i].party){
    cr.style.display='none';pn.style.display='block';
    pn.textContent='This will be added to Party Assets.';
  } else {
    cr.style.display='block';pn.style.display='none';
    if(!S.party.length){alert('Need at least one adventurer!');return;}
    document.getElementById('ov-bi-sel').innerHTML=S.party.map(function(c,ci){
      return '<option value="'+ci+'">'+esc(c.name)+' ('+esc(c.cls)+')</option>';
    }).join('');
  }
  openOv('ov-buyitem');
});

document.getElementById('ov-bi-no').addEventListener('click',function(){closeOv('ov-buyitem');});
document.getElementById('ov-bi-yes').addEventListener('click',function(){
  if(!P5.item)return;
  var item=P5.item.item;
  if(!goldSpend(item.price,'Purchased '+item.name,'buy'))return;
  if(item.party){
    if(!S.partyAssets)S.partyAssets=[];
    S.partyAssets.push({name:item.name,ic:item.ic,type:item.type});
    logAdd(item.name+' added to Party Assets','buy');
  } else {
    var ci=parseInt(document.getElementById('ov-bi-sel').value);
    if(!S.party[ci].inv)S.party[ci].inv=[];
    S.party[ci].inv.push(item.name);
    logAdd(item.name+' → '+S.party[ci].name,'buy');
  }
  P5.item=null;closeOv('ov-buyitem');save();renderParty();renderStore();
});

/* ═══════════════════════ SETTINGS ═══════════════════════ */

function applySettings(){
  var cfg=S.settings||{};
  var fs=(cfg.fontSize||18)+'px';
  document.getElementById('app').style.setProperty('--fs',fs);
  var n=cfg.appName||'Acquisitions Incorporated';
  var sub=cfg.subtitle||'Field Operations Ledger — Personal Edition';
  document.getElementById('hdr-title').textContent='⚔ '+n+' ⚔';
  document.getElementById('hdr-sub').textContent=sub;
  document.title=n+' — Field Ledger';
}

function renderSettings(){
  var cfg=S.settings||{};
  document.getElementById('set-name').value=cfg.appName||'';
  document.getElementById('set-sub').value=cfg.subtitle||'';
  document.getElementById('set-fs').value=String(cfg.fontSize||18);
  document.getElementById('set-morn').value=String(cfg.morningHour||6);
  document.getElementById('fs-preview').textContent='Current: '+(cfg.fontSize||18)+'px';
}

document.getElementById('set-fs').addEventListener('change',function(){
  if(!S.settings)S.settings={};
  S.settings.fontSize=parseInt(this.value)||18;
  document.getElementById('app').style.setProperty('--fs',S.settings.fontSize+'px');
  document.getElementById('fs-preview').textContent='Current: '+S.settings.fontSize+'px';
  save();
});
document.getElementById('btn-savebrand').addEventListener('click',function(){
  if(!S.settings)S.settings={};
  S.settings.appName=document.getElementById('set-name').value.trim();
  S.settings.subtitle=document.getElementById('set-sub').value.trim();
  applySettings();save();alert('Branding saved!');
});
document.getElementById('btn-savemorn').addEventListener('click',function(){
  if(!S.settings)S.settings={};
  S.settings.morningHour=parseInt(document.getElementById('set-morn').value)||6;
  save();alert('Reset time saved!');
});
document.getElementById('btn-export').addEventListener('click',function(){
  var json=JSON.stringify(S,null,2);
  var blob=new Blob([json],{type:'application/json'});
  var url=URL.createObjectURL(blob);
  var a=document.createElement('a');
  a.href=url;a.download='acqinc-save.json';a.click();
  URL.revokeObjectURL(url);
});
document.getElementById('btn-import-trigger').addEventListener('click',function(){
  document.getElementById('import-file-input').value='';
  document.getElementById('import-file-input').click();
});
document.getElementById('import-file-input').addEventListener('change',function(e){
  var file=e.target.files&&e.target.files[0];
  if(!file){return;}
  var statusEl=document.getElementById('import-status');
  var reader=new FileReader();
  reader.onload=function(ev){
    try{
      var d=JSON.parse(ev.target.result);
      // Basic validation
      if(typeof d!=='object'||Array.isArray(d)){
        statusEl.textContent='❌ Invalid file — not a save object.';return;
      }
      // Merge ALL keys from imported data into S
      for(var k in d){
        if(d.hasOwnProperty(k))S[k]=d[k];
      }
      // Ensure any keys present in S but missing from d keep their defaults
      // (already the case since we only overwrite what d has)
      save();
      // Refresh every screen and global UI element
      setGold();
      applySettings();
      renderTasks();
      renderSettings();
      // Status summary
      var inv=0;
      (S.party||[]).forEach(function(c){inv+=(c.inv||[]).length;});
      statusEl.style.color='var(--forest)';
      statusEl.textContent='✅ Imported — '+
        S.gold+' gp · '+
        (S.active||[]).length+' contracts · '+
        (S.archived||[]).length+' archived · '+
        (S.party||[]).length+' adventurers · '+
        inv+' inventory items · '+
        (S.squads||[]).length+' squads · '+
        (S.partyAssets||[]).length+' party assets.';
      logAdd('Save data imported from file.','gold');
    }catch(err){
      statusEl.textContent='❌ Error reading file: '+err.message;
    }
  };
  reader.readAsText(file);
});

/* ═══════════════════════ SUPABASE SYNC ═══════════════════════ */

var SB_URL='https://kzrxedpcasrwzhfqhzit.supabase.co';
var SB_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imt6cnhlZHBjYXNyd3poZnFoeml0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ5ODM5NzYsImV4cCI6MjA5MDU1OTk3Nn0.GBTpGx2Lukkhm4ef2FiuCOOwAQ8OVBFaC65o_yG2IiM';

var SB_HDR={'Content-Type':'application/json','apikey':SB_KEY,'Authorization':'Bearer '+SB_KEY};

function sbGet(table,params){
  return fetch(SB_URL+'/rest/v1/'+table+'?'+(params||''),{method:'GET',headers:SB_HDR})
    .then(function(r){if(!r.ok)throw new Error(table+' GET '+r.status);return r.json();});
}
function sbUpsert(table,rows){
  return fetch(SB_URL+'/rest/v1/'+table,{
    method:'POST',
    headers:Object.assign({},SB_HDR,{'Prefer':'resolution=merge-duplicates,return=minimal'}),
    body:JSON.stringify(Array.isArray(rows)?rows:[rows])
  }).then(function(r){if(!r.ok)return r.text().then(function(t){throw new Error(table+' upsert '+r.status+': '+t);});return true;});
}
function sbDel(table,filter){
  return fetch(SB_URL+'/rest/v1/'+table+'?'+filter,{method:'DELETE',headers:SB_HDR})
    .then(function(r){if(!r.ok&&r.status!==404)throw new Error(table+' DELETE '+r.status);return true;});
}

function syncStatus(msg,color){
  var el=document.getElementById('sync-status');
  if(!el)return;
  el.textContent=msg;
  el.style.color=color||'var(--ink-light)';
}

/* ── PUSH ── */
function sbPush(manual){
  syncStatus('Syncing\u2026','var(--gold-dark)');
  var ops=[];

  // franchise
  ops.push(sbUpsert('franchise',{id:'main',gold:S.gold,settings:S.settings||{},last_sync:new Date().toISOString()}));

  // party — delete all then re-insert (simplest for ordering)
  ops.push(sbDel('party','id=neq.00000000-0000-0000-0000-000000000000').then(function(){
    if(!(S.party||[]).length)return true;
    return sbUpsert('party',S.party.map(function(c,i){
      return {sort_order:i,name:c.name,species:c.species||'',cls:c.cls||'',bg:c.bg||'',
        rel:c.rel||'',age:c.age||0,height:c.height||'',weight:c.weight||'',
        level:c.level||0,hire_cost:c.hireCost||0,
        hireling:!!c.hireling,former_hireling:!!c.formerHireling,premium:!!c.premium,
        skills:c.skills||[],tools:c.tools||[],lang:c.lang||[],weapons:c.weapons||[],inv:c.inv||[]};
    }));
  }));

  // active tasks
  ops.push(sbDel('active_tasks','id=neq.00000000-0000-0000-0000-000000000000').then(function(){
    if(!(S.active||[]).length)return true;
    return sbUpsert('active_tasks',S.active.map(function(t,i){
      return {sort_order:i,name:t.name,gp:t.gp||5,count:t.count||0,
        subtasks:t.subtasks||[],collapsed:!!t.collapsed,fav:!!t.fav,
        freq:t.freq||null,cat:t.cat||null,burner_until:t.burnerUntil||null};
    }));
  }));

  // archived tasks
  ops.push(sbDel('archived_tasks','id=neq.00000000-0000-0000-0000-000000000000').then(function(){
    if(!(S.archived||[]).length)return true;
    return sbUpsert('archived_tasks',S.archived.map(function(t,i){
      return {sort_order:i,name:t.name,gp:t.gp||5,freq:t.freq||'custom',
        cat:t.cat||null,fav:!!t.fav,subtasks:t.subtasks||[],
        arch_group:t.archGroup||t.freq||'custom'};
    }));
  }));

  // party assets
  ops.push(sbDel('party_assets','id=neq.00000000-0000-0000-0000-000000000000').then(function(){
    if(!(S.partyAssets||[]).length)return true;
    return sbUpsert('party_assets',(S.partyAssets||[]).map(function(a,i){
      return {sort_order:i,name:a.name,ic:a.ic||'',type:a.type||''};
    }));
  }));

  // squads
  ops.push(sbDel('squads','id=neq.00000000-0000-0000-0000-000000000000').then(function(){
    if(!(S.squads||[]).length)return true;
    return sbUpsert('squads',(S.squads||[]).map(function(sq){
      return {name:sq.name,member_ids:[],collapsed:!!sq.collapsed};
    }));
  }));

  // quest state
  if(S.questState){
    ops.push(sbUpsert('quest_cycles',{
      cycle_id:S.questState.cycleId,
      revealed:S.questState.revealed||[],
      done:S.questState.done||[],
      pending:S.questState.pending||[],
      assigned:S.questState.assigned||{},
      party_lv_at_start:S.questState.partyLvAtStart||0
    }));
  }

  // gold log (last 100, replace)
  var recentLog=(S.log||[]).slice(0,100);
  if(recentLog.length){
    ops.push(sbDel('gold_log','id=neq.00000000-0000-0000-0000-000000000000').then(function(){
      return sbUpsert('gold_log',recentLog.map(function(e){
        return {msg:e.msg,type:e.type||'gold',entry_date:e.date||'',entry_time:e.time||''};
      }));
    }));
  }

  return Promise.all(ops)
    .then(function(){
      if(manual){
        syncStatus('\u2705 Pushed to Supabase '+new Date().toLocaleTimeString(),'var(--forest)');
        logAdd('Supabase: push complete.','gold');
      } else {
        syncStatus('\u2601 Synced '+new Date().toLocaleTimeString(),'var(--ink-light)');
      }
    })
    .catch(function(err){
      syncStatus('\u26a0 Sync error: '+err.message,'var(--crimson)');
      console.error('Supabase push:',err);
    });
}

/* ── PULL ── */
function sbPull(manual){
  if(manual)syncStatus('Pulling from Supabase\u2026','var(--gold-dark)');
  return Promise.all([
    sbGet('franchise','id=eq.main'),
    sbGet('party','order=sort_order.asc'),
    sbGet('active_tasks','order=sort_order.asc'),
    sbGet('archived_tasks','order=sort_order.asc'),
    sbGet('party_assets','order=sort_order.asc'),
    sbGet('squads','order=created_at.asc'),
    sbGet('quest_cycles','order=created_at.desc&limit=1'),
    sbGet('gold_log','order=created_at.desc&limit=500'),
    sbGet('task_groups','order=sort_order.asc'),
    sbGet('archive_groups','order=sort_order.asc')
  ]).then(function(res){
    var franchise=res[0],party=res[1],tasks=res[2],archived=res[3],
        assets=res[4],squads=res[5],questCycles=res[6],log=res[7],
        taskGroups=res[8],archGroups=res[9];

    if(franchise&&franchise[0]){
      S.gold=franchise[0].gold||0;
      S.settings=franchise[0].settings||{appName:'',subtitle:'',fontSize:18,morningHour:6};
    }
    if(party&&party.length){
      S.party=party.map(function(c){
        return {_sbId:c.id,name:c.name,species:c.species,cls:c.cls,bg:c.bg,rel:c.rel,
          age:c.age,height:c.height,weight:c.weight,level:c.level,hireCost:c.hire_cost,
          hireling:c.hireling,formerHireling:c.former_hireling,premium:c.premium,
          skills:c.skills||[],tools:c.tools||[],lang:c.lang||[],weapons:c.weapons||[],inv:c.inv||[]};
      });
    }
    if(tasks&&tasks.length){
      S.active=tasks.map(function(t){
        return {_sbId:t.id,name:t.name,gp:t.gp,count:t.count,subtasks:t.subtasks||[],
          collapsed:t.collapsed,fav:t.fav,freq:t.freq,cat:t.cat,burnerUntil:t.burner_until||null};
      });
    }
    if(archived&&archived.length){
      S.archived=archived.map(function(t){
        return {_sbId:t.id,name:t.name,gp:t.gp,freq:t.freq,cat:t.cat,
          fav:t.fav,subtasks:t.subtasks||[],archGroup:t.arch_group};
      });
    }
    if(assets&&assets.length){
      S.partyAssets=assets.map(function(a){return {_sbId:a.id,name:a.name,ic:a.ic,type:a.type};});
    }
    if(squads&&squads.length){
      S.squads=squads.map(function(sq){
        return {_sbId:sq.id,name:sq.name,memberIdxs:[],collapsed:sq.collapsed||false};
      });
    }
    if(questCycles&&questCycles[0]){
      var qc=questCycles[0];
      S.questState={cycleId:qc.cycle_id,revealed:qc.revealed||[],done:qc.done||[],
        pending:qc.pending||[],assigned:qc.assigned||{},partyLvAtStart:qc.party_lv_at_start||0};
    }
    if(log&&log.length){
      S.log=log.map(function(e){return {_sbId:e.id,msg:e.msg,type:e.type,date:e.entry_date,time:e.entry_time};});
    }
    if(taskGroups&&taskGroups.length){
      S.taskGroups=taskGroups.map(function(g){
        return {_sbId:g.id,name:g.name,taskIds:[],collapsed:g.collapsed,deferUntil:g.defer_until||0};
      });
    }
    if(archGroups&&archGroups.length){
      archGroups.forEach(function(g){FLAB[g.key]=g.label;});
      S.archGroups=archGroups.map(function(g){return {key:g.key,label:g.label};});
    }

    try{localStorage.setItem('acqv7',JSON.stringify(S));}catch(e){}
    setGold();applySettings();renderTasks();renderSettings();
    var inv=0;(S.party||[]).forEach(function(c){inv+=(c.inv||[]).length;});
    if(manual){
      syncStatus('\u2705 Pulled '+new Date().toLocaleTimeString()+
        ' \u2014 '+S.gold+' gp \u00b7 '+(S.active||[]).length+' tasks \u00b7 '+
        (S.party||[]).length+' adventurers \u00b7 '+inv+' items','var(--forest)');
      logAdd('Supabase: pull complete.','gold');
    } else {
      syncStatus('\u2601 Loaded from Supabase '+new Date().toLocaleTimeString(),'var(--ink-light)');
    }
  }).catch(function(err){
    syncStatus(manual?'\u274c Pull failed: '+err.message:'\u26a0 Offline \u2014 using local data','var(--crimson)');
    console.error('Supabase pull:',err);
  });
}

/* ── Debounced auto-push ── */
var autoPushTimer=null;
function schedulePush(){
  if(autoPushTimer)clearTimeout(autoPushTimer);
  autoPushTimer=setTimeout(function(){sbPush(false);},4000);
}

document.getElementById('btn-sync-push').addEventListener('click',function(){sbPush(true);});
document.getElementById('btn-sync-pull').addEventListener('click',function(){sbPull(true);});

function checkFavourites(){
  var today=todayStr();
  if(S.lastFavCheck===today)return;
  var h=(S.settings&&S.settings.morningHour)||6;
  if(new Date().getHours()<h)return;
  S.lastFavCheck=today;
  var n=0;
  S.archived.forEach(function(t){
    if(!t.fav)return;
    if(S.active.some(function(a){return a.name===t.name;}))return;
    S.active.push({name:t.name,gp:t.gp,count:0,freq:t.freq,cat:t.cat,
      subtasks:(t.subtasks||[]).map(function(s){return{name:s.name,done:false};}),
      collapsed:false,fav:true});
    n++;
  });
  if(n){logAdd('Morning: '+n+' favourite'+( n>1?'s':'')+' activated.','task');save();}
}

/* ═══════════════════════ NAVIGATION ═══════════════════════ */

var SCRMAP={
  tasks:'s-tasks',archive:'s-archive',party:'s-party',recruit:'s-recruit',
  adventure:'s-adventure',store:'s-store',log:'s-log',settings:'s-settings'
};
var RENDER={
  tasks:renderTasks,archive:renderArchive,party:renderParty,
  adventure:renderAdv,store:renderStore,log:renderLog,settings:renderSettings
};

document.getElementById('nav').addEventListener('click',function(e){
  var b=e.target.closest('.nb');
  if(!b)return;
  var s=b.getAttribute('data-s');
  document.querySelectorAll('.scr').forEach(function(el){el.classList.remove('on');});
  document.querySelectorAll('.nb').forEach(function(el){el.classList.remove('on');});
  var target=document.getElementById(SCRMAP[s]);
  if(target)target.classList.add('on');
  b.classList.add('on');
  if(RENDER[s])RENDER[s]();
});

// Close overlays on backdrop click
document.querySelectorAll('.ov').forEach(function(ov){
  ov.addEventListener('click',function(e){if(e.target===ov)ov.classList.remove('on');});
});

/* ═══════════════════════ INIT ═══════════════════════ */

load();

if(!S.party.length){
  S.party.push({
    name:'The Founder',species:'Human',cls:'Expert',bg:'Guild Artisan',
    rel:'Avandra (Change)',age:34,height:"5'10\"",weight:'175 lbs',
    lang:['Common','Elvish'],skills:['Persuasion','Insight','Investigation','History'],
    tools:["Cartographer's Tools",'Gaming Set'],weapons:['Simple Weapons'],
    level:1,inv:['Ledger of Accounts','Fancy Quill Pen','Company Seal']
  });
}
if(!S.archived.length){
  S.archived=PRESET.map(function(t){return{name:t.name,gp:t.gp,freq:t.freq,cat:t.cat,count:0,subtasks:[],fav:false};});
}
if(!S.log.length){
  S.gold=10;
  logAdd('Franchise established. Starting stipend: 10 gp.','gold');
}
if(!S.squads)S.squads=[];
if(!S.squadCollapsed)S.squadCollapsed={};
if(!S.taskGroups)S.taskGroups=[];
if(!S.partyAssets)S.partyAssets=[];
if(S.assetsCollapsed===undefined)S.assetsCollapsed=false;
if(!S.encAssigned)S.encAssigned={};
if(!S.doneEnc)S.doneEnc=[];
if(!S.pendingQuests)S.pendingQuests=[];
if(!S.questCycles)S.questCycles=[];
if(!S.questState)initQuestState();
checkQuestCycleReset();
if(!S.archGroups)S.archGroups=[];
if(!S.archCollapsed)S.archCollapsed={};
if(!S.settings)S.settings={appName:'',subtitle:'',fontSize:18,morningHour:6};
if(!S.settings.morningHour)S.settings.morningHour=6;
if(!S.lastFavCheck)S.lastFavCheck='';

save();
applySettings();
checkFavourites();
setGold();
renderTasks();

// Pull fresh data from Supabase on startup (async — UI already showing from localStorage)
sbPull(false).then(function(){
  checkQuestCycleReset();
  setGold();
  renderTasks();
  renderSettings();
}).catch(function(){
  // Offline — localStorage data already displayed, that's fine
});

})();
</script>
</body>
