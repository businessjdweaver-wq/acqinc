// Which tiers are available for a given party max level
function tiersForLevel(maxLv){
  if(maxLv>=11)return ['common','uncommon','rare','perilous','legendary'];
  if(maxLv>=7) return ['common','uncommon','rare','perilous'];
  if(maxLv>=5) return ['common','uncommon','rare'];
  if(maxLv>=2) return ['common','uncommon'];
  return ['common'];
}

