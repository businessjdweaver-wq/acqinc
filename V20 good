  var q2=set.quests[qi2];
  if(!q2)return;
  var pr=q2.pre;

  document.getElementById('ov-q-desc').textContent=q2.desc;

  var busy={};
  var now0=Date.now();
  (qs.pending||[]).forEach(function(pq){
    if(pq.idx===qi2)return;
    if(pq.doneAt>now0)(pq.chars||[]).forEach(function(ci){busy[ci]=true;});
  });

  var totalPre=(pr.skills||[]).length+(pr.tools||[]).length+(pr.lang||[]).length+(pr.rel?2:0)+(pr.items||[]).length;
  function score(c){
    var s=0;
    (pr.skills||[]).forEach(function(x){if((c.skills||[]).indexOf(x)!==-1)s++;});
    (pr.tools||[]).forEach(function(x){if((c.tools||[]).indexOf(x)!==-1)s++;});
    (pr.lang||[]).forEach(function(x){if((c.lang||[]).indexOf(x)!==-1)s++;});
    if(pr.rel&&c.rel===pr.rel)s+=2;
    (pr.items||[]).forEach(function(x){if((c.inv||[]).indexOf(x)!==-1)s++;});
    return s;
  }

  var bestEl=document.getElementById('ov-q-best');
  if(totalPre>0&&S.party.length){
    var scored=S.party.map(function(c,ci){return{ci:ci,sc:score(c),name:c.name};})
      .filter(function(x){return !busy[x.ci]&&!S.party[x.ci].hireling;})
      .sort(function(a,b2){return b2.sc-a.sc;});
    if(scored.length&&scored[0].sc>0){
      bestEl.style.display='block';
      bestEl.textContent='💡 Best fit: '+scored.slice(0,2).map(function(x){return x.name;}).join(', ');
    } else bestEl.style.display='none';
  } else bestEl.style.display='none';

  var prevAssigned=qs.assigned[qi2]||qs.assigned[String(qi2)]||[];
  document.getElementById('ov-q-chars').innerHTML=S.party.length?
    S.party.map(function(c,ci){
      var isBusy=busy[ci];
      var chk=prevAssigned.indexOf(ci)!==-1?'checked':'';
      var pct2=totalPre>0?Math.round(score(c)/totalPre*100):null;
      var ml=pct2!==null?' <span style="font-size:.67em;color:'+(pct2>=80?'var(--forest)':pct2>=40?'var(--gold-dark)':'var(--ink-light)')+'">'+
        (pct2>=80?'⭐':pct2>=40?'🔸':'')+pct2+'%</span>':'';
      var bl=isBusy?'<span style="font-size:.63em;color:var(--crimson);margin-left:4px">⚠ on quest</span>':'';
      var hl=c.hireling?'<span style="font-size:.63em;color:var(--ink-light);margin-left:4px">🪓 hireling</span>':'';
      var cl=c.contact?'<span style="font-size:.63em;color:var(--teal);margin-left:4px">🤝 contact</span>':'';
      return '<label style="'+(isBusy?'opacity:.45;cursor:not-allowed;':'')+'display:flex;align-items:center;gap:6px;margin-bottom:4px">'+
        '<input type="checkbox" class="qcb" value="'+ci+'" '+chk+(isBusy?' disabled':'')+' style="width:auto">'+
        esc(c.name)+' ('+esc(c.cls)+', Lv '+c.level+')'+ml+bl+hl+cl+'</label>';
    }).join(''):'<div style="font-style:italic;font-size:.82em;color:var(--ink-light)">No adventurers yet.</div>';

  var prRow=document.getElementById('ov-q-payrow');
  if(pr.pay){
    prRow.style.display='block';
    var sel=document.getElementById('ov-q-pay');
    sel.value='0';
    for(var oi=0;oi<sel.options.length;oi++){
      if(parseFloat(sel.options[oi].value)>=pr.pay){sel.value=sel.options[oi].value;break;}
    }
  } else {
    prRow.style.display='none';
    document.getElementById('ov-q-pay').value='0';
  }
  var gpRow=document.getElementById('ov-q-goldrow');
  if(pr.gold){gpRow.style.display='block';document.getElementById('ov-q-goldnote').textContent=pr.gold+' gp spent now — returned with 50% profit in reward.';}
  else gpRow.style.display='none';

  updateQuestModal();
  openOv('ov-quest');
});

