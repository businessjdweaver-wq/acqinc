function questReadiness(q,qs){
  var available=S.party.map(function(_,ci){return ci;}).filter(function(ci){
    var busy=false;
    (qs.pending||[]).forEach(function(pq){if(pq.doneAt>Date.now()&&(pq.chars||[]).indexOf(ci)!==-1)busy=true;});
    return !busy;
  });
  var missing=questPrereqCheck(q,available,q.pre.pay||0);
  if(missing.length===0)return 'ready';
  if(missing.length<=2)return 'stretch';
  return 'overreach';
}

function fmtCountdown(ms){
  if(ms<=0)return 'Ready to collect!';
  var h=Math.floor(ms/3600000);
  var m=Math.floor((ms%3600000)/60000);
  var s=Math.floor((ms%60000)/1000);
  return h+'h '+'0'.concat(m).slice(-2)+'m '+'0'.concat(s).slice(-2)+'s remaining';
}

