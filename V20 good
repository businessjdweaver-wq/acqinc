/* ═══════════════════════ QUEST SYSTEM ═══════════════════════ */

function cycleId(){
  var d=new Date();
  return d.getFullYear()+'-'+(d.getMonth()+1);
}
function cycleLabel(){
  var d=new Date();
  var months=['January','February','March','April','May','June',
              'July','August','September','October','November','December'];
  return months[d.getMonth()]+' '+d.getFullYear();
}

function initQuestState(cycleNum){
  var id=cycleId();
  var maxLv=partyMaxLevel();
  var tier=partyDndTier(maxLv);
  var num=cycleNum||0;
  var set=questSetForCycle(num,tier);
  S.questState={
    cycleId:id,
    setId:set.id,
    cycleNum:num,
    revealed:set.quests.map(function(q){return q.idx;}), // all non-capstone visible; capstone gated by done count
    done:[],
    pending:[],
    assigned:{},
    grindPending:[]
  };
}

function checkQuestCycleReset(){
  if(!S.questState||!S.questState.cycleId){initQuestState(0);return;}
  var cur=cycleId();
  if(S.questState.cycleId===cur)return;
  // New month — archive old cycle and init new one
  var old=S.questState;
  var set=activeQuestSet();
  var missed=set.quests.filter(function(q){
    return old.done.indexOf(q.idx)===-1;
  }).map(function(q){return q.title;});
  if(!S.questCycles)S.questCycles=[];
  S.questCycles.push({cycleId:old.cycleId,setId:old.setId,completed:old.done,missed:missed});
  var msg='New quest cycle: '+cycleLabel()+'. Previous: '+
    old.done.length+' completed'+(missed.length?' · missed: '+missed.join(', '):'');
  logAdd(msg,'adv');
  var nextNum=(old.cycleNum||0)+1;
  initQuestState(nextNum);
  save();
}

