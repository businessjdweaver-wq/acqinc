function pickItemForChar(c,budget){
  // Build priority list from skills, class, and all affinities
  var candidates=[];
  var add=function(name){if(candidates.indexOf(name)===-1)candidates.push(name);};
  if(ITEM_AFFINITY[c.cls])ITEM_AFFINITY[c.cls].forEach(add);
  (c.skills||[]).forEach(function(sk){if(ITEM_AFFINITY[sk])ITEM_AFFINITY[sk].forEach(add);});
  // Filter to affordable items char doesn't already own
  var owned=(c.inv||[]);
  var eligible=GEAR.filter(function(g){
    return g.price<=budget&&owned.indexOf(g.name)===-1&&candidates.indexOf(g.name)!==-1;
  });
  // Fall back to any affordable item not owned
  if(!eligible.length){
    eligible=GEAR.filter(function(g){return g.price<=budget&&owned.indexOf(g.name)===-1;});
  }
  if(!eligible.length)return null;
  // Prefer higher-value items (better value for the money)
  eligible.sort(function(a,b){return b.price-a.price;});
  return eligible[0];
}

/* ── Quest Completion Log ── */
// Stored in S.questLog: [{cycleId,questTitle,type,reward,franchiseCut,chars:[{name,cut,item}],completedAt}]

var P4={quest:null};

function collectQuest(qi,pq,q,set){
  var totalReward=pq.reward;
  var chars=pq.chars||[];
  var cn=chars.map(function(ci){return S.party[ci]?S.party[ci].name:'?';}).join(', ')||'unassigned';

  // 90/10 split
  var charPool=Math.floor(totalReward*0.10);
  var franchiseCut=totalReward-charPool;

  // Weight: base 1 + level + badge levels
  var weights=[],totalWeight=0;
  chars.forEach(function(ci){
    var c=S.party[ci];
    if(!c){weights.push(0);return;}
    var w=1+(c.level||0);
    Object.keys(XP_TRACKS).forEach(function(track){w+=getXpBadgeLevel(c,track);});
    weights.push(w);totalWeight+=w;
  });

  // Distribute 10%, auto-shop
  var charResults=[];
  var unspent=0;
  chars.forEach(function(ci,idx){
    var c=S.party[ci];
    if(!c||!totalWeight){unspent+=0;return;}
    var share=Math.floor(charPool*(weights[idx]/(totalWeight||1)));
    var bought=null;
    if(share>0){
      var item=pickItemForChar(c,share);
      if(item){
        if(!c.inv)c.inv=[];
        c.inv.push(item.name);
        unspent+=share-item.price;
        bought=item.name+' ('+item.price+' gp)';
        logAdd(c.name+' spent '+item.price+' gp on '+item.name,'buy');
      } else {
        unspent+=share;
      }
    }
    charResults.push({name:c.name,cut:share,item:bought});

    // Award XP
    if(!c.xp)c.xp={};
    var track=q.type;
    if(XP_TRACKS[track]){
      var prevXp=c.xp[track]||0;
      c.xp[track]=prevXp+1;
      var prevBadge=null,newBadge=null;
      XP_TRACKS[track].thresholds.forEach(function(t,i){
        if(prevXp>=t)prevBadge=XP_TRACKS[track].badges[i];
        if(c.xp[track]>=t)newBadge=XP_TRACKS[track].badges[i];
      });
      if(newBadge&&newBadge!==prevBadge){
        logAdd(c.name+' earned: '+XP_TRACKS[track].icon+' '+newBadge+'!','hire');
      }
    }
  });

  franchiseCut+=unspent;
  goldAdd(franchiseCut,'Quest: "'+q.title+'" ('+cn+') — franchise cut','adv');
  logAdd('Quest completed: "'+q.title+'" — '+totalReward+' gp ('+franchiseCut+' gp to franchise, '+charPool+' gp to adventurers)','adv');

  // Quest log entry
  if(!S.questLog)S.questLog=[];
  S.questLog.unshift({
    cycleId:S.questState.cycleId,
    questTitle:q.title,
    type:q.type,
    reward:totalReward,
    franchiseCut:franchiseCut,
    chars:charResults,
    completedAt:new Date().toLocaleString()
  });

  // Mark done, remove from pending
  if(!S.questState.done)S.questState.done=[];
  if(S.questState.done.indexOf(qi)===-1)S.questState.done.push(qi);
  var pqIdx=-1;
  (S.questState.pending||[]).forEach(function(p,pi){if(p.idx===qi)pqIdx=pi;});
  if(pqIdx!==-1)S.questState.pending.splice(pqIdx,1);

  if(q.capstone)awardCapstonReward(set);
}

function autoCollectExpired(){
  var qs=S.questState;
  if(!qs||!qs.pending||!qs.pending.length)return;
  var set=activeQuestSet();
  var now=Date.now();
  var collected=[];
  qs.pending.slice().forEach(function(pq){
    if(pq.doneAt<=now&&qs.done.indexOf(pq.idx)===-1){
      var q=set.quests[pq.idx];
      if(!q)return;
      collectQuest(pq.idx,pq,q,set);
      collected.push(q.title);
    }
  });
  if(collected.length){
    save();setGold();renderAdv();
  }
}

document.getElementById('avcontent').addEventListener('click',function(e){
  var qs=S.questState;
  var set=activeQuestSet();

  // Collect main quest
  var bc=e.target.closest('[data-a="qcollect"]');
  if(bc){
    var qi=parseInt(bc.getAttribute('data-qi'));
    var pqIdx2=-1;
    (qs.pending||[]).forEach(function(pq,pi){if(pq.idx===qi)pqIdx2=pi;});
    if(pqIdx2===-1)return;
    var pq2=qs.pending[pqIdx2];
    if(pq2.doneAt>Date.now()){alert('Not ready yet! '+fmtCountdown(pq2.doneAt-Date.now()));return;}
    var q=set.quests[qi];
    if(!q)return;
    collectQuest(qi,pq2,q,set);
    save();setGold();renderAdv();
    return;
  }

  // Collect grind mission
  var gc=e.target.closest('[data-a="gcollect"]');
  if(gc){
    var gid=gc.getAttribute('data-gid');
    var gpIdx=-1;
    (qs.grindPending||[]).forEach(function(gp,pi){if(gp.id===gid)gpIdx=pi;});
    if(gpIdx===-1)return;
    var gp=qs.grindPending[gpIdx];
    if(gp.doneAt>Date.now()){alert('Not ready yet!');return;}
    goldAdd(gp.reward,'Grind mission: "'+gp.title+'"','adv');
    qs.grindPending.splice(gpIdx,1);
    save();renderAdv();
    return;
  }

  // Send on grind mission
  var ga=e.target.closest('[data-a="gassign"]');
  if(ga){
    var gid2=ga.getAttribute('data-gid');
    var g=null;
    GRIND.forEach(function(x){if(x.id===gid2)g=x;});
    if(!g)return;
    var reward=g.baseGp+rndInt(-3,8);
    if(!qs.grindPending)qs.grindPending=[];
