// PHB class skill tables: {mandatory, choose} — choose 1 from list, then 2 random from remainder
var CLASS_SKILLS={
  'Barbarian': {mandatory:'Intimidation',   choose:['Animal Handling','Athletics','Nature','Perception','Survival']},
  'Bard':      {mandatory:'Performance',    choose:DND.skills}, // any skill for slot 2; gets 3 total PHB + 1 random
  'Cleric':    {mandatory:'Religion',       choose:['History','Insight','Medicine','Persuasion']},
  'Druid':     {mandatory:'Nature',         choose:['Arcana','Animal Handling','Insight','Medicine','Perception','Religion','Survival']},
  'Fighter':   {mandatory:'Athletics',      choose:['Acrobatics','Animal Handling','History','Insight','Intimidation','Perception','Survival']},
  'Monk':      {mandatory:'Acrobatics',     choose:['Athletics','History','Insight','Religion','Stealth']},
  'Paladin':   {mandatory:'Persuasion',     choose:['Athletics','Insight','Intimidation','Medicine','Religion']},
  'Ranger':    {mandatory:'Survival',       choose:['Animal Handling','Athletics','Insight','Investigation','Nature','Perception','Stealth']},
  'Rogue':     {mandatory:'Stealth',        choose:['Acrobatics','Athletics','Deception','Insight','Intimidation','Investigation','Perception','Performance','Persuasion','Sleight of Hand']},
  'Sorcerer':  {mandatory:'Arcana',         choose:['Deception','Insight','Intimidation','Persuasion','Religion']},
  'Warlock':   {mandatory:'Deception',      choose:['Arcana','History','Intimidation','Investigation','Nature','Religion']},
  'Wizard':    {mandatory:'History',        choose:['Arcana','Insight','Investigation','Medicine','Religion']},
  'Artificer': {mandatory:'Investigation',  choose:['Arcana','History','Medicine','Nature','Perception','Sleight of Hand']}
};

function pickClassSkills(cls){
  var cs=CLASS_SKILLS[cls];
  if(!cs){
    // Fallback for any unknown class — 4 random skills
    return pick(DND.skills,4);
  }
  var skills=[cs.mandatory];
  // Pick 1 from the class list (excluding mandatory)
  var pool=cs.choose.filter(function(s){return s!==cs.mandatory;});
  var chosen=rnd(pool);
  skills.push(chosen);
  // Bard gets a 3rd PHB pick — pick 1 more from any skill not yet chosen
  if(cls==='Bard'){
    var bardPool=DND.skills.filter(function(s){return skills.indexOf(s)===-1;});
    skills.push(rnd(bardPool));
  }
  // Fill remaining slots (up to 4 total) with random skills not already chosen
  var remaining=DND.skills.filter(function(s){return skills.indexOf(s)===-1;});
  var needed=4-skills.length;
  pick(remaining,needed).forEach(function(s){skills.push(s);});
  return skills;
}

