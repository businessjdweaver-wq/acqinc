        skills:c.skills||[],tools:c.tools||[],lang:c.lang||[],weapons:c.weapons||[],inv:c.inv||[]};
    }));
  }));

  // active tasks
  ops.push(sbDel('active_tasks','id=neq.00000000-0000-0000-0000-000000000000').then(function(){
    if(!(S.active||[]).length)return true;
    return sbUpsert('active_tasks',S.active.map(function(t,i){
      return {sort_order:i,name:t.name,gp:t.gp||5,count:t.count||0,
        subtasks:t.subtasks||[],collapsed:!!t.collapsed,fav:!!t.fav,
        freq:t.freq||null,cat:t.cat||null,burner_until:t.burnerUntil||null};
    }));
  }));

  // archived tasks
  ops.push(sbDel('archived_tasks','id=neq.00000000-0000-0000-0000-000000000000').then(function(){
    if(!(S.archived||[]).length)return true;
    return sbUpsert('archived_tasks',S.archived.map(function(t,i){
      return {sort_order:i,name:t.name,gp:t.gp||5,freq:t.freq||'custom',
        cat:t.cat||null,fav:!!t.fav,subtasks:t.subtasks||[],
        arch_group:t.archGroup||t.freq||'custom'};
    }));
  }));

  // party assets
  ops.push(sbDel('party_assets','id=neq.00000000-0000-0000-0000-000000000000').then(function(){
    if(!(S.partyAssets||[]).length)return true;
    return sbUpsert('party_assets',(S.partyAssets||[]).map(function(a,i){
      return {sort_order:i,name:a.name,ic:a.ic||'',type:a.type||''};
    }));
  }));

  // squads
  ops.push(sbDel('squads','id=neq.00000000-0000-0000-0000-000000000000').then(function(){
    if(!(S.squads||[]).length)return true;
    return sbUpsert('squads',(S.squads||[]).map(function(sq){
      return {name:sq.name,member_ids:[],collapsed:!!sq.collapsed};
    }));
  }));

  // quest state — delete then re-insert to guarantee fresh data
  if(S.questState){
    var qsPayload={
      cycle_id:S.questState.cycleId,
      revealed:S.questState.revealed||[],
      done:S.questState.done||[],
      pending:S.questState.pending||[],
      assigned:Object.assign({},S.questState.assigned||{},{
        _setId:S.questState.setId||'root-and-branch',
        _cycleNum:S.questState.cycleNum||0,
        _grindPending:S.questState.grindPending||[],
        _popupShown:S.questState.popupShown||false
      }),
      party_lv_at_start:S.questState.partyLvAtStart||0
    };
    console.log('[QuestPush] pending count:',S.questState.pending.length,'payload:',JSON.stringify(qsPayload.pending));
    ops.push(
      sbDel('quest_cycles','cycle_id=eq.'+encodeURIComponent(S.questState.cycleId)).then(function(){
        return sbUpsert('quest_cycles',qsPayload);
      }).then(function(){
