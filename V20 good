  },
  wonder: {
    label:'Arcana',icon:'✨',
    badges:['Apprentice Arcanist','Seeker','Adept','Arcanist','Sage'],
    thresholds:[1,3,6,10,15]
  }
};

function getXpBadge(c,track){
  var xp=(c.xp&&c.xp[track])||0;
  var t=XP_TRACKS[track];
  var badge=null;
  for(var i=t.thresholds.length-1;i>=0;i--){
    if(xp>=t.thresholds[i]){badge=t.badges[i];break;}
  }
  return badge;
}

function getXpBadgeLevel(c,track){
  var xp=(c.xp&&c.xp[track])||0;
  var t=XP_TRACKS[track];
  var level=0;
  for(var i=0;i<t.thresholds.length;i++){if(xp>=t.thresholds[i])level=i+1;}
  return level;
}

function allBadges(c){
  var badges=[];
  Object.keys(XP_TRACKS).forEach(function(track){
    var b=getXpBadge(c,track);
    if(b)badges.push(XP_TRACKS[track].icon+' '+b);
  });
  return badges;
}

