<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Acquisitions Incorporated</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=IM+Fell+English:ital@0;1&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root{
  --parchment:#f4e8c1;--parchment-deep:#d4b97a;
  --ink:#2c1a0e;--ink-light:#4a3020;
  --gold:#c9922a;--gold-bright:#f0b429;--gold-dark:#8a6010;
  --crimson:#8b1a1a;--forest:#2d5016;--forest-light:#4a7c25;
  --purple:#6655aa;--teal:#1a6b8a;
  --shadow:rgba(44,26,14,.35);
  --fs:18px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Crimson Text',Georgia,serif;background:var(--ink);min-height:100vh;color:var(--ink);line-height:1.5;}
body::before{content:'';position:fixed;inset:0;
  background:repeating-linear-gradient(0deg,transparent,transparent 28px,rgba(139,96,16,.07) 28px,rgba(139,96,16,.07) 29px),
  radial-gradient(ellipse at 20% 20%,rgba(201,146,42,.12) 0%,transparent 60%),
  radial-gradient(ellipse at 80% 80%,rgba(139,26,26,.08) 0%,transparent 60%),#f4e8c1;
  z-index:0;pointer-events:none;}
#app{position:relative;z-index:1;max-width:480px;margin:0 auto;padding:0 0 88px;min-height:100vh;font-size:var(--fs);}

/* HEADER */
#hdr{background:linear-gradient(135deg,var(--ink) 0%,#3d1f0a 100%);color:var(--gold-bright);
  padding:10px 16px 8px;text-align:center;border-bottom:3px solid var(--gold);
  position:sticky;top:0;z-index:100;box-shadow:0 2px 12px var(--shadow);}
#hdr h1{font-family:'Cinzel',serif;font-size:1em;letter-spacing:.1em;text-transform:uppercase;color:var(--gold-bright);}
#hdr .sub{font-family:'IM Fell English',serif;font-style:italic;font-size:.8em;color:var(--parchment-deep);margin-top:1px;}
#gold-disp{display:inline-flex;align-items:center;gap:6px;background:rgba(201,146,42,.15);
  border:1px solid var(--gold-dark);border-radius:20px;padding:3px 14px;margin-top:5px;
  font-family:'Cinzel',serif;font-size:1.05em;font-weight:700;color:var(--gold-bright);}

/* NAV */
#nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);
  width:100%;max-width:480px;background:linear-gradient(0deg,#1a0d04,#2c1a0e);
  border-top:2px solid var(--gold);display:flex;z-index:200;box-shadow:0 -3px 16px rgba(0,0,0,.5);}
.nb{flex:1;background:none;border:none;border-right:1px solid rgba(201,146,42,.15);
  color:var(--parchment-deep);padding:7px 2px 6px;cursor:pointer;
  font-size:.52em;font-family:'Cinzel',serif;text-transform:uppercase;
  display:flex;flex-direction:column;align-items:center;gap:2px;
  transition:color .15s,background .15s;-webkit-tap-highlight-color:transparent;}
.nb:last-child{border-right:none;}
.nb .ni{font-size:1.2em;}
.nb.on{color:var(--gold-bright);background:rgba(201,146,42,.12);}

/* SCREENS */
.scr{display:none;padding:14px 12px;}
.scr.on{display:block;}
.stitle{font-family:'Cinzel',serif;font-size:.98em;color:var(--crimson);
  border-bottom:2px solid var(--parchment-deep);padding-bottom:5px;margin-bottom:12px;}

/* CARD */
.card{background:rgba(255,255,255,.52);border:1px solid var(--parchment-deep);
  border-radius:6px;padding:11px 13px;margin-bottom:10px;
  box-shadow:0 1px 4px rgba(44,26,14,.1);position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--gold);}
.card.dim{opacity:.6;}
.card.dim::before{background:#999;}
.card.grp-card::before{background:var(--purple);}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:4px;padding:.38em .7em;
  border:1.5px solid;border-radius:4px;cursor:pointer;
  font-family:'Cinzel',serif;font-size:.75em;font-weight:600;
  letter-spacing:.04em;text-transform:uppercase;
  transition:all .12s;background:none;min-height:2.2em;
  -webkit-tap-highlight-color:transparent;}
.bg{border-color:var(--gold);color:var(--gold-dark);background:rgba(201,146,42,.12);}
.bg:hover,.bg:active{background:rgba(201,146,42,.28);}
.bgn{border-color:var(--forest);color:var(--forest);background:rgba(45,80,22,.08);}
.bgn:hover,.bgn:active{background:rgba(45,80,22,.22);}
.bred{border-color:var(--crimson);color:var(--crimson);background:rgba(139,26,26,.08);}
.bred:hover,.bred:active{background:rgba(139,26,26,.2);}
.bink{border-color:var(--ink-light);color:var(--ink-light);background:rgba(44,26,14,.07);}
.bink:hover,.bink:active{background:rgba(44,26,14,.16);}
.bpur{border-color:var(--purple);color:var(--purple);background:rgba(102,85,170,.08);}
.sm{padding:.25em .5em;font-size:.68em;min-height:1.9em;}
.lg{padding:.55em 1.1em;font-size:.85em;}
.full{width:100%;}
.btn:disabled{opacity:.35;cursor:not-allowed;}

/* INPUTS */
input[type=text],input[type=number],input[type=time],select,textarea{
  padding:.42em .6em;border:1.5px solid var(--parchment-deep);border-radius:4px;
  background:rgba(255,255,255,.7);font-family:'Crimson Text',serif;
  font-size:1em;color:var(--ink);outline:none;
  transition:border-color .15s;width:100%;}
input:focus,select:focus,textarea:focus{border-color:var(--gold);}
label.lbl{font-family:'Cinzel',serif;font-size:.72em;letter-spacing:.04em;
  color:var(--ink-light);display:block;margin-bottom:3px;text-transform:uppercase;}
.frow{margin-bottom:10px;}
.addrow{display:flex;gap:6px;margin-top:10px;}
.hint{font-size:.78em;color:var(--ink-light);font-style:italic;margin-top:4px;}
.snote{font-size:.82em;color:var(--ink-light);font-style:italic;margin-bottom:10px;}
.empty{text-align:center;color:var(--ink-light);font-style:italic;font-size:.88em;padding:22px 0;}

/* PILLS */
.pills{display:flex;flex-wrap:wrap;gap:5px;margin:5px 0;}
.pill{background:rgba(201,146,42,.12);border:1px solid var(--parchment-deep);
  border-radius:10px;padding:.15em .5em;font-size:.75em;color:var(--ink-light);}

/* TASK SCREEN */
.sbar{display:flex;gap:6px;align-items:center;margin-bottom:10px;flex-wrap:wrap;}
.sbar label{margin:0;font-family:'Cinzel',serif;font-size:.72em;text-transform:uppercase;color:var(--ink-light);}
.sbar select{width:auto;padding:.3em .5em;font-size:.85em;}
.trow{display:flex;align-items:flex-start;gap:7px;}
.tinfo{flex:1;}
.tname{font-size:1em;color:var(--ink);font-weight:600;line-height:1.35;}
.tsub{font-size:.75em;color:var(--gold-dark);font-family:'Cinzel',serif;margin-top:2px;}
.tacts{display:flex;flex-direction:column;gap:4px;flex-shrink:0;}
.tarr{display:flex;flex-direction:column;gap:2px;margin-right:2px;flex-shrink:0;}
.tarr button{background:none;border:1px solid var(--parchment-deep);border-radius:3px;
  cursor:pointer;font-size:.72em;padding:.15em .4em;color:var(--ink-light);line-height:1.3;}
.tarr button:disabled{opacity:.3;cursor:not-allowed;}
.burner-lbl{font-size:.72em;color:#888;font-style:italic;margin-top:2px;}

/* SUBTASKS */
.stlist{margin:7px 0 4px 16px;border-left:2px solid var(--parchment-deep);padding-left:8px;}
.strow{display:flex;align-items:center;gap:6px;padding:3px 0;border-bottom:1px dotted rgba(139,96,16,.15);}
.strow:last-child{border-bottom:none;}
.stname{flex:1;font-size:.85em;color:var(--ink-light);}
.stdone{text-decoration:line-through;opacity:.5;}
.stgp{font-family:'Cinzel',serif;font-size:.65em;color:var(--gold-dark);}
.staddrow{display:flex;gap:4px;margin-top:5px;}
.staddrow input{flex:1;font-size:.88em;padding:.3em .5em;}
.colbtn{background:none;border:none;cursor:pointer;font-size:.78em;color:var(--ink-light);padding:0 3px;}

/* TASK GROUPS */
.grp-hdr{display:flex;align-items:center;gap:6px;cursor:pointer;padding:4px 0 5px;user-select:none;}
.grp-hdr-name{font-family:'Cinzel',serif;font-size:.8em;text-transform:uppercase;
  letter-spacing:.06em;color:var(--purple);flex:1;}
.grp-body{margin-top:4px;}

/* ARCHIVE */
.ach-grp-hdr{display:flex;align-items:center;gap:6px;cursor:pointer;
  border-bottom:1px dashed var(--parchment-deep);padding:5px 0 4px;margin:8px 0 5px;}
.ach-grp-name{font-family:'Cinzel',serif;font-size:.75em;text-transform:uppercase;
  letter-spacing:.06em;color:var(--gold-dark);flex:1;}
.ach-row{display:flex;align-items:center;gap:6px;padding:5px 0;
  border-bottom:1px solid rgba(139,96,16,.1);}
.ach-row:last-child{border-bottom:none;}
.ach-info{flex:1;}
.ach-name{font-size:.93em;color:var(--ink);}
.ach-sub{font-size:.75em;color:var(--ink-light);font-style:italic;}
.fav-btn{background:none;border:none;cursor:pointer;font-size:1.1em;
  padding:2px 4px;opacity:.45;transition:opacity .15s;line-height:1;}
.fav-btn.on{opacity:1;}
.ach-updn button{background:none;border:1px solid var(--parchment-deep);
  border-radius:2px;cursor:pointer;font-size:.65em;padding:1px 4px;
  color:var(--ink-light);display:block;line-height:1.4;}
.ach-updn button:disabled{opacity:.3;cursor:not-allowed;}

/* CHAR CARDS */
.char-card{background:rgba(255,255,255,.55);border:2px solid var(--gold);
  border-radius:8px;padding:11px;margin-bottom:12px;}
.cname{font-family:'Cinzel',serif;font-size:1em;color:var(--crimson);font-weight:700;}
.cmeta{font-size:.88em;color:var(--ink-light);font-style:italic;margin:2px 0 5px;}
.clvl{font-family:'Cinzel',serif;font-size:.75em;color:var(--gold-dark);margin-bottom:6px;}
.inv-ttl{font-family:'Cinzel',serif;font-size:.7em;text-transform:uppercase;
  letter-spacing:.05em;color:var(--gold-dark);margin:7px 0 3px;}
.inv-item{font-size:.85em;color:var(--ink-light);padding:2px 0;
  border-bottom:1px dotted rgba(139,96,16,.18);}

/* SQUADS */
.sq-card{background:rgba(139,26,26,.06);border:1.5px solid rgba(139,26,26,.25);
  border-radius:7px;padding:9px 11px;margin-bottom:9px;}
.sq-hdr{display:flex;align-items:center;cursor:pointer;user-select:none;}
.sq-name{font-family:'Cinzel',serif;font-size:.9em;color:var(--crimson);font-weight:700;flex:1;}
.sq-pill{background:rgba(139,26,26,.1);border:1px solid rgba(139,26,26,.3);
  border-radius:8px;padding:1px 8px;font-size:.72em;color:var(--crimson);}

/* Subtask checkboxes — bigger on tablet/desktop */
@media (min-width:600px){
  .strow input[type=checkbox]{width:1.3em;height:1.3em;cursor:pointer;}
  .cblist input[type=checkbox],.qcb{width:1.3em;height:1.3em;cursor:pointer;}
}
@media (min-width:900px){
  .strow input[type=checkbox]{width:1.6em;height:1.6em;}
  .cblist input[type=checkbox],.qcb{width:1.6em;height:1.6em;}
}

/* PREMIUM RECRUIT */
.prem-opt-tag{font-size:.7em;color:var(--gold-dark);font-family:'Crimson Text',serif;text-transform:none;letter-spacing:0;font-style:italic;}
.prem-toggle{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border:1.5px solid var(--parchment-deep);border-radius:12px;font-size:.75em;cursor:pointer;user-select:none;color:var(--ink-light);background:rgba(255,255,255,.5);transition:all .12s;}
.prem-toggle.on{border-color:var(--gold);color:var(--gold-dark);background:rgba(201,146,42,.15);}

/* RECRUIT */
.gen-box{background:rgba(255,255,255,.62);border:2px solid var(--gold);
  border-radius:8px;padding:13px;margin-bottom:11px;min-height:80px;}
.hire-bar{display:flex;align-items:center;justify-content:space-between;
  padding-top:9px;border-top:1px dashed var(--parchment-deep);}
.gold-badge{display:inline-flex;align-items:center;gap:4px;
  font-family:'Cinzel',serif;font-size:.8em;color:var(--gold-dark);
  background:rgba(201,146,42,.12);border:1px solid var(--gold);
  border-radius:10px;padding:2px 10px;}

/* QUEST */
.prereq-box{background:rgba(201,146,42,.06);border:1px solid var(--parchment-deep);
  border-radius:6px;padding:8px 10px;margin:7px 0;}
.prereq-ttl{font-family:'Cinzel',serif;font-size:.7em;text-transform:uppercase;
  letter-spacing:.05em;color:var(--gold-dark);margin-bottom:5px;}
.prerow{display:flex;align-items:center;gap:5px;font-size:.82em;color:var(--ink-light);padding:2px 0;}
.pmet{color:var(--forest);}
.punmet{color:var(--crimson);}
.enc-card{background:rgba(255,255,255,.48);border:1px solid var(--parchment-deep);
  border-radius:6px;padding:10px 12px;margin-bottom:8px;}
.etype{font-family:'Cinzel',serif;font-size:.6em;text-transform:uppercase;
  letter-spacing:.08em;margin-bottom:3px;}
.et-social{color:var(--teal);}.et-combat{color:var(--crimson);}
.et-explore{color:var(--forest);}.et-wonder{color:var(--purple);}
.etitle{font-weight:700;font-size:.95em;color:var(--ink);margin-bottom:2px;}
.edesc{font-size:.85em;color:var(--ink-light);font-style:italic;margin-bottom:5px;}
.erew{font-family:'Cinzel',serif;font-size:.72em;color:var(--gold-dark);}
.enc-done{opacity:.45;}
.enc-done .etitle::after{content:' ✓';color:var(--forest);}
.adv-hdr{background:linear-gradient(135deg,var(--ink),#3d1f0a);color:var(--gold-bright);
  border-radius:8px;padding:11px 13px;margin-bottom:11px;border:1px solid var(--gold);}
.adv-ttl{font-family:'Cinzel',serif;font-size:.98em;font-weight:700;margin-bottom:2px;}
.adv-sub{font-size:.8em;color:var(--parchment-deep);font-style:italic;margin-bottom:3px;}
.adv-prog{margin-top:7px;background:rgba(255,255,255,.1);border-radius:4px;height:8px;overflow:hidden;}
.adv-bar{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold-bright));transition:width .4s;}
.best-fit{font-size:.78em;color:var(--forest);font-family:'Cinzel',serif;
  padding:4px 7px;background:rgba(45,80,22,.08);border-radius:4px;margin-bottom:6px;}

/* STORE */
.store-tabs{display:flex;border:1px solid var(--parchment-deep);border-radius:6px;
  overflow:hidden;margin-bottom:11px;}
.stab{flex:1;background:none;border:none;border-right:1px solid var(--parchment-deep);
  padding:.35em .25em;font-family:'Cinzel',serif;font-size:.62em;text-transform:uppercase;
  cursor:pointer;color:var(--ink-light);transition:background .15s;}
.stab:last-child{border-right:none;}
.stab.on{background:rgba(201,146,42,.15);color:var(--gold-dark);}
.store-card{display:flex;gap:10px;background:rgba(255,255,255,.48);
  border:1px solid var(--parchment-deep);border-radius:6px;
  padding:9px 11px;margin-bottom:8px;align-items:flex-start;}
.stic{font-size:1.4em;padding-top:1px;}
.sinfo{flex:1;}
.sname{font-weight:700;font-size:.93em;color:var(--ink);}
.sdesc{font-size:.8em;color:var(--ink-light);font-style:italic;margin:2px 0 3px;}
.rarity{font-family:'Cinzel',serif;font-size:.57em;text-transform:uppercase;
  padding:1px 5px;border-radius:3px;border:1px solid;display:inline-block;}
.r-common{border-color:#aaa;color:#666;}.r-uncommon{border-color:var(--forest-light);color:var(--forest);}
.r-rare{border-color:var(--teal);color:var(--teal);}.r-veryrare{border-color:var(--purple);color:var(--purple);}
.r-vehicle,.r-building{border-color:var(--gold-dark);color:var(--gold-dark);}
.spcol{display:flex;flex-direction:column;align-items:flex-end;gap:5px;min-width:68px;}
.sprice{font-family:'Cinzel',serif;font-size:.78em;color:var(--gold-dark);}

/* LOG */
.log-row{display:flex;gap:7px;padding:7px 0;border-bottom:1px solid rgba(139,96,16,.1);font-size:.88em;}
.ltime{font-family:'Cinzel',serif;font-size:.65em;color:var(--gold-dark);
  white-space:nowrap;min-width:50px;padding-top:2px;}
.lmsg{flex:1;color:var(--ink);line-height:1.4;}
.ltag{font-size:.62em;padding:1px 5px;border-radius:3px;align-self:flex-start;margin-top:2px;white-space:nowrap;}
.lt-gold{background:rgba(201,146,42,.15);color:var(--gold-dark);}
.lt-task{background:rgba(45,80,22,.12);color:var(--forest);}
.lt-hire{background:rgba(139,26,26,.1);color:var(--crimson);}
.lt-buy{background:rgba(102,85,170,.1);color:var(--purple);}
.lt-adv{background:rgba(26,107,138,.1);color:var(--teal);}

/* SETTINGS */
.set-sec{margin-bottom:18px;}
.set-sec-ttl{font-family:'Cinzel',serif;font-size:.78em;text-transform:uppercase;
  letter-spacing:.07em;color:var(--gold-dark);border-bottom:1px dashed var(--parchment-deep);
  padding-bottom:3px;margin-bottom:9px;}
.set-row{display:flex;align-items:center;gap:10px;margin-bottom:7px;}
.set-row label{margin:0;flex:1;}
.set-row select,.set-row input{flex:1;max-width:180px;}

/* MODAL */
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.65);
  z-index:500;align-items:center;justify-content:center;padding:14px;}
.ov.on{display:flex;}
.modal{background:var(--parchment);border:2px solid var(--gold);border-radius:10px;
  padding:17px;width:100%;max-width:380px;
  box-shadow:0 8px 40px rgba(0,0,0,.55);max-height:86vh;overflow-y:auto;}
.modal h3{font-family:'Cinzel',serif;color:var(--crimson);margin-bottom:9px;font-size:.95em;}
.modal p{font-size:.9em;color:var(--ink-light);margin-bottom:10px;line-height:1.5;}
.mbtns{display:flex;gap:7px;justify-content:flex-end;margin-top:13px;}
.cblist{max-height:160px;overflow-y:auto;border:1px solid var(--parchment-deep);
  border-radius:4px;padding:6px 8px;}
.cblist label{display:flex;align-items:center;gap:6px;font-size:.86em;
  text-transform:none;letter-spacing:0;color:var(--ink);margin-bottom:4px;cursor:pointer;}
.cblist input[type=checkbox]{width:auto;}
</style>
</head>
<body>
<div id="app">

<!-- HEADER -->
<div id="hdr">
  <h1 id="hdr-title">⚔ Acquisitions Incorporated ⚔</h1>
  <div class="sub" id="hdr-sub">Field Operations Ledger — Personal Edition</div>
  <div id="gold-disp">🪙 <span id="gamt">0</span> gp</div>
</div>

<!-- TASKS -->
<div class="scr on" id="s-tasks">
  <div class="stitle">✦ Active Contracts</div>
  <div class="addrow" style="margin-bottom:6px">
    <input type="text" id="new-tname" placeholder="New contract…" style="flex:1">
    <input type="number" id="new-tgp" value="5" min="1" style="width:56px">
    <button class="btn bg" id="btn-addtask">+ Add</button>
  </div>
  <div class="hint" style="margin-bottom:8px">↑ Gold per progress tick</div>
  <div class="sbar">
    <label>Sort:</label>
    <select id="tsort">
      <option value="manual">Manual</option>
      <option value="gold-hi">Gold ↓</option>
      <option value="gold-lo">Gold ↑</option>
      <option value="az">A→Z</option>
      <option value="za">Z→A</option>
      <option value="ticks">Ticks ↓</option>
    </select>
    <button class="btn bink sm" id="btn-newgrp">📂 Group</button>
    <button class="btn bink sm" id="btn-nav-archive">🗃 Archive</button>
  </div>
  <div id="tlist"></div>
</div>

<!-- ARCHIVE -->
<div class="scr" id="s-archive">
  <div class="stitle">✦ Contract Archive</div>
  <p class="snote">⭐ = favourite (auto-activates at morning reset). ↑↓ reorder within group.</p>
  <div class="addrow" style="margin-top:0;margin-bottom:10px;">
    <input type="text" id="arch-newgrp-name" placeholder="New archive group name…" style="flex:1">
    <button class="btn bg sm" id="btn-arch-newgrp">+ Group</button>
  </div>
  <div id="alist"></div>
</div>

<!-- PARTY -->
<div class="scr" id="s-party">
  <div class="stitle" style="display:flex;justify-content:space-between;align-items:center">
    ✦ The Adventuring Party
    <div style="display:flex;gap:6px">
      <button class="btn bink sm" id="btn-party-stats">📊 Stats</button>
      <button class="btn bg sm" id="btn-nav-recruit">🎲 Recruit</button>
    </div>
  </div>
  <div id="party-stats-panel" style="display:none"></div>
  <div id="plist"></div>
</div>

<!-- RECRUIT -->
<div class="scr" id="s-recruit">
  <div class="stitle">✦ Recruitment Office</div>

  <!-- Standard hire -->
  <div class="set-sec-ttl" style="margin-bottom:8px">Standard Recruitment</div>
  <p class="snote">Randomize a candidate, then hire them for gold.</p>
  <button class="btn bg lg full" id="btn-randall" style="margin-bottom:11px">🎲 Randomize All</button>
  <div class="gen-box" id="rbox"><div class="empty">Roll the dice to reveal a candidate…</div></div>
  <div class="hire-bar" id="hirebar" style="display:none">
