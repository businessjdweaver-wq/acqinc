function questCalcReward(q,charIdxs,pay){
  var tier=QTIERS[q.tier];
  var pr=q.pre;
  var b=q.baseGp;
  b+=(pr.skills||[]).length*10;
  b+=(pr.tools||[]).length*15;
  b+=(pr.lang||[]).length*10;
  if(pr.rel)b+=20;
  b+=(pr.items||[]).length*15;
  if(pr.gold)b+=Math.floor(pr.gold*1.5);
  b+=(pr.pay||0)*8;
  b+=Math.max(0,(pay||0)-(pr.pay||0))*4;
  b+=Math.max(0,(charIdxs||[]).length-1)*15;
  var topLevel=0;
  (charIdxs||[]).forEach(function(ci){
    var c=S.party[ci];if(c&&!c.hireling&&c.level>topLevel)topLevel=c.level;
  });
  b+=Math.max(0,topLevel-(tier.minLv||1))*tier.lvBonus;
  var assetNames=(S.partyAssets||[]).map(function(a){return a.name;});
  if(q.vehicleReq&&assetNames.indexOf(q.vehicleReq.name)!==-1)b+=Math.round(q.baseGp*0.2);
  if(q.buildingReq&&assetNames.indexOf(q.buildingReq.name)!==-1)b+=Math.round(q.baseGp*0.15);
  return b;
}

function questPrereqCheck(q,charIdxs,pay){
  var pr=q.pre,missing=[];
  var sk=[],to=[],la=[],re=[],inv=[];
  // Build a set of all standard (non-exotic) skills/tools/languages for filtering
  var stdSkills=DND.skills;
  var stdTools=DND.tools;
  var stdLang=DND.lang;
  (charIdxs||[]).forEach(function(ci){
    var c=S.party[ci];if(!c)return;
    // Skills: contacts only contribute standard skills
    (c.skills||[]).forEach(function(s){if(stdSkills.indexOf(s)!==-1)sk.push(s);});
    // Tools: contacts only contribute standard tools
    (c.tools||[]).forEach(function(t){if(stdTools.indexOf(t)!==-1)to.push(t);});
    // Languages: contacts only contribute standard languages
    (c.lang||[]).forEach(function(l){if(stdLang.indexOf(l)!==-1)la.push(l);});
    if(c.rel&&stdLang.indexOf(c.rel)===-1)re.push(c.rel); // faith is always usable
    if(c.rel)re.push(c.rel);
    (c.inv||[]).forEach(function(x){inv.push(x);});
  });
  (pr.skills||[]).forEach(function(s){if(sk.indexOf(s)===-1)missing.push('Skill: '+s);});
  (pr.tools||[]).forEach(function(t){if(to.indexOf(t)===-1)missing.push('Tool: '+t);});
  (pr.lang||[]).forEach(function(l){if(la.indexOf(l)===-1)missing.push('Language: '+l);});
  if(pr.rel&&re.indexOf(pr.rel)===-1)missing.push('Faith: '+pr.rel);
  (pr.items||[]).forEach(function(x){if(inv.indexOf(x)===-1)missing.push('Item: '+x);});
  if(pr.gold&&S.gold<pr.gold)missing.push('Gold invest: '+pr.gold+' gp');
  return missing;
}

