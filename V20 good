/* ── PUSH ── */
function sbPush(manual){
  syncStatus('Syncing\u2026','var(--gold-dark)');
  var ops=[];

  // franchise
  ops.push(sbUpsert('franchise',{id:'main',gold:S.gold,settings:S.settings||{},last_sync:new Date().toISOString()}));

  // party — delete all then re-insert (simplest for ordering)
  ops.push(sbDel('party','id=neq.00000000-0000-0000-0000-000000000000').then(function(){
    if(!(S.party||[]).length)return true;
    return sbUpsert('party',S.party.map(function(c,i){
      return {sort_order:i,name:c.name,species:c.species||'',cls:c.cls||'',bg:c.bg||'',
        rel:c.rel||'',age:c.age||0,height:c.height||'',weight:c.weight||'',
        level:c.level||0,hire_cost:c.hireCost||0,
