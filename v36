var XP_TRACKS={
  combat: {label:'Combat',   icon:'⚔', badges:['Apprentice Fighter','Veteran Fighter','Elite Fighter','Champion','Combat Legend'],    thresholds:[1,3,6,10,15]},
  social: {label:'Diplomacy',icon:'🗣', badges:['Junior Envoy','Negotiator','Diplomat','Ambassador','Grand Consul'],                  thresholds:[1,3,6,10,15]},
