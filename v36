// Select the right quest set for current party / month
function activeQuestSet(){
  if(!S.questState||!S.questState.setId)return QUESTSETS[0];
  var found=null;
  QUESTSETS.forEach(function(qs){if(qs.id===S.questState.setId)found=qs;});
  return found||QUESTSETS[0];
}

// Pick quest set by party tier and cycle count
function questSetForCycle(cycleNum,dndTier){
  // cycleNum 0 = first month, 1 = second month, etc.
  // Filter sets matching this dnd tier
  var matching=QUESTSETS.filter(function(s){return s.dndTier===dndTier;});
  if(!matching.length)matching=QUESTSETS;
  return matching[cycleNum%matching.length];
}

