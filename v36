  var bestEl=document.getElementById('ov-q-best');
  if(totalPre>0&&S.party.length){
    var scored=S.party.map(function(c,ci){return{ci:ci,sc:score(c),name:c.name};})
      .filter(function(x){return !busy[x.ci]&&!S.party[x.ci].hireling;})
      .sort(function(a,b2){return b2.sc-a.sc;});
    if(scored.length&&scored[0].sc>0){
      bestEl.style.display='block';
      bestEl.textContent='💡 Best fit: '+scored.slice(0,2).map(function(x){return x.name;}).join(', ');
    } else bestEl.style.display='none';
  } else bestEl.style.display='none';

  var prevAssigned=qs.assigned[qi2]||qs.assigned[String(qi2)]||[];
  var charList=S.party.map(function(c,ci){
    var isBusy=!!busy[ci];
    var sc=score(c);
    var pct=totalPre>0?Math.round(sc/totalPre*100):100;
    return{ci:ci,c:c,isBusy:isBusy,sc:sc,pct:pct};
  }).sort(function(a,b){
    if(a.isBusy!==b.isBusy)return a.isBusy?1:-1;
    return b.sc-a.sc;
  });

  document.getElementById('ov-q-chars').innerHTML=charList.length?
    charList.map(function(entry){
      var ci=entry.ci,c=entry.c,isBusy=entry.isBusy,pct=entry.pct;
      var chk=prevAssigned.indexOf(ci)!==-1?'checked':'';
      var pctCol=pct>=100?'var(--forest)':pct>=50?'var(--gold-dark)':'var(--crimson)';
      var pctBadge=totalPre>0?'<span style="font-size:.67em;color:'+pctCol+';margin-left:4px;font-weight:700">'+pct+'%</span>':'';
      var bl=isBusy?'<span style="font-size:.63em;color:var(--crimson);margin-left:4px">⚔ on quest</span>':'';
      var hl=c.hireling?'<span style="font-size:.63em;color:var(--ink-light);margin-left:4px">🪓 hireling</span>':'';
      var cl=c.contact?'<span style="font-size:.63em;color:var(--teal);margin-left:4px">🤝 contact</span>':'';
      var contribHtml='';
      if(totalPre>0&&pct<100&&!isBusy){
        var contrib=[];
        (pr.skills||[]).forEach(function(s){if((c.skills||[]).indexOf(s)!==-1)contrib.push('⭐ '+s);});
        (pr.tools||[]).forEach(function(t){if((c.tools||[]).indexOf(t)!==-1)contrib.push('🔧 '+t);});
        (pr.lang||[]).forEach(function(l){if((c.lang||[]).indexOf(l)!==-1)contrib.push('🗣 '+l);});
        if(contrib.length)contribHtml='<div style="font-size:.65em;color:var(--ink-light);margin-left:22px;margin-top:1px">Brings: '+contrib.join(', ')+'</div>';
