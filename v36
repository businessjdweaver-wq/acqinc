          age:c.age,height:c.height,weight:c.weight,level:c.level,hireCost:c.hire_cost,
          hireling:c.hireling,formerHireling:meta.formerHireling||c.former_hireling,
          premium:c.premium,contact:meta.contact||false,
          contactBg:meta.contactBg||'',exoticTrait:meta.exoticTrait||'',
          xp:meta.xp||{},
          skills:c.skills||[],tools:c.tools||[],lang:c.lang||[],
          weapons:c.weapons||[],inv:cleanInv};
      });
    }
    if(tasks&&tasks.length){
      S.active=tasks.map(function(t){
        return {_sbId:t.id,name:t.name,gp:t.gp,count:t.count,subtasks:t.subtasks||[],
          collapsed:t.collapsed,fav:t.fav,freq:t.freq,cat:t.cat,burnerUntil:t.burner_until||null};
      });
    }
    if(archived&&archived.length){
      S.archived=archived.map(function(t){
        return {_sbId:t.id,name:t.name,gp:t.gp,freq:t.freq,cat:t.cat,
          fav:t.fav,subtasks:t.subtasks||[],archGroup:t.arch_group};
      });
    }
    if(assets&&assets.length){
      S.partyAssets=assets.map(function(a){return {_sbId:a.id,name:a.name,ic:a.ic,type:a.type};});
    }
    if(squads&&squads.length){
      S.squads=squads.map(function(sq){return {_sbId:sq.id,name:sq.name,memberIdxs:(sq.member_ids||[]).map(Number),collapsed:false};});
    }
    if(questCycles&&questCycles[0]){
      console.log('[QuestPull] raw row:',JSON.stringify(questCycles[0]));
      var qc=questCycles[0];
      var asgn=qc.assigned||{};
      var cleanAsgn={};
      Object.keys(asgn).forEach(function(k){if(k[0]!=='_')cleanAsgn[k]=asgn[k];});
      S.questState={
        cycleId:qc.cycle_id,
        setId:asgn._setId||'root-and-branch',
        cycleNum:asgn._cycleNum||0,
        revealed:qc.revealed||[],
        done:qc.done||[],
        pending:(qc.pending||[]).map(function(pq){
          return {idx:parseInt(pq.idx),chars:(pq.chars||[]).map(function(c){return parseInt(c);}),
            reward:parseInt(pq.reward)||0,doneAt:parseInt(pq.doneAt)||0};
        }),
        assigned:(function(){
          var out={};
          Object.keys(cleanAsgn).forEach(function(k){
            var n=parseInt(k);
            out[isNaN(n)?k:n]=(cleanAsgn[k]||[]).map(function(c){return parseInt(c);});
          });
          return out;
        }()),
        grindPending:(asgn._grindPending||[]).map(function(gp){
          var r=parseInt(gp.reward);
          return {id:gp.id,title:gp.title,chars:(gp.chars||[]).map(function(c){return parseInt(c);}),reward:isNaN(r)||r<=0?20:r,doneAt:parseInt(gp.doneAt)||0};
        }),
        popupShown:true,
        partyLvAtStart:qc.party_lv_at_start||0
      };
      console.log('[QuestPull] restored pending:',JSON.stringify(S.questState.pending));
    }
    if(log&&log.length){
      S.log=log.map(function(e){return {_sbId:e.id,msg:e.msg,type:e.type,date:e.entry_date,time:e.entry_time};});
    }
    if(taskGroups&&taskGroups.length){
      S.taskGroups=taskGroups.map(function(g){
        return {_sbId:g.id,name:g.name,taskIds:[],collapsed:g.collapsed,deferUntil:g.defer_until||0};
      });
    }
    if(archGroups&&archGroups.length){
      archGroups.forEach(function(g){FLAB[g.key]=g.label;});
      S.archGroups=archGroups.map(function(g){return {key:g.key,label:g.label};});
    }

    try{localStorage.setItem('acqv7',JSON.stringify(S));}catch(e){}
    setGold();applySettings();renderTasks();renderSettings();renderAdv();
    var inv=0;(S.party||[]).forEach(function(c){inv+=(c.inv||[]).length;});
    if(manual){
      syncStatus('✅ Pulled '+new Date().toLocaleTimeString()+
        ' — '+S.gold+' gp · '+(S.active||[]).length+' tasks · '+
        (S.party||[]).length+' adventurers · '+inv+' items','var(--forest)');
      logAdd('Supabase: pull complete.','gold');
    } else {
      syncStatus('☁ Loaded from Supabase '+new Date().toLocaleTimeString(),'var(--ink-light)');
    }
  }).catch(function(err){
    syncStatus(manual?'❌ Pull failed: '+err.message:'⚠ Offline — using local data','var(--crimson)');
    console.error('Supabase pull:',err);
  });
}

/* ── Debounced auto-push ── */
var autoPushTimer=null;
function schedulePush(){
  console.log('[Push] schedulePush called');
  if(autoPushTimer)clearTimeout(autoPushTimer);
  autoPushTimer=setTimeout(function(){
    console.log('[Push] timer fired, calling sbPush');
    sbPush(false);
  },4000);
}

document.getElementById('btn-sync-push').addEventListener('click',function(){sbPush(true);});
document.getElementById('btn-sync-pull').addEventListener('click',function(){sbPull(true);});

function checkFavourites(){
  var today=todayStr();
  var h=(S.settings&&S.settings.morningHour)||6;
  var pastMorning=new Date().getHours()>=h;
  if(pastMorning&&S.lastRerollReset!==today){
    S.lastRerollReset=today;
    S.recruitRollDate='';
    S.hirelRollDate='';
    save();
  }
  if(S.lastFavCheck===today)return;
  if(!pastMorning)return;
  S.lastFavCheck=today;
  var n=0;
  S.archived.forEach(function(t){
    if(!t.fav)return;
    if(S.active.some(function(a){return a.name===t.name;}))return;
    S.active.push({name:t.name,gp:t.gp,count:0,freq:t.freq,cat:t.cat,
      subtasks:(t.subtasks||[]).map(function(s){return{name:s.name,done:false};}),
      collapsed:false,fav:true});
    n++;
  });
  if(n){logAdd('Morning: '+n+' favourite'+(n>1?'s':'')+' activated.','task');save();}
}

/* ═══════════════════════ NAVIGATION ═══════════════════════ */
var SCRMAP={
  tasks:'s-tasks',archive:'s-archive',party:'s-party',recruit:'s-recruit',
  adventure:'s-adventure',store:'s-store',log:'s-log',settings:'s-settings'
};
var RENDER={
  tasks:renderTasks,archive:renderArchive,party:renderParty,recruit:function(){},
  adventure:renderAdv,store:renderStore,log:renderLog,settings:renderSettings
};

function navTo(s){
  document.querySelectorAll('.scr').forEach(function(el){el.classList.remove('on');});
  document.querySelectorAll('.nb').forEach(function(el){el.classList.remove('on');});
  var target=document.getElementById(SCRMAP[s]);
  if(target)target.classList.add('on');
  var nb=document.querySelector('.nb[data-s="'+s+'"]');
  if(nb)nb.classList.add('on');
  if(RENDER[s])RENDER[s]();
}

document.getElementById('nav').addEventListener('click',function(e){
  var b=e.target.closest('.nb');if(!b)return;
  navTo(b.getAttribute('data-s'));
});

document.getElementById('btn-nav-archive').addEventListener('click',function(){navTo('archive');});
document.getElementById('btn-nav-recruit').addEventListener('click',function(){navTo('recruit');});
document.getElementById('btn-nav-log').addEventListener('click',function(){navTo('log');});

document.querySelectorAll('.ov').forEach(function(ov){
  ov.addEventListener('click',function(e){if(e.target===ov)ov.classList.remove('on');});
});

/* ═══════════════════════ INIT ═══════════════════════ */
load();

if(!S.party.length){
  S.party.push({
    name:'The Founder',species:'Human',cls:'Expert',bg:'Guild Artisan',
    rel:'Avandra (Change)',age:34,height:"5'10\"",weight:'175 lbs',
    lang:['Common','Elvish'],skills:['Persuasion','Insight','Investigation','History'],
    tools:["Cartographer's Tools",'Gaming Set'],weapons:['Simple Weapons'],
    level:1,inv:['Ledger of Accounts','Fancy Quill Pen','Company Seal']
  });
}
if(!S.archived.length){
  S.archived=PRESET.map(function(t){return{name:t.name,gp:t.gp,freq:t.freq,cat:t.cat,count:0,subtasks:[],fav:false};});
}
if(!S.log.length){
  S.gold=10;
  logAdd('Franchise established. Starting stipend: 10 gp.','gold');
}
if(!S.squads)S.squads=[];
if(!S.squadCollapsed)S.squadCollapsed={};
if(!S.taskGroups)S.taskGroups=[];
if(!S.partyAssets)S.partyAssets=[];
if(S.assetsCollapsed===undefined)S.assetsCollapsed=false;
if(!S.encAssigned)S.encAssigned={};
if(!S.doneEnc)S.doneEnc=[];
if(!S.pendingQuests)S.pendingQuests=[];
if(!S.questCycles)S.questCycles=[];
if(!S.questLog)S.questLog=[];
if(!S.questState)initQuestState(0);
if(!S.questState.grindPending)S.questState.grindPending=[];
// Sanitise old grindPending entries with missing/zero/NaN rewards
S.questState.grindPending=S.questState.grindPending.map(function(gp){
  var r=parseInt(gp.reward);
  if(isNaN(r)||r<=0){var gDef=GRIND.filter(function(g){return g.id===gp.id;})[0];r=gDef?Math.floor(gDef.baseGp*0.9):20;}
  return Object.assign({},gp,{reward:r,chars:gp.chars||[]});
});
if(S.questState.cycleNum===undefined)S.questState.cycleNum=0;
checkQuestCycleReset();
if(!S.archGroups)S.archGroups=[];
if(!S.archCollapsed)S.archCollapsed={};
if(!S.settings)S.settings={appName:'',subtitle:'',fontSize:18,morningHour:6};
if(!S.settings.morningHour)S.settings.morningHour=6;
if(!S.lastFavCheck)S.lastFavCheck='';
if(S.partyTagFilter===undefined)S.partyTagFilter=null;
if(!S.recruitRollDate)S.recruitRollDate='';
if(!S.hirelRollDate)S.hirelRollDate='';
if(!S.lastRerollReset)S.lastRerollReset='';

save();
applySettings();
checkFavourites();
setGold();
renderTasks();
autoCollectExpired();

var _localPending=(S.questState&&S.questState.pending&&S.questState.pending.length)?S.questState.pending.slice():[];
var _localGrind=(S.questState&&S.questState.grindPending&&S.questState.grindPending.length)?S.questState.grindPending.slice():[];

sbPull(false).then(function(){
  if(S.questState){
    if((!S.questState.pending||!S.questState.pending.length)&&_localPending.length)S.questState.pending=_localPending;
    if((!S.questState.grindPending||!S.questState.grindPending.length)&&_localGrind.length)S.questState.grindPending=_localGrind;
  }
  checkQuestCycleReset();
  autoCollectExpired();
  setGold();
  renderTasks();
  renderSettings();
  renderAdv();
}).catch(function(){});

}());
