function charHasTag(c,ci,tag){
  if(!tag)return false;
  // Squad membership
  var inSq=(S.squads||[]).some(function(s){
    return s.name===tag&&(s.memberIdxs||[]).indexOf(ci)!==-1;
  });
  if(inSq)return true;
  // Skills, languages, tools, weapons
  if((c.skills||[]).indexOf(tag)!==-1)return true;
  if((c.lang||[]).indexOf(tag)!==-1)return true;
  if((c.tools||[]).indexOf(tag)!==-1)return true;
  if((c.weapons||[]).indexOf(tag)!==-1)return true;
  // Faith
  if(c.rel===tag)return true;
  // Inventory (real items only)
  var realInv=(c.inv||[]).filter(function(x){return typeof x==='string'&&x.indexOf('__meta__')!==0;});
  if(realInv.indexOf(tag)!==-1)return true;
  return false;
}

function renderParty(){
  if(typeof partyStatsOpen!=='undefined'&&partyStatsOpen)renderPartyStats();
  var el=document.getElementById('plist');
  if(!S.party.length){el.innerHTML='<div class="empty">No adventurers. Visit the Recruitment Office!</div>';return;}
  var squads=S.squads||[];
  var activeFilter=S.partyTagFilter||null;

  // Build set of character indices currently on quests or grind missions
  var questingChars={};
  var now=Date.now();
  (S.questState&&S.questState.pending||[]).forEach(function(pq){
    if(pq.doneAt>now)(pq.chars||[]).forEach(function(ci){questingChars[ci]=true;});
  });
  (S.questState&&S.questState.grindPending||[]).forEach(function(gp){
    if(gp.doneAt>now)(gp.chars||[]).forEach(function(ci){questingChars[ci]=true;});
  });

  // Squad tag filter bar
  var tagBar='<div style="margin-bottom:10px">'+
    '<div style="display:flex;flex-wrap:wrap;align-items:center;gap:6px;margin-bottom:6px">'+
    '<span style="font-family:\'Cinzel\',serif;font-size:.72em;color:var(--ink-light);text-transform:uppercase;letter-spacing:.04em">Squads:</span>'+
    (squads.length?squads.map(function(sq,sqi){
      var isActive=activeFilter===sq.name;
      return '<span class="squad-tag'+(isActive?' squad-tag-active':'')+'" data-a="ptag" data-v="'+esc(sq.name)+'">⚔ '+esc(sq.name)+
        ' <span style="font-size:.75em;opacity:.7">('+((sq.memberIdxs||[]).filter(function(ci){return S.party[ci];}).length)+')</span></span>'+
        '<button class="btn bink sm" data-a="sqedit" data-sqi="'+sqi+'" style="font-size:.62em;padding:1px 5px;min-height:18px">Edit</button>';
    }).join(''):'<span style="font-size:.8em;color:var(--ink-light);font-style:italic">No squads yet.</span>')+
    '<button class="btn bg sm" data-a="sqnew" style="margin-left:auto">+ Squad</button>'+
    '</div>'+
    (activeFilter?'<div style="font-size:.75em;color:var(--ink-light);margin-bottom:6px">'+
      '🔍 Filtered by: <strong style="color:var(--crimson)">'+esc(activeFilter)+'</strong> — '+
      '<button class="btn bink sm" data-a="ptag" data-v="" style="font-size:.75em;padding:1px 6px;min-height:18px">✕ Clear</button></div>':'')+
    '</div>';

  // Filter/sort party: if filter active, only show matching characters (sorted to top)
  var ordered=S.party.map(function(c,ci){return{c:c,ci:ci};});
  if(activeFilter){
    ordered=ordered.filter(function(x){return charHasTag(x.c,x.ci,activeFilter);});
  }

  var html=tagBar+(ordered.length?ordered.map(function(x){
    var questing=questingChars[x.ci]||false;
    return charCardHtml(x.c,x.ci,{questing:questing});
  }).join(''):
    '<div class="empty">No characters match "'+esc(activeFilter)+'".</div>');

  // Assets — collapsible with gold total
  var assets=S.partyAssets||[];
  if(!S.assetsCollapsed)S.assetsCollapsed=false;
  var assetsCollapsed=S.assetsCollapsed;

  // Calculate total gold value by matching against all item lists
  var allPurchasables=[].concat(VEHICLES,BUILDINGS,PETS,GEAR);
  var totalValue=0;
  // Also count hire costs for party members and level-up costs
  S.party.forEach(function(c){
    if(c.hireCost)totalValue+=c.hireCost;
    for(var lv=1;lv<c.level;lv++)totalValue+=lv*50;
  });
  assets.forEach(function(a){
    var match=allPurchasables.filter(function(x){return x.name===a.name;});
    if(match.length)totalValue+=match[0].price;
  });

  html+='<div class="card" style="margin-top:14px;padding:9px 12px">'+
    '<div style="display:flex;align-items:center;cursor:pointer;user-select:none" data-a="assets-col">'+
    '<span style="font-size:.8em;margin-right:5px">'+(assetsCollapsed?'▶':'▼')+'</span>'+
    '<span style="font-family:\'Cinzel\',serif;font-size:.78em;text-transform:uppercase;letter-spacing:.05em;color:var(--gold-dark);flex:1">'+
    '🏰 Assets &amp; Investments</span>'+
    '<span style="font-family:\'Cinzel\',serif;font-size:.75em;color:var(--gold-dark);font-weight:700">'+totalValue.toLocaleString()+' gp invested</span>'+
