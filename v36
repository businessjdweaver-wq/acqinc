function cycleId(){var d=new Date();return d.getFullYear()+'-'+d.getMonth();}
function cycleLabel(){var d=new Date();return d.toLocaleString('default',{month:'long'})+' '+d.getFullYear();}

function questDuration(){
  var t=(S.settings&&S.settings.testQuestMins)||0;
  if(t>0)return t*60000;
  return 8*3600000;
}
function questDurationLabel(){
  var t=(S.settings&&S.settings.testQuestMins)||0;
  if(t>0)return t+' min (test)';
  return '8 hours';
}

function initQuestState(cycleNum){
  var num=cycleNum||0;
  var set=activeQuestSet();
  S.questState={
    cycleId:cycleId(),
    setId:set.id,
    cycleNum:num,
    revealed:set.quests.map(function(q){return q.idx;}),
    done:[],
    pending:[],
    assigned:{},
    grindPending:[]
  };
}

function checkQuestCycleReset(){
  if(!S.questState||!S.questState.cycleId){initQuestState(0);return;}
  var cur=cycleId();
  if(S.questState.cycleId===cur)return;
  var old=S.questState;
  var set=activeQuestSet();
  var missed=set.quests.filter(function(q){return old.done.indexOf(q.idx)===-1;}).map(function(q){return q.title;});
  if(!S.questCycles)S.questCycles=[];
  S.questCycles.push({cycleId:old.cycleId,setId:old.setId,completed:old.done,missed:missed});
  var msg='New quest cycle: '+cycleLabel()+'. Previous: '+old.done.length+' completed'+(missed.length?' · missed: '+missed.join(', '):'');
  logAdd(msg,'adv');
  initQuestState((old.cycleNum||0)+1);
  save();
}

function partyMaxLevel(){
  var max=0;
  (S.party||[]).forEach(function(c){if(!c.hireling&&c.level>max)max=c.level;});
  return max;
}

function partyDndTier(maxLv){
  if(maxLv>=17)return 4;
  if(maxLv>=11)return 3;
  if(maxLv>=5)return 2;
  return 1;
}

function questCalcReward(q,charIdxs){
  var tier=QTIERS[q.tier]||QTIERS.common;
  var range=tier.baseRange;
  var b=q.baseGp||Math.floor(range[0]+Math.random()*(range[1]-range[0]));
  var topLevel=0;
  (charIdxs||[]).forEach(function(ci){
    var c=S.party[ci];if(c&&!c.hireling&&c.level>topLevel)topLevel=c.level;
  });
  b+=Math.max(0,topLevel-(tier.minLv||1))*tier.lvBonus;
  var assetNames=(S.partyAssets||[]).map(function(a){return a.name;});
  if(q.vehicleReq&&assetNames.indexOf(q.vehicleReq.name)!==-1)b+=Math.round(q.baseGp*0.25);
  if(q.buildingReq&&assetNames.indexOf(q.buildingReq.name)!==-1)b+=Math.round(q.baseGp*0.25);
  return b;
}

function questPrereqCheck(q,charIdxs){
  var pr=q.pre,missing=[];
  var sk=[],to=[],la=[],re=[],inv=[];
  (charIdxs||[]).forEach(function(ci){
    var c=S.party[ci];if(!c)return;
    (c.skills||[]).forEach(function(s){if(DND.skills.indexOf(s)!==-1)sk.push(s);});
    (c.tools||[]).forEach(function(t){if(DND.tools.indexOf(t)!==-1)to.push(t);});
    (c.lang||[]).forEach(function(l){if(DND.lang.indexOf(l)!==-1)la.push(l);});
    if(c.rel)re.push(c.rel);
    (c.inv||[]).filter(function(x){return typeof x==='string'&&x.indexOf('__meta__')!==0;}).forEach(function(x){inv.push(x);});
  });
  (pr.skills||[]).forEach(function(s){if(sk.indexOf(s)===-1)missing.push('Skill: '+s);});
  (pr.tools||[]).forEach(function(t){if(to.indexOf(t)===-1)missing.push('Tool: '+t);});
  (pr.lang||[]).forEach(function(l){if(la.indexOf(l)===-1)missing.push('Language: '+l);});
  if(pr.rel&&re.indexOf(pr.rel)===-1)missing.push('Faith: '+pr.rel);
  (pr.items||[]).forEach(function(x){if(inv.indexOf(x)===-1)missing.push('Item: '+x);});
  if(pr.gold&&S.gold<pr.gold)missing.push('Gold: '+pr.gold+' gp');
  var topLevel=0;
  (charIdxs||[]).forEach(function(ci){var c=S.party[ci];if(c&&!c.hireling&&c.level>topLevel)topLevel=c.level;});
  if(QTIERS[q.tier]&&QTIERS[q.tier].minLv>0&&topLevel<QTIERS[q.tier].minLv)
    missing.push('Party level '+QTIERS[q.tier].minLv+'+ (highest: '+topLevel+')');
  return missing;
}

