    S.active[i].burnerUntil=null;
    logAdd('"'+S.active[i].name+'" returned to active contracts','task');
    save();renderTasks();
  } else if(a==='brn'){
    P.brn=i;
    document.getElementById('ov-brn-name').textContent=S.active[i].name;
    openOv('ov-burner');
  } else if(a==='col'){
    S.active[i].collapsed=!S.active[i].collapsed;
    save();renderTasks();
