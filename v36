function pickClassSkills(cls){
  var cs=CLASS_SKILLS[cls];
  if(!cs)return pick(DND.skills,4);
  var skills=[cs.mandatory];
  var pool=cs.choose.filter(function(s){return s!==cs.mandatory;});
  skills.push(rnd(pool));
  if(cls==='Bard'){
    var bp=DND.skills.filter(function(s){return skills.indexOf(s)===-1;});
    skills.push(rnd(bp));
  }
  var remaining=DND.skills.filter(function(s){return skills.indexOf(s)===-1;});
  pick(remaining,4-skills.length).forEach(function(s){skills.push(s);});
  return skills;
}

