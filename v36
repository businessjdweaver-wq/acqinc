/* ═══════════════════════ RENDER ADV ═══════════════════════ */
var advCountdownTimer=null;

function renderAdv(){
  var el=document.getElementById('avcontent');
  if(!el)return;
  var qs=S.questState;
  if(!S.questState||S.questState.cycleId!==cycleId()){checkQuestCycleReset();}
  if(!S.questState){el.innerHTML='<div class="empty">No quest data.</div>';return;}

  var set=activeQuestSet();
  if(!set){el.innerHTML='<div class="empty">No quest sets available.</div>';return;}

  if(advCountdownTimer){clearInterval(advCountdownTimer);advCountdownTimer=null;}

  var now=Date.now();
  var pendingByIdx={};
  (qs.pending||[]).forEach(function(pq){pendingByIdx[pq.idx]=pq;});

  var doneCount=qs.done.length;
  var totalQ=set.quests.length;
  var pct=totalQ>0?Math.round(doneCount/totalQ*100):0;

  var html='<div style="background:rgba(44,26,14,.05);border:1px solid var(--parchment-deep);'+
    'border-radius:7px;padding:10px 12px;margin-bottom:14px">'+
    '<div style="font-family:\'Cinzel\',serif;font-size:.78em;color:var(--gold-dark);margin-bottom:5px">'+esc(set.name)+'</div>'+
    '<div style="font-size:.78em;color:var(--ink-light);margin-bottom:8px;font-style:italic">'+esc(set.theme)+'</div>'+
    '<div class="adv-prog"><div class="adv-bar" style="width:'+pct+'%"></div></div>'+
    '<div style="font-size:.72em;color:var(--parchment-deep);margin-top:3px">'+doneCount+' / '+totalQ+' quests completed</div>'+
    '</div>';

  set.quests.forEach(function(q){
    var isDone=qs.done.indexOf(q.idx)!==-1;
    var pq=pendingByIdx[q.idx];
    var inProgress=pq&&!isDone;
    var tier=QTIERS[q.tier]||QTIERS.common;

    var nonCapstoneDone=qs.done.filter(function(di){var dq=set.quests[di];return dq&&!dq.capstone;}).length;
    var capstoneUnlocked=nonCapstoneDone>=2;
    if(q.capstone&&!isDone&&!inProgress&&!capstoneUnlocked){
      html+='<div class="enc-card" style="border-color:var(--gold-dark);border-style:dashed">'+
        '<div style="display:flex;align-items:center;gap:6px;margin-bottom:3px">'+
        '<span>⭐</span>'+
        '<span style="display:inline-block;font-family:\'Cinzel\',serif;font-size:.62em;font-weight:700;background:'+tier.color+';color:#fff;border-radius:3px;padding:1px 5px">'+tier.badge+'</span>'+
        '<span class="etype" style="color:var(--gold-dark)">CAPSTONE · '+tier.label.toUpperCase()+'</span>'+
        '</div>'+
        '<div class="etitle">'+esc(q.title)+'</div>'+
        '<div style="font-size:.78em;color:var(--ink-light);margin-top:5px;font-style:italic">🔒 Complete '+Math.max(0,2-nonCapstoneDone)+' more quest'+(Math.max(0,2-nonCapstoneDone)!==1?'s':'')+' to unlock</div>'+
        '<div style="margin-top:6px"><div style="height:5px;background:rgba(44,26,14,.1);border-radius:3px">'+
        '<div style="width:'+Math.round(Math.min(nonCapstoneDone,2)/2*100)+'%;height:100%;background:var(--gold-dark);border-radius:3px"></div>'+
        '</div></div></div>';
      return;
    }

    var readiness=!isDone&&!inProgress?questReadiness(q,qs):'ready';
    var borderCol=isDone?'var(--forest)':inProgress?'var(--gold-dark)':
      q.capstone?'var(--gold-dark)':
      readiness==='ready'?'var(--forest)':readiness==='stretch'?'var(--gold-dark)':'var(--crimson)';

    var nameSource=inProgress?(pq.chars||[]):(qs.assigned[q.idx]||qs.assigned[String(q.idx)]||[]);
    var names=nameSource.map(function(ci){return S.party[ci]?S.party[ci].name:'?';});

    var statusHtml='';
    if(inProgress){
      var remaining=pq.doneAt-now;
      var ready=remaining<=0;
      statusHtml='<div style="margin-top:6px;padding:7px 10px;background:rgba(201,146,42,.12);border:1px solid var(--gold-dark);border-radius:5px">'+
        '<div style="font-family:Cinzel,serif;font-size:.72em;color:var(--gold-dark);margin-bottom:3px">'+(ready?'✅ Quest complete — reward ready!':'⏳ In progress')+'</div>'+
        '<div style="font-family:monospace;font-size:.82em;color:var(--ink)" id="qcd-'+q.idx+'">'+fmtCountdown(remaining)+'</div>'+
        '<div style="font-size:.72em;color:var(--ink-light);margin-top:2px">'+
        names.map(function(n){return '<span style="background:rgba(139,26,26,.1);border:1px solid rgba(139,26,26,.3);border-radius:5px;padding:1px 5px;color:var(--crimson)">⚔ '+esc(n)+'</span>';}).join(' ')+
        '</div><div style="font-size:.72em;color:var(--gold-dark);margin-top:2px">💰 Reward: '+pq.reward+' gp</div>'+
        (ready?'<button class="btn bgn sm" style="margin-top:6px" data-a="qcollect" data-qi="'+q.idx+'">🏆 Collect '+pq.reward+' gp</button>':'')+
        '</div>';
    } else if(isDone){
      statusHtml='<div style="color:var(--forest);font-size:.8em;margin-top:5px">✓ Completed this cycle</div>';
    } else {
      var ri=readiness==='ready'?'🟢 Ready':readiness==='stretch'?'🟡 Stretch':'🔴 Overreach';
      statusHtml='<div style="font-size:.72em;margin-top:4px">'+ri+'</div>';
    }

    html+='<div class="enc-card" style="border-color:'+borderCol+';border-width:1.5px">'+
      '<div style="display:flex;align-items:center;gap:6px;margin-bottom:3px">'+
      (q.capstone?'<span>⭐</span>':'')+
      '<span style="display:inline-block;font-family:\'Cinzel\',serif;font-size:.62em;font-weight:700;background:'+tier.color+';color:#fff;border-radius:3px;padding:1px 5px">'+tier.badge+'</span>'+
      '<span class="etype et-'+q.type+'" style="color:'+tier.color+'">'+(q.capstone?'CAPSTONE · ':'')+tier.label.toUpperCase()+' · '+q.type.toUpperCase()+'</span>'+
      '</div>'+
      '<div class="etitle">'+esc(q.title)+'</div>'+
      '<div class="edesc">'+esc(q.desc)+'</div>'+
      statusHtml+
      (names.length&&!inProgress&&!isDone?'<div style="font-size:.72em;color:var(--ink-light);margin-top:3px">Previously: '+names.map(function(n){return esc(n);}).join(', ')+'</div>':'')+
      (!isDone&&!inProgress?'<button class="btn bg sm" style="margin-top:7px" data-a="qassign" data-qi="'+q.idx+'">⚔ Assign & Begin</button>':'')+
      '</div>';
  });

  // Grind missions — shown when all main quests completed
  if(doneCount>=totalQ){
    var gByIdx={};
    (qs.grindPending||[]).forEach(function(gp){gByIdx[gp.id]=gp;});
    html+='<div style="font-family:\'Cinzel\',serif;font-size:.78em;color:var(--gold-dark);'+
      'border-top:1px dashed var(--parchment-deep);margin-top:14px;padding-top:10px;margin-bottom:8px">'+
      '⚙ Grind Missions <span style="font-weight:400;color:var(--ink-light);font-size:.9em">— repeatable, common reward, no expertise gained</span></div>';

    (GRIND||[]).forEach(function(g){
      var gp=gByIdx[g.id];
      var inProg=!!gp;
      var rem=gp?gp.doneAt-now:0;
      var ready=inProg&&rem<=0;
      var readiness=!inProg?grindReadiness(g):'ready';
      var borderCol=inProg?'var(--gold-dark)':
        readiness==='ready'?'var(--forest)':readiness==='stretch'?'var(--gold-dark)':'var(--crimson)';
      var ri=readiness==='ready'?'🟢 Ready':readiness==='stretch'?'🟡 Stretch':'🔴 Overreach';

      // Prereq summary row (only when not in progress)
      var prereqSummary='';
      if(!inProg){
        var preItems=[];
        (g.pre.skills||[]).forEach(function(s){preItems.push('⭐ '+s);});
        (g.pre.tools||[]).forEach(function(t){preItems.push('🔧 '+t);});
        (g.pre.lang||[]).forEach(function(l){preItems.push('🗣 '+l);});
        if(preItems.length){
          prereqSummary='<div style="font-size:.72em;color:var(--ink-light);margin-top:3px">Needs: '+preItems.join(', ')+'</div>';
        }
      }

      // In-progress: assigned char names from grindPending
      var namesHtml='';
      if(inProg&&gp.chars&&gp.chars.length){
        namesHtml='<div style="font-size:.72em;color:var(--ink-light);margin-top:2px">'+
          gp.chars.map(function(ci){return '<span style="background:rgba(139,26,26,.1);border:1px solid rgba(139,26,26,.3);border-radius:5px;padding:1px 5px;color:var(--crimson)">⚔ '+esc(S.party[ci]?S.party[ci].name:'?')+'</span>';}).join(' ')+
          '</div>';
      }

      html+='<div class="enc-card" style="border-color:'+borderCol+';border-width:1.5px">'+
        '<div style="display:flex;align-items:center;gap:6px;margin-bottom:3px">'+
        '<span style="display:inline-block;font-family:\'Cinzel\',serif;font-size:.62em;font-weight:700;'+
        'background:var(--ink-light);color:#fff;border-radius:3px;padding:1px 5px">G</span>'+
        '<span class="etype et-'+g.type+'" style="color:var(--ink-light)">GRIND · '+g.type.toUpperCase()+'</span>'+
        (!inProg?'<span style="margin-left:auto;font-size:.72em">'+ri+'</span>':'')+
        '</div>'+
        '<div class="etitle">'+esc(g.title)+'</div>'+
        '<div class="edesc">'+esc(g.desc)+'</div>'+
        prereqSummary+
        (inProg?
          '<div style="margin-top:6px;padding:6px 10px;background:rgba(201,146,42,.1);border:1px solid var(--gold-dark);border-radius:5px">'+
          '<div style="font-size:.72em;color:var(--gold-dark);margin-bottom:2px">'+(ready?'✅ Complete — collect reward!':'⏳ In progress')+'</div>'+
          '<div style="font-family:monospace;font-size:.82em;color:var(--ink)" id="gcd-'+g.id+'">'+(ready?'Ready!':fmtCountdown(rem))+'</div>'+
          namesHtml+
          '<div style="font-size:.72em;color:var(--gold-dark);margin-top:2px">💰 Reward: '+gp.reward+' gp</div>'+
          (ready?'<button class="btn bgn sm" style="margin-top:5px" data-a="gcollect" data-gid="'+g.id+'">🏆 Collect '+gp.reward+' gp</button>':'')+
          '</div>':
          '<div style="display:flex;justify-content:space-between;align-items:center;margin-top:7px">'+
          '<span style="font-size:.75em;color:var(--gold-dark)">~'+g.baseGp+' gp · '+questDurationLabel()+'</span>'+
          '<button class="btn bink sm" data-a="gassign" data-gid="'+g.id+'">⚔ Assign & Send</button>'+
          '</div>')+
        '</div>';
    });
  }

  el.innerHTML=html;

  // Countdown timer
  var hasPending=(qs.pending||[]).length>0||(qs.grindPending||[]).length>0;
  if(hasPending){
    advCountdownTimer=setInterval(function(){
      var n=Date.now();
      (S.questState.pending||[]).forEach(function(pq){
        var cdEl=document.getElementById('qcd-'+pq.idx);
        if(cdEl){var rem=pq.doneAt-n;cdEl.textContent=fmtCountdown(rem);if(rem<=0){clearInterval(advCountdownTimer);renderAdv();}}
      });
      (S.questState.grindPending||[]).forEach(function(gp){
        var cdEl=document.getElementById('gcd-'+gp.id);
        if(cdEl){var rem=gp.doneAt-n;cdEl.textContent=rem<=0?'✅ Ready!':fmtCountdown(rem);if(rem<=0){clearInterval(advCountdownTimer);renderAdv();}}
      });
    },1000);
  }
}

/* ── Quest modal handlers ── */
function questModalShowTab(name){
  document.querySelectorAll('.qtab').forEach(function(t){
    var active=t.getAttribute('data-qt')===name;
    t.classList.toggle('on',active);
    t.style.color=active?'var(--gold-dark)':'var(--ink-light)';
    t.style.borderBottom=active?'2px solid var(--gold-dark)':'none';
  });
  document.querySelectorAll('.qt-pane').forEach(function(p){p.style.display='none';});
  var target=document.getElementById('qt-'+name);
  if(target)target.style.display='block';
}

document.getElementById('avcontent').addEventListener('click',function(e){
  var qs=S.questState;
  var set=activeQuestSet();

  var bc=e.target.closest('[data-a="qcollect"]');
  if(bc){
    var qi=parseInt(bc.getAttribute('data-qi'));
    var pqIdx2=-1;
    (qs.pending||[]).forEach(function(pq,pi){if(pq.idx===qi)pqIdx2=pi;});
    if(pqIdx2===-1)return;
    var pq2=qs.pending[pqIdx2];
    if(pq2.doneAt>Date.now()){alert('Not ready yet! '+fmtCountdown(pq2.doneAt-Date.now()));return;}
    var q=set.quests[qi];if(!q)return;
    collectQuest(qi,pq2,q,set);
    save();setGold();renderAdv();
    return;
  }

  var gc=e.target.closest('[data-a="gcollect"]');
  if(gc){
    var gid=gc.getAttribute('data-gid');
    var gpIdx=-1;
    (qs.grindPending||[]).forEach(function(gp,gi){if(gp.id===gid)gpIdx=gi;});
    if(gpIdx===-1)return;
    var gpEntry=qs.grindPending[gpIdx];
    if(gpEntry.doneAt>Date.now()){alert('Not ready yet!');return;}
    // Coerce reward to integer — guard against old NaN/undefined saved data
    var gReward=parseInt(gpEntry.reward)||0;
    var cn=((gpEntry.chars||[]).map(function(ci){return S.party[ci]?S.party[ci].name:'?';})).join(', ')||'unassigned';
    goldAdd(gReward,'Grind: "'+gpEntry.title+'" ('+cn+')','adv');
    // Add to quest completion log
    if(!S.questLog)S.questLog=[];
    S.questLog.unshift({
      cycleId:S.questState.cycleId,
      questTitle:gpEntry.title+' [Grind]',
      type:'grind',
      reward:gReward,
      franchiseCut:gReward,
      chars:(gpEntry.chars||[]).map(function(ci){return {name:S.party[ci]?S.party[ci].name:'?',cut:0,item:null};}),
      completedAt:new Date().toLocaleString()
    });
    qs.grindPending.splice(gpIdx,1);
    save();renderAdv();
    return;
  }

  var ga=e.target.closest('[data-a="gassign"]');
  if(ga){
    var gid2=ga.getAttribute('data-gid');
    var gObj=GRIND.filter(function(g){return g.id===gid2;})[0];
    if(!gObj)return;
    // Reuse the quest modal — store grind id in P4 with a 'grind' flag
    P4.quest=null;
    P4.grind=gid2;
    document.getElementById('ov-q-title').textContent=gObj.title;
    document.getElementById('ov-q-desc').textContent=gObj.desc;
    document.getElementById('ov-q-dur-label').textContent=questDurationLabel();
    var pr=gObj.pre;

    // Build busy map
    var busyG={};
    var now0G=Date.now();
    (qs.pending||[]).forEach(function(pq){if(pq.doneAt>now0G)(pq.chars||[]).forEach(function(ci){busyG[ci]=true;});});
    (qs.grindPending||[]).forEach(function(gp){if(gp.doneAt>now0G)(gp.chars||[]).forEach(function(ci){busyG[ci]=true;});});

    var totalPre2=(pr.skills||[]).length+(pr.tools||[]).length+(pr.lang||[]).length+(pr.rel?1:0);
    function scoreG(c){
      var s=0;
      (pr.skills||[]).forEach(function(x){if((c.skills||[]).indexOf(x)!==-1)s++;});
      (pr.tools||[]).forEach(function(x){if((c.tools||[]).indexOf(x)!==-1)s++;});
      (pr.lang||[]).forEach(function(x){if((c.lang||[]).indexOf(x)!==-1)s++;});
      if(pr.rel&&c.rel===pr.rel)s++;
      return s;
    }

    var bestEl=document.getElementById('ov-q-best');
    if(totalPre2>0&&S.party.length){
      var scoredG=S.party.map(function(c,ci){return{ci:ci,sc:scoreG(c),name:c.name};})
        .filter(function(x){return !busyG[x.ci]&&!S.party[x.ci].hireling;})
        .sort(function(a,b2){return b2.sc-a.sc;});
      if(scoredG.length&&scoredG[0].sc>0){bestEl.style.display='block';bestEl.textContent='💡 Best fit: '+scoredG.slice(0,2).map(function(x){return x.name;}).join(', ');}
      else bestEl.style.display='none';
    } else bestEl.style.display='none';

    var charListG=S.party.map(function(c,ci){
      var isBusy=!!busyG[ci];
      var sc=scoreG(c);
      var pct=totalPre2>0?Math.round(sc/totalPre2*100):100;
      return{ci:ci,c:c,isBusy:isBusy,sc:sc,pct:pct};
    }).sort(function(a,b){if(a.isBusy!==b.isBusy)return a.isBusy?1:-1;return b.sc-a.sc;});

    document.getElementById('ov-q-chars').innerHTML=charListG.length?
      charListG.map(function(entry){
        var ci=entry.ci,c=entry.c,isBusy=entry.isBusy,pct=entry.pct;
        var pr2=gObj.pre;
        var pctCol=pct>=100?'var(--forest)':pct>=50?'var(--gold-dark)':'var(--crimson)';
        var pctBadge=totalPre2>0?'<span style="font-size:.75em;color:'+pctCol+';margin-left:4px;font-weight:700">'+pct+'%</span>':'';
        var bl=isBusy?'<span style="font-size:.75em;color:var(--crimson);margin-left:4px">⚔ on quest</span>':'';
        var contribHtml='';
        if(totalPre2>0&&pct<100&&!isBusy){
          var contrib=[];
          (pr2.skills||[]).forEach(function(s){if((c.skills||[]).indexOf(s)!==-1)contrib.push('⭐ '+s);});
          (pr2.tools||[]).forEach(function(t){if((c.tools||[]).indexOf(t)!==-1)contrib.push('🔧 '+t);});
          (pr2.lang||[]).forEach(function(l){if((c.lang||[]).indexOf(l)!==-1)contrib.push('🗣 '+l);});
          if(contrib.length)contribHtml='<div style="font-size:.78em;color:var(--ink-light);margin-left:22px;margin-top:1px">Brings: '+contrib.join(', ')+'</div>';
        }
        return '<div style="margin-bottom:5px">'+
          '<label style="'+(isBusy?'opacity:.45;cursor:not-allowed;':'')+'display:flex;align-items:center;gap:6px">'+
          '<input type="checkbox" class="qcb" value="'+ci+'"'+(isBusy?' disabled':'')+' style="width:auto">'+
          '<span style="font-size:.92em">'+esc(c.name)+'</span>'+
          '<span style="font-size:.82em;color:var(--ink-light)">('+esc(c.cls)+', Lv '+c.level+')</span>'+
          pctBadge+bl+'</label>'+contribHtml+'</div>';
      }).join(''):'<div style="font-style:italic;font-size:.88em;color:var(--ink-light)">No adventurers yet.</div>';

    // Show prereqs tab
    questModalShowTab('prereqs');
    updateQuestModal(); // populate prereqs for empty selection
    openOv('ov-quest');
    return;
  }

  var b=e.target.closest('[data-a="qassign"]');
  if(!b)return;
  var qi2=parseInt(b.getAttribute('data-qi'));
  P4.quest=qi2;
  var q2=set.quests[qi2];if(!q2)return;
  var pr=q2.pre;

  document.getElementById('ov-q-title').textContent=q2.title;
  document.getElementById('ov-q-desc').textContent=q2.desc;
  document.getElementById('ov-q-dur-label').textContent=questDurationLabel();

  var busy={};
  var now0=Date.now();
  (qs.pending||[]).forEach(function(pq){
    if(pq.idx===qi2)return;
    if(pq.doneAt>now0)(pq.chars||[]).forEach(function(ci){busy[ci]=true;});
  });

  var totalPre=(pr.skills||[]).length+(pr.tools||[]).length+(pr.lang||[]).length+(pr.rel?2:0)+(pr.items||[]).length;
  function score(c){
    var s=0;
    (pr.skills||[]).forEach(function(x){if((c.skills||[]).indexOf(x)!==-1)s++;});
    (pr.tools||[]).forEach(function(x){if((c.tools||[]).indexOf(x)!==-1)s++;});
    (pr.lang||[]).forEach(function(x){if((c.lang||[]).indexOf(x)!==-1)s++;});
    if(pr.rel&&c.rel===pr.rel)s+=2;
    (pr.items||[]).forEach(function(x){if((c.inv||[]).indexOf(x)!==-1)s++;});
