document.getElementById('alist').addEventListener('click',function(e){
  var b=e.target.closest('[data-a]');
  if(!b)return;
  var a=b.getAttribute('data-a');
  var ai=parseInt(b.getAttribute('data-i'));
  var k=b.getAttribute('data-k');

  if(a==='ag-col'){
    if(!S.archCollapsed)S.archCollapsed={};
    S.archCollapsed[k]=!S.archCollapsed[k];
    save();renderArchive();
  } else if(a==='ag-up'||a==='ag-dn'){
    var order=archGroupOrder();
    var idx=order.indexOf(k);
    var swap=a==='ag-up'?idx-1:idx+1;
    if(swap>=0&&swap<order.length){
      if(!S.archGroups||!S.archGroups.length){
        S.archGroups=order.map(function(x){return{key:x,label:FLAB[x]||x};});
      }
      // Reorder S.archGroups to match
      var tmp=order[idx];order[idx]=order[swap];order[swap]=tmp;
      S.archGroups=order.map(function(x){return{key:x,label:FLAB[x]||x};});
      save();renderArchive();
    }
  } else if(a==='afav'){
    S.archived[ai].fav=!S.archived[ai].fav;
    save();renderArchive();
  } else if(a==='aup'||a==='adn'){
    var t=S.archived[ai];
    var grpKey=t.archGroup||(t.freq||'custom');
    var grpIdxs=[];
    S.archived.forEach(function(x,xi){if((x.archGroup||(x.freq||'custom'))===grpKey)grpIdxs.push(xi);});
    var pos=grpIdxs.indexOf(ai);
    var sw=a==='aup'?grpIdxs[pos-1]:grpIdxs[pos+1];
    if(sw!==undefined){
      var tmp2=S.archived[ai];S.archived[ai]=S.archived[sw];S.archived[sw]=tmp2;
      save();renderArchive();
    }
  } else if(a==='aname-edit'){
    var curName=S.archived[ai].name;
    var newName=(prompt('Edit task name:\nCurrent: "'+curName+'"')||'').trim();
    if(newName&&newName!==curName){
      // Also update any active task with the same name
      S.active.forEach(function(t){if(t.name===curName)t.name=newName;});
      S.archived[ai].name=newName;
      logAdd('Archive task renamed: "'+curName+'" → "'+newName+'"','task');
      save();renderArchive();renderTasks();
    }
  } else if(a==='agp-edit'){
    P2.archMove=null;
    // Inline prompt — use a small popover approach via modal
    var curGp=S.archived[ai].gp;
    var newGp=parseInt(prompt('Edit gold per tick for "'+S.archived[ai].name+'".\nCurrent: '+curGp+' gp\n\nEnter new amount:'),10);
    if(!isNaN(newGp)&&newGp>0){
      S.archived[ai].gp=newGp;
      logAdd('Archive gp updated: "'+S.archived[ai].name+'" → '+newGp+' gp/tick','task');
      save();renderArchive();
    }
  } else if(a==='amove'){
    P2.archMove=ai;
    document.getElementById('ov-am-msg').textContent='Move "'+S.archived[ai].name+'" to a different group.';
    var grps2=archGroups();
    var ord2=archGroupOrder();
    var curK=S.archived[ai].archGroup||(S.archived[ai].freq||'custom');
    document.getElementById('ov-am-dest').innerHTML=ord2.map(function(x){
      return '<option value="'+esc(x)+'"'+(x===curK?' selected':'')+'>'+esc(FLAB[x]||x)+'</option>';
    }).join('');
    openOv('ov-archmove');
  } else if(a==='act'){
    if(b.disabled)return;
    var t2=S.archived[ai];
    if(S.active.some(function(x){return x.name===t2.name;}))return;
    S.active.push({name:t2.name,gp:t2.gp,count:0,freq:t2.freq,cat:t2.cat,
      subtasks:(t2.subtasks||[]).map(function(s){return{name:s.name,done:false};}),
      collapsed:false,fav:t2.fav});
    logAdd('Activated: "'+t2.name+'"','task');
    save();renderTasks();renderArchive();
  }
});

