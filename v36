function sbPull(manual){
  if(manual)syncStatus('Pulling from Supabase…','var(--gold-dark)');
  return Promise.all([
    sbGet('franchise','id=eq.main'),
    sbGet('party','order=sort_order.asc'),
    sbGet('active_tasks','order=sort_order.asc'),
    sbGet('archived_tasks','order=sort_order.asc'),
    sbGet('party_assets','order=sort_order.asc'),
    sbGet('squads','order=created_at.asc'),
    sbGet('quest_cycles','cycle_id=eq.'+cycleId()+'&limit=1'),
    sbGet('gold_log','order=created_at.desc&limit=500'),
