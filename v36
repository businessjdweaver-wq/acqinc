function generateContact(){
  var roll=Math.random();
  var exoticType=roll<0.33?'lang':roll<0.66?'rel':'tool';
  var firstName=rnd(DND.fn);
  var c={
    name:firstName,
    species:rnd(DND.species),cls:'Contact',bg:rnd(DND.bg),
    age:rndInt(20,55),
    height:rndInt(4,6)+"'"+rndInt(0,11)+'"',
    weight:rndInt(100,200)+' lbs',
    skills:[rnd(DND.skills)],
    tools:[],lang:['Common'],weapons:[rnd(DND.weapons)],
    level:0,inv:["Hireling's Pack"],
    hireCost:0,hireling:true,contact:true,
    contactBg:rnd(CONTACT_BG)
  };
  if(exoticType==='lang'){
    var el=rnd(EXOTIC_LANG);
    c.lang.push(el);
    c.exoticTrait='Speaks '+el;
  } else if(exoticType==='rel'){
    c.rel=rnd(EXOTIC_REL);
    c.exoticTrait='Follower of '+c.rel;
  } else {
    var et=rnd(EXOTIC_TOOLS);
    c.tools.push(et);
    c.exoticTrait='Proficient: '+et;
  }
  return c;
}

