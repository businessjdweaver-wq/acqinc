}

/* ── Quest collect + XP ── */
var P4={quest:null,grind:null};

function collectQuest(qi,pq,q,set){
  var totalReward=pq.reward;
  var chars=pq.chars||[];
  var cn=chars.map(function(ci){return S.party[ci]?S.party[ci].name:'?';}).join(', ')||'unassigned';
  var charPool=Math.floor(totalReward*0.10);
  var franchiseCut=totalReward-charPool;
  var weights=[],totalWeight=0;
  chars.forEach(function(ci){
    var c=S.party[ci];
    if(!c){weights.push(0);return;}
    var w=1+(c.level||0);
    Object.keys(XP_TRACKS).forEach(function(track){w+=getXpBadgeLevel(c,track);});
    weights.push(w);totalWeight+=w;
  });
  var charResults=[];
  var unspent=0;
  chars.forEach(function(ci,idx){
    var c=S.party[ci];
    if(!c||!totalWeight){return;}
    var share=Math.floor(charPool*(weights[idx]/(totalWeight||1)));
    var bought=null;
    if(share>0){
      var item=pickItemForChar(c,share);
      if(item){
        if(!c.inv)c.inv=[];
        c.inv.push(item.name);
        unspent+=share-item.price;
        bought=item.name+' ('+item.price+' gp)';
        logAdd(c.name+' spent '+item.price+' gp on '+item.name,'buy');
      } else {
        unspent+=share;
      }
    }
    charResults.push({name:c.name,cut:share,item:bought});
    if(!c.xp)c.xp={};
    var track=q.type;
    if(XP_TRACKS[track]){
      var prevXp=c.xp[track]||0;
      c.xp[track]=prevXp+1;
      var prevBadge=null,newBadge=null;
      XP_TRACKS[track].thresholds.forEach(function(t,i){
        if(prevXp>=t)prevBadge=XP_TRACKS[track].badges[i];
        if(c.xp[track]>=t)newBadge=XP_TRACKS[track].badges[i];
      });
      if(newBadge&&newBadge!==prevBadge)logAdd(c.name+' earned: '+XP_TRACKS[track].icon+' '+newBadge+'!','hire');
    }
  });
  franchiseCut+=unspent;
  goldAdd(franchiseCut,'Quest: "'+q.title+'" ('+cn+') — franchise cut','adv');
  logAdd('Quest completed: "'+q.title+'" — '+totalReward+' gp ('+franchiseCut+' franchise, '+charPool+' adventurers)','adv');
  if(!S.questLog)S.questLog=[];
  S.questLog.unshift({cycleId:S.questState.cycleId,questTitle:q.title,type:q.type,reward:totalReward,franchiseCut:franchiseCut,chars:charResults,completedAt:new Date().toLocaleString()});
  if(!S.questState.done)S.questState.done=[];
  if(S.questState.done.indexOf(qi)===-1)S.questState.done.push(qi);
  var pqIdx=-1;
  (S.questState.pending||[]).forEach(function(p,pi){if(p.idx===qi)pqIdx=pi;});
  if(pqIdx!==-1)S.questState.pending.splice(pqIdx,1);
  if(q.capstone)awardCapstonReward(set);
}

function autoCollectExpired(){
  var qs=S.questState;
  if(!qs||!qs.pending||!qs.pending.length)return;
  var set=activeQuestSet();
  var now=Date.now();
  var collected=[];
  qs.pending.slice().forEach(function(pq){
    if(pq.doneAt<=now&&qs.done.indexOf(pq.idx)===-1){
      var q=set.quests[pq.idx];
      if(!q)return;
      collectQuest(pq.idx,pq,q,set);
      collected.push(q.title);
    }
  });
  if(collected.length){save();setGold();renderAdv();}
}

function awardCapstonReward(set){
  var tier=partyDndTier(partyMaxLevel());
  var pool=CAPSTONE_REWARDS[tier]||CAPSTONE_REWARDS[1];
  var roll=Math.random();
  var reward,msg;
  if(roll<0.33){
    reward=rnd(pool.pets);
    if(!S.partyAssets)S.partyAssets=[];
    S.partyAssets.push({name:reward.name,ic:reward.ic,type:'pet'});
    logAdd('⭐ Capstone reward: '+reward.name+' (pet) joins the franchise!','adv');
    msg='🐾 '+reward.name+'\n'+reward.desc;
  } else if(roll<0.66){
    reward=rnd(pool.items);
    if(!S.partyAssets)S.partyAssets=[];
    S.partyAssets.push({name:reward.name,ic:reward.ic,type:'artifact'});
    logAdd('⭐ Capstone reward: '+reward.name+' acquired!','adv');
    msg='✨ '+reward.name+'\n'+reward.desc;
  } else {
    reward=generateContact();
    S.party.push(reward);
    logAdd('⭐ Capstone reward: '+reward.name+' (🤝 Contact) joins!','hire');
    msg='🤝 New Contact: '+reward.name+'\n'+(reward.contactBg||'')+'\nExotic trait: '+(reward.exoticTrait||'');
  }
  alert('⭐ CAPSTONE REWARD!\n\n'+msg);
}

